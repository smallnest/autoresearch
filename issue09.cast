[0.000, "o", "\u001b[91m\u001b[1m| \u001b[0m\u001b[90m Bash     \u001b[0mCheck no-archive handling in run.sh\r\n\r\n"]
[0.000, "o", "#!/bin/bash\r\n"]
[0.000, "o", "# autoresearch/run.sh - 自动化处理 GitHub Issue\r\n#\r\n# 通用版本 - 可处理任意 Git + GitHub 项目\r\n#\r\n# 用法:\r\n"]
[0.000, "o", "#   ./run.sh [-p project_path] [-a agents] [-c] [--no-archive] <issue_number> [max_iterations]\r\n"]
[0.000, "o", "#\r\n# 示例:\r\n#   ./run.sh 42                              # 处理当前目录项目的 Issue #42\r\n"]
[0.000, "o", "#   ./run.sh -p /path/to/project 42         # 处理指定项目的 Issue #42\r\n"]
[0.000, "o", "#   ./run.sh -p /path/to/project 42 10      # 最多迭代 10 次\r\n#   ./run.sh -a claude,codex 42              # 只启用 Claude 和 Codex\r\n"]
[0.000, "o", "#   ./run.sh -a claude 42                    # 单 agent 模式\r\n#   ./run.sh -a claude,opencode,codex 42     # 自定义 agent 顺序\r\n"]
[0.000, "o", "#   ./run.sh --no-archive 42                 # 跳过归档（调试用）\r\n#\r\n# 要求:\r\n#   - 项目目录必须是 git 仓库\r\n#   - 项目目录必须有 GitHub remote (origin)\r\n"]
[0.000, "o", "#\r\n# 配置文件 (可选):\r\n"]
[0.000, "o", "#   在项目根目录创建 .autoresearch/ 目录，可以放置:\r\n"]
[0.000, "o", "#   - .autoresearch/agents/codex.md     自定义 Codex 指令\r\n"]
[0.000, "o", "#   - .autoresearch/agents/claude.md    自定义 Claude 指令\r\n#   - .autoresearch/agents/opencode.md  自定义 OpenCode 指令\r\n"]
[0.000, "o", "--\r\n\r\n"]
[0.000, "o", "    if [ $success -eq 1 ]; then\r\n        return 0\r\n"]
[0.000, "o", "    else\r\n"]
[0.000, "o", "        error \"$agent 调用失败，已重试 $MAX_RETRIES 次\"\r\n        return 1\r\n    fi\r\n}\r\n\r\nusage() {\r\n"]
[0.000, "o", "    echo \"用法: $0 [-p project_path] [-a agents] [-c] [--no-archive] <issue_number> [max_iterations]\"\r\n"]
[0.000, "o", "    echo \"\"\r\n    echo \"通用自动化 Issue 处理工具，支持任意 Git + GitHub 项目。\"\r\n    echo \"\"\r\n    echo \"参数:\"\r\n    echo \"  -p <path>        项目路径 (默认: 当前目录)\"\r\n"]
[0.000, "o", "    echo \"  -a <agents>      逗号分隔的 agent 列表 (默认: claude,codex,opencode)\"\r\n    echo \"                   第一个 agent 用于初始实现，后续 agent 按顺序轮流审核+修复\"\r\n    echo \"  -c               继续模式，从上次中断的迭代继续\"\r\n"]
[0.000, "o", "    echo \"  --no-archive     跳过归档其他 Issue 的 workflows 数据 (调试用)\"\r\n"]
[0.000, "o", "    echo \"  issue_number     GitHub Issue 编号\"\r\n"]
[0.000, "o", "    echo \"  max_iterations   最大迭代次数 (默认: $DEFAULT_MAX_ITERATIONS)\"\r\n    echo \"\"\r\n"]
[0.000, "o", "    echo \"配置 (环境变量):\"\r\n    echo \"  PASSING_SCORE=85              达标评分线 (百分制)\"\r\n    echo \"  MAX_CONSECUTIVE_FAILURES=3    连续失败最大次数\"\r\n"]
[0.000, "o", "    echo \"\"\r\n    echo \"自定义配置文件 (放在项目目录 .autoresearch/ 下):\"\r\n"]
[0.000, "o", "    echo \"  agents/codex.md              Codex 指令\"\r\n    echo \"  agents/claude.md             Claude 指令\"\r\n"]
[0.000, "o", "--\r\nNO_ARCHIVE=0\r\n"]
[0.001, "o", "AGENT_LIST=\"\"\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "while getopts \"p:a:c-:\" opt; do\r\n    case $opt in\r\n        p) PROJECT_ROOT=\"$(cd \"$OPTARG\" && pwd)\" ;;\r\n        a) AGENT_LIST=\"$OPTARG\" ;;\r\n"]
[0.000, "o", "        c) CONTINUE_MODE=1 ;;\r\n        -)\r\n"]
[0.000, "o", "            case \"$OPTARG\" in\r\n"]
[0.000, "o", "                no-archive) NO_ARCHIVE=1 ;;\r\n                *) usage ;;\r\n            esac\r\n"]
[0.000, "o", "            ;;\r\n        *) usage ;;\r\n"]
[0.000, "o", "    esac\r\ndone\r\nshift $((OPTIND - 1))\r\n"]
[0.000, "o", "\r\nif [ -z \"$1\" ]; then\r\n    usage\r\n\r\nI will search for the string \"no-archive\" in `run.sh` and examine the surrounding lines to understand how it is handled.\r\n\u001b[91m\u001b[1m| \u001b[0m\u001b[90m Bash     \u001b[0mSearch for test_archive.sh in git history\r\nI will check the git log for any commits related to `tests/test_archive.sh` to see if it was recently added or modified.\r\n"]
[0.000, "o", "\u001b[91m\u001b[1m| \u001b[0m\u001b[90m Bash     \u001b[0mCheck setup_work_directory implementation\r\n"]
[0.000, "o", "\r\nsetup_work_directory() {\r\n"]
[0.000, "o", "    local issue_number=$1\r\n\r\n"]
[0.000, "o", "    # 归档其他 Issue 的 workflows 数据（非继续模式且未禁用归档时）\r\n"]
[0.000, "o", "    if [ $CONTINUE_MODE -eq 0 ] && [ $NO_ARCHIVE -eq 0 ]; then\r\n"]
[0.000, "o", "        archive_old_workflows \"$issue_number\"\r\n    fi\r\n\r\n"]
[0.000, "o", "    WORK_DIR=\"$PROJECT_ROOT/.autoresearch/workflows/issue-$issue_number\"\r\n    mkdir -p \"$WORK_DIR\"\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "    log \"工作目录: $WORK_DIR\"\r\n"]
[0.000, "o", "\r\n    if [ $CONTINUE_MODE -eq 1 ]; then\r\n"]
[0.000, "o", "        if [ ! -f \"$WORK_DIR/log.md\" ]; then\r\n"]
[0.000, "o", "            error \"未找到 Issue #$issue_number 的工作日志，无法继续\"\r\n"]
[0.000, "o", "            exit 1\r\n        fi\r\n        log \"继续模式: 追加到已有日志\"\r\n        return\r\n    fi\r\n\r\n"]
