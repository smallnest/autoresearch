[0.000, "o", "+# 归档 workflows 目录下其他 Issue 的数据\r\n"]
[0.000, "o", "+# 将非当前 Issue 的 issue-* 目录移动到 .autoresearch/archive/YYYY-MM-DD-issue-N/\r\n"]
[0.000, "o", "+archive_old_workflows() {\r\n+    local current_issue=$1\r\n"]
[0.000, "o", "+    local workflows_dir=\"$PROJECT_ROOT/.autoresearch/workflows\"\r\n+    local archive_dir=\"$PROJECT_ROOT/.autoresearch/archive\"\r\n"]
[0.000, "o", "+\r\n+    if [ ! -d \"$workflows_dir\" ]; then\r\n+        return 0\r\n"]
[0.000, "o", "+    fi\r\n+\r\n+    local archived_count=0\r\n"]
[0.000, "o", "+    local current_date\r\n"]
[0.000, "o", "+    current_date=$(date '+%Y-%m-%d')\r\n+\r\n+    for dir in \"$workflows_dir\"/issue-*; do\r\n"]
[0.000, "o", "+        [ -d \"$dir\" ] || continue\r\n+\r\n"]
[0.000, "o", "+        local dirname\r\n+        dirname=$(basename \"$dir\")\r\n+        # 跳过当前 Issue 的目录\r\n+        if [ \"$dirname\" = \"issue-$current_issue\" ]; then\r\n"]
[0.000, "o", "+            continue\r\n"]
[0.000, "o", "+        fi\r\n"]
[0.000, "o", "+\r\n+        # 从目录名提取 Issue 编号\r\n"]
[0.000, "o", "+        local issue_num\r\n"]
[0.000, "o", "+        issue_num=$(echo \"$dirname\" | grep -oE '[0-9]+$')\r\n+        [ -z \"$issue_num\" ] && continue\r\n"]
[0.000, "o", "+\r\n+        local target_dir=\"$archive_dir/${current_date}-issue-${issue_num}\"\r\n+\r\n+        # 处理目标目录已存在的情况：追加数字后缀\r\n+        if [ -d \"$target_dir\" ]; then\r\n"]
[0.000, "o", "+            local suffix=1\r\n+            while [ -d \"${target_dir}-${suffix}\" ]; do\r\n+                suffix=$((suffix + 1))\r\n+            done\r\n+            target_dir=\"${target_dir}-${suffix}\"\r\n+        fi\r\n"]
[0.000, "o", "+\r\n+        mkdir -p \"$archive_dir\"\r\n+        mv \"$dir\" \"$target_dir\"\r\n+        log \"已归档: $dirname -> $archive_dir/${current_date}-issue-${issue_num}\"\r\n+        archived_count=$((archived_count + 1))\r\n+    done\r\n"]
[0.000, "o", "+\r\n"]
[0.000, "o", "+    if [ $archived_count -gt 0 ]; then\r\n"]
[0.000, "o", "+        log \"归档完成，共归档 $archived_count 个 Issue 目录\"\r\n"]
[0.000, "o", "+    fi\r\n"]
[0.000, "o", "+}\r\n+\r\n setup_work_directory() {\r\n     local issue_number=$1\r\n \r\n"]
[0.000, "o", "+    # 归档其他 Issue 的 workflows 数据（非继续模式且未禁用归档时）\r\n+    if [ $CONTINUE_MODE -eq 0 ] && [ $NO_ARCHIVE -eq 0 ]; then\r\n+        archive_old_workflows \"$issue_number\"\r\n"]
[0.000, "o", "+    fi\r\n"]
[0.000, "o", "+\r\n"]
[0.000, "o", "     WORK_DIR=\"$PROJECT_ROOT/.autoresearch/workflows/issue-$issue_number\"\r\n     mkdir -p \"$WORK_DIR\"\r\n \r\n@@ -1822,13 +1881,20 @@ restore_continue_state() {\r\n # ==================== 参数解析 ====================\r\n"]
[0.000, "o", " \r\n CONTINUE_MODE=0\r\n+NO_ARCHIVE=0\r\n"]
[0.000, "o", " AGENT_LIST=\"\"\r\n \r\n-while getopts \"p:a:c\" opt; do\r\n+while getopts \"p:a:c-:\" opt; do\r\n     case $opt in\r\n         p) PROJECT_ROOT=\"$(cd \"$OPTARG\" && pwd)\" ;;\r\n"]
[0.000, "o", "         a) AGENT_LIST=\"$OPTARG\" ;;\r\n         c) CONTINUE_MODE=1 ;;\r\n+        -)\r\n+            case \"$OPTARG\" in\r\n+                no-archive) NO_ARCHIVE=1 ;;\r\n"]
[0.000, "o", "+                *) usage ;;\r\n"]
[0.000, "o", "+            esac\r\n+            ;;\r\n         *) usage ;;\r\n"]
[0.000, "o", "     esac\r\n done\r\n\r\nI will run `git diff` to see the changes made to `CLAUDE.md` and `run.sh`.\r\n\u001b[96m\u001b[1m| \u001b[0m\u001b[90m Read     \u001b[0m.autoresearch/workflows/issue-9/log.md\r\n"]
[0.000, "o", "I will read the `log.md` file in the work directory to understand the history of the task and what has been attempted so far.\r\n\u001b[91m\u001b[1m| \u001b[0m\u001b[90m Bash     \u001b[0mCheck for iteration 6 log\r\n\r\n"]
