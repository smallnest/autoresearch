{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Autoresearch Desktop",
  "version": "0.1.0",
  "identifier": "com.chaoyuepan.autoresearch",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Autoresearch Desktop",
        "width": 1200,
        "height": 800,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "resources": [
      "resources/runtime/"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Autoresearch Desktop",
    "longDescription": "Autoresearch Desktop - 自动化软件开发工具，基于多 Agent 迭代审核实现 GitHub Issue 自动实现、PR 创建与合并",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "exceptionDomain": "",
      "dmg": {
        "background": "dmg/background.png",
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    }
  }
}
