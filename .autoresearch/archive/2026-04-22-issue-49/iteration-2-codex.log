+cleanup EXIT
+assert_true "direct child stopped" "! kill -0 \"$child_pid\" 2>/dev/null"
+assert_true "grandchild stopped" "! kill -0 \"$grandchild_pid\" 2>/dev/null"
+teardown_case
+
+echo ""
+echo "=========================================="
+echo "Total: $TOTAL  Passed: $PASS  Failed: $FAIL"
+echo "=========================================="
+
+if [ $FAIL -gt 0 ]; then
+    exit 1
+fi
+
+exit 0

