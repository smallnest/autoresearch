+    fi
+    WORK_ROOT=""
+    WORK_DIR=""
+}
+
+wait_for_pid() {
+    local parent_pid="$1"
+    local attempts=0
+    local child_pid=""
+
+    while [ $attempts -lt 50 ]; do
+        child_pid=$(list_child_pids "$parent_pid" | head -n 1 || true)
+        if [ -n "$child_pid" ]; then
