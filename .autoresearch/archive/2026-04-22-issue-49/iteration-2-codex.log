+wait_for_pid() {
+    local parent_pid="$1"
+    local attempts=0
+    local child_pid=""
+
+    while [ $attempts -lt 50 ]; do
+        child_pid=$(list_child_pids "$parent_pid" | head -n 1 || true)
+        if [ -n "$child_pid" ]; then
+            echo "$child_pid"
+            return 0
+        fi
+        attempts=$((attempts + 1))
+        sleep 0.1
+    done
+    return 1
+}
