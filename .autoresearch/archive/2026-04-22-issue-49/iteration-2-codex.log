+
+assert_eq() {
+    local test_name="$1"
+    local expected="$2"
+    local actual="$3"
+    TOTAL=$((TOTAL + 1))
+    if [ "$expected" = "$actual" ]; then
+        PASS=$((PASS + 1))
+        echo "  PASS: $test_name"
+    else
+        FAIL=$((FAIL + 1))
+        echo "  FAIL: $test_name (expected=$expected, actual=$actual)"
+    fi
+}
+
+reset_state() {
+    GLOBAL_TEMP_FILES=""
+    SPINNER_PID=""
+    SCRIPT_COMPLETED_NORMALLY=0
+    CLEANUP_ALREADY_RAN=0
+    DEV_SERVER_CLEANED=0
