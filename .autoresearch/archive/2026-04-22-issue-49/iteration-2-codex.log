+    if [ -z "$child_pids" ] && command -v ps >/dev/null 2>&1; then
+        child_pids=$(ps -eo pid=,ppid= 2>/dev/null | awk -v ppid="$parent_pid" '$2 == ppid { print $1 }') || child_pids=""
+    fi
+
+    if [ -n "$child_pids" ]; then
+        printf '%s\n' "$child_pids"
+    fi
