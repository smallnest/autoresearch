+    WORK_DIR="$WORK_ROOT/work"
+    mkdir -p "$WORK_DIR"
+    : > "$WORK_DIR/log.md"
+}
+
+teardown_case() {
+    if [ -n "$WORK_ROOT" ] && [ -d "$WORK_ROOT" ]; then
+        rm -rf "$WORK_ROOT"
+    fi
+    WORK_ROOT=""
+    WORK_DIR=""
+}
+
+wait_for_pid() {
+    local parent_pid="$1"
+    local attempts=0
+    local child_pid=""
+
+    while [ $attempts -lt 50 ]; do
+        child_pid=$(list_child_pids "$parent_pid" | head -n 1 || true)
+        if [ -n "$child_pid" ]; then
+            echo "$child_pid"
