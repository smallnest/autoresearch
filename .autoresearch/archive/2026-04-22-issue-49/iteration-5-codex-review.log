        case "$1" in
            -0|-9)
                signal="$1"
                pid="$2"
                ;;
            *)
                pid="$1"
                ;;
        esac

        if [ -z "$pid" ]; then
            return 1
        fi

        if printf '%s\n' "$MOCK_ALIVE_PIDS" | grep -Fxq "$pid"; then
