run_with_retry() {
    local agent=$1
    local prompt="$2"
    local log_file="$3"
    local retry=0
    local success=0
    local skip_agent=0
    local rl_hard_stop=0

    while [ $retry -lt $MAX_RETRIES ]; do
        retry=$((retry + 1))

        # Before each attempt, check if a previous agent hit a rate limit.
        # If so, handle accordingly instead of per-agent backoff.
        if [ -n "$WORK_DIR" ] && is_rate_limited "$WORK_DIR" "$agent"; then
            local existing_type
            existing_type=$(get_rate_limit_type "$WORK_DIR" "$agent")
            if [ "$existing_type" = "quota_exceeded" ]; then
                # Per-agent quota exceeded — this agent should stop immediately
                log_console "🛑 $agent 检测到 quota exceeded 标记，立即停止"
                clear_rate_limit_marker "$WORK_DIR" "$agent"
                rl_hard_stop=1
                break
            elif [ "$existing_type" = "transient_429" ]; then
                log_console "⏳ 检测到全局限速状态 (transient 429)，执行全局冷却"
                global_rate_limit_wait "$WORK_DIR" "$RATE_LIMIT_COOLDOWN"
                clear_rate_limit_marker "$WORK_DIR"
                # 不消耗重试次数，继续重试
                retry=$((retry - 1))
                continue
            fi
        fi

        if [ $retry -gt 1 ]; then
            local delay
            delay=$(annealing_delay $retry)
            log_console "重试 $retry/$MAX_RETRIES，等待 ${delay} 秒..."
            sleep $delay
        fi

        log_console "调用 $agent (尝试 $retry/$MAX_RETRIES)..."

        # Truncate log file before each attempt so we only capture this attempt's output
        : > "$log_file"

        local exit_code=1

        # 启动等待动画
        start_spinner "$agent 正在工作中..."

        if [ "$agent" = "codex" ]; then
            timeout_wrapper "$AGENT_TIMEOUT" codex exec --full-auto "$prompt" > "$log_file" 2>&1 && exit_code=0 || exit_code=$?
        elif [ "$agent" = "opencode" ]; then
            timeout_wrapper "$AGENT_TIMEOUT" opencode run "$prompt" > "$log_file" 2>&1 && exit_code=0 || exit_code=$?
        else
            timeout_wrapper "$AGENT_TIMEOUT" claude -p "$prompt" --dangerously-skip-permissions > "$log_file" 2>&1 && exit_code=0 || exit_code=$?
        fi

        # 停止等待动画
        stop_spinner

        # Check for context overflow first (non-retryable)
        if detect_context_overflow "$log_file"; then
            log_console "检测到上下文溢出，停止重试"
            break
        fi

        # Check for MiniMax tool_call format errors (non-retryable: model bug, skip this agent)
        if has_toolcall_format_error "$log_file"; then
            local error_tail
            error_tail=$(tail -10 "$log_file" 2>/dev/null)
            log_console "⚠️ $agent 遇到 MiniMax tool_call 格式错误，终止并跳过此 agent"
            if [ -n "$error_tail" ]; then
                log_console "错误信息:"
                echo "$error_tail" | while read -r line; do log_console "  $line"; done
            fi
            skip_agent=1
            break
        fi

        # Classify rate limit errors (transient 429 vs quota exceeded)
        local rl_type=0
        classify_rate_limit "$log_file" || rl_type=$?
        if [ "$rl_type" -eq 2 ]; then
            # Quota exceeded — hard stop, write marker for other agents
            log_console "🛑 $agent 检测到 quota exceeded，设置限速标记并停止"
            if [ -n "$WORK_DIR" ]; then
                set_rate_limit_marker "$WORK_DIR" "quota_exceeded" "$agent"
            fi
            rl_hard_stop=1
            break
        elif [ "$rl_type" -eq 1 ]; then
            # Transient 429 — set global marker and do coordinated cooldown
            log_console "⚠️ $agent 检测到 rate limit (transient 429)，设置全局限速标记"
            if [ -n "$WORK_DIR" ]; then
                set_rate_limit_marker "$WORK_DIR" "transient_429"
            fi
            global_rate_limit_wait "$WORK_DIR" "$RATE_LIMIT_COOLDOWN"
            clear_rate_limit_marker "$WORK_DIR"
            # Continue retrying after cooldown (don't consume a retry slot)
            retry=$((retry - 1))
            continue
        fi

        # Check for non-zero exit code from the agent
        if [ $exit_code -ne 0 ]; then
            local error_tail
