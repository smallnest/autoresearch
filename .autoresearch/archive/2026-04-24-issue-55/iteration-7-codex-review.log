# 检测 Agent 输出是否包含致命错误（区分代码讨论中的 "error" 与真正的运行时错误）
has_fatal_error() {
    local log_file="$1"
    # 仅匹配行首的错误模式，避免误判代码中讨论 "error handling" 等正常内容
    # Rate limit patterns (rate.limit, too.many.requests, quota.exceeded, billing.hard.limit)
    # are intentionally excluded here — they are handled by classify_rate_limit() in
    # run_with_retry() which runs BEFORE this check.  Including them causes false positives
    # when agent output discusses rate limit topics in code/planning text.
    local pattern='^(Error|ERROR|Fatal|Panic|Exception)[: ]'
    pattern+='|^(timeout|authentication|unauthorized|API.key).*error'
    pattern+='|context.length.exceeded'
    pattern+='|maximum.context.length'
    pattern+='|token.limit.exceeded'
    pattern+='|model.is.overloaded'
    pattern+='|server.error'
    pattern+='|service.unavailable'
    pattern+='|internal.server.error'
    pattern+='|connection.refused'
    pattern+='|network.error'
    pattern+='|DNS.resolution'
    pattern+='|Timed.out'
    pattern+='|Command.timed.out'
    grep -qE "$pattern" "$log_file" 2>/dev/null
}

