-    [ -f "$marker_dir/$RATE_LIMIT_MARKER" ]
-}
-
-# Get the rate limit type from the marker.
-# Prints "transient_429", "quota_exceeded", or "" if no marker.
-get_rate_limit_type() {
-    local marker_dir="$1"
-    local marker_file="$marker_dir/$RATE_LIMIT_MARKER"
-    if [ -f "$marker_file" ]; then
-        cut -d' ' -f1 "$marker_file" 2>/dev/null
-    fi
-}
-
-# Get the timestamp (epoch seconds) when rate limit was detected.
-# Prints the timestamp or "" if no marker.
-get_rate_limit_timestamp() {
-    local marker_dir="$1"
-    local marker_file="$marker_dir/$RATE_LIMIT_MARKER"
-    if [ -f "$marker_file" ]; then
-        cut -d' ' -f2 "$marker_file" 2>/dev/null
-    fi
-}
-
-# ==================== Global Cooldown ====================
-
-# Wait for the global rate limit cooldown.
-# If the marker was set recently, sleeps only the remaining time.
-# Usage: global_rate_limit_wait "$WORK_DIR" [cooldown_seconds]
-global_rate_limit_wait() {
-    local marker_dir="$1"
-    local cooldown="${2:-$RATE_LIMIT_COOLDOWN}"
-    local now
-    now=$(date +%s)
-
-    local timestamp
-    timestamp=$(get_rate_limit_timestamp "$marker_dir")
-
-    local remaining=$cooldown
-    if [ -n "$timestamp" ] && [ "$timestamp" -gt 0 ] 2>/dev/null; then
-        local elapsed=$((now - timestamp))
-        remaining=$((cooldown - elapsed))
-    fi
-
-    if [ "$remaining" -le 0 ]; then
-        return 0
-    fi
-
-    echo "⏳ 全局限速冷却中，等待 ${remaining} 秒..."
-    sleep "$remaining"
-}
