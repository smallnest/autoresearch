#!/bin/bash
# lib/rate_limit.sh - Global rate limit awareness for multi-agent retry coordination
#
# Problem: Each agent retries independently (5×), so a single rate limit event can
# burn 15 retries (3 agents × 5), wasting time and quota.
#
# Solution:
#   1. Detect rate limit errors (transient 429 vs quota exceeded)
#   2. Write a shared marker file to $WORK_DIR so all agents see the state
#   3. Global cooldown (sleep) instead of per-agent retries
#   4. Quota exceeded → hard stop (no retry, exit the run)
#
# Usage in run.sh:
#   source "$SCRIPT_DIR/lib/rate_limit.sh"
#   RATE_LIMIT_COOLDOWN=${RATE_LIMIT_COOLDOWN:-60}
#   RATE_LIMIT_MARKER_DIR="$WORK_DIR"
#
#   # Inside run_with_retry, after agent call:
#   classify_rate_limit "$log_file"
#   local rl_type=$?
#   if [ "$rl_type" -eq 2 ]; then
#       # quota exceeded — hard stop
#       set_rate_limit_marker "$RATE_LIMIT_MARKER_DIR" "quota_exceeded"
#       return 3
#   elif [ "$rl_type" -eq 1 ]; then
#       # transient 429 — global cooldown
#       set_rate_limit_marker "$RATE_LIMIT_MARKER_DIR" "transient_429"
#       global_rate_limit_wait "$RATE_LIMIT_MARKER_DIR" "$RATE_LIMIT_COOLDOWN"
#       clear_rate_limit_marker "$RATE_LIMIT_MARKER_DIR"
#       # continue with retry
#   fi
#
#   # Before each agent call:
#   if is_rate_limited "$RATE_LIMIT_MARKER_DIR"; then
#       global_rate_limit_wait "$RATE_LIMIT_MARKER_DIR" "$RATE_LIMIT_COOLDOWN"
#       clear_rate_limit_marker "$RATE_LIMIT_MARKER_DIR"
#   fi

# ==================== Configuration ====================

# Default cooldown in seconds; override via RATE_LIMIT_COOLDOWN env var
RATE_LIMIT_COOLDOWN="${RATE_LIMIT_COOLDOWN:-60}"

# ==================== Detection ====================

# Detect transient 429 (rate limited but retryable).
# Returns 0 if a transient 429 pattern is found.
has_transient_429() {
    local log_file="$1"
    local pattern='status.429'
    pattern+='|HTTP.429'
    pattern+='|rate.limit'
    pattern+='|too.many.requests'
    pattern+='|request.was.throttled'
    pattern+='|Rate.limit.exceeded'
    pattern+='|API.rate.limit'
    grep -qiE "$pattern" "$log_file" 2>/dev/null
}

# Detect quota exceeded (non-retryable, should hard-stop).
# Returns 0 if a quota exceeded pattern is found.
has_quota_exceeded() {
    local log_file="$1"
    local pattern='quota.exceeded'
    pattern+='|billing.hard.limit'
    pattern+='|billing.limit.reached'
    pattern+='|monthly.spending.limit'
    pattern+='|usage.cap.exceeded'
    pattern+='|plan.limit.exceeded'
    pattern+='|insufficient.quota'
    grep -qiE "$pattern" "$log_file" 2>/dev/null
}

# Classify the rate limit type from a log file.
# Returns:
#   0 = no rate limit detected
#   1 = transient 429 (retryable with cooldown)
#   2 = quota exceeded (hard stop)
classify_rate_limit() {
    local log_file="$1"

    # Check quota exceeded first (higher severity)
    if has_quota_exceeded "$log_file"; then
        return 2
    fi

    # Check transient 429
    if has_transient_429 "$log_file"; then
        return 1
    fi

    return 0
}

# ==================== Shared State (file-based marker) ====================

# Marker file name (stored in WORK_DIR)
RATE_LIMIT_MARKER=".rate_limit_state"

# Set the rate limit marker with type and timestamp.
# Usage: set_rate_limit_marker "$WORK_DIR" "transient_429"
set_rate_limit_marker() {
    local marker_dir="$1"
    local rl_type="$2"  # "transient_429" or "quota_exceeded"
    local marker_file="$marker_dir/$RATE_LIMIT_MARKER"
    echo "${rl_type} $(date +%s)" > "$marker_file"
}

# Clear the rate limit marker.
clear_rate_limit_marker() {
    local marker_dir="$1"
    rm -f "$marker_dir/$RATE_LIMIT_MARKER" 2>/dev/null || true
}

# Check if currently rate limited (marker file exists).
# Returns 0 if rate limited, 1 otherwise.
is_rate_limited() {
    local marker_dir="$1"
    [ -f "$marker_dir/$RATE_LIMIT_MARKER" ]
}

# Get the rate limit type from the marker.
# Prints "transient_429", "quota_exceeded", or "" if no marker.
get_rate_limit_type() {
    local marker_dir="$1"
    local marker_file="$marker_dir/$RATE_LIMIT_MARKER"
    if [ -f "$marker_file" ]; then
        cut -d' ' -f1 "$marker_file" 2>/dev/null
    fi
}

# Get the timestamp (epoch seconds) when rate limit was detected.
# Prints the timestamp or "" if no marker.
get_rate_limit_timestamp() {
    local marker_dir="$1"
    local marker_file="$marker_dir/$RATE_LIMIT_MARKER"
    if [ -f "$marker_file" ]; then
        cut -d' ' -f2 "$marker_file" 2>/dev/null
    fi
}

# ==================== Global Cooldown ====================

# Wait for the global rate limit cooldown.
# If the marker was set recently, sleeps only the remaining time.
# Usage: global_rate_limit_wait "$WORK_DIR" [cooldown_seconds]
global_rate_limit_wait() {
    local marker_dir="$1"
    local cooldown="${2:-$RATE_LIMIT_COOLDOWN}"
    local now
    now=$(date +%s)

    local timestamp
    timestamp=$(get_rate_limit_timestamp "$marker_dir")

    local remaining=$cooldown
    if [ -n "$timestamp" ] && [ "$timestamp" -gt 0 ] 2>/dev/null; then
        local elapsed=$((now - timestamp))
        remaining=$((cooldown - elapsed))
    fi

    if [ "$remaining" -le 0 ]; then
        return 0
    fi

    echo "⏳ 全局限速冷却中，等待 ${remaining} 秒..."
    sleep "$remaining"
}
