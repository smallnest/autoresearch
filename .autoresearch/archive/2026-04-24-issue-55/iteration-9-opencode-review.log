-#!/bin/bash
-# tests/test_rate_limit.sh - Unit tests for global rate limit awareness
-#
-# Usage: bash tests/test_rate_limit.sh
-
-set -e
-
-SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
-PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
-
-# ==================== Test Framework ====================
-
-PASS=0
-FAIL=0
-TOTAL=0
-
-assert_eq() {
-    local test_name="$1"
-    local expected="$2"
-    local actual="$3"
-    TOTAL=$((TOTAL + 1))
-    if [ "$expected" = "$actual" ]; then
-        PASS=$((PASS + 1))
-        echo "  PASS: $test_name (expected=$expected, actual=$actual)"
-    else
-        FAIL=$((FAIL + 1))
-        echo "  FAIL: $test_name (expected=$expected, actual=$actual)"
-    fi
-}
-
-assert_true() {
-    local test_name="$1"
-    local cmd="$2"
-    TOTAL=$((TOTAL + 1))
-    if eval "$cmd"; then
-        PASS=$((PASS + 1))
-        echo "  PASS: $test_name"
-    else
-        FAIL=$((FAIL + 1))
-        echo "  FAIL: $test_name (expected true, got false)"
-    fi
-}
-
-assert_false() {
-    local test_name="$1"
-    local cmd="$2"
-    TOTAL=$((TOTAL + 1))
-    if ! eval "$cmd"; then
-        PASS=$((PASS + 1))
-        echo "  PASS: $test_name"
-    else
-        FAIL=$((FAIL + 1))
-        echo "  FAIL: $test_name (expected false, got true)"
-    fi
-}
-
-# ==================== Setup ====================
-
-TEST_DIR=$(mktemp -d)
-trap 'rm -rf "$TEST_DIR"' EXIT
-
-# Source the rate limit library
-# shellcheck source=/dev/null
-source "$PROJECT_DIR/lib/rate_limit.sh"
-
-# Override cooldown to 1 second for testing
-RATE_LIMIT_COOLDOWN=1
-
-# ==================== Tests: Detection ====================
-
-echo ""
-echo "=== Detection Tests ==="
-echo ""
-
-# Test has_transient_429 with various patterns
-echo "--- has_transient_429() ---"
-
-# Create test log files with various 429 patterns
-echo "Error: status 429 Too Many Requests" > "$TEST_DIR/429_status.log"
-assert_true "detects 'status 429'" "has_transient_429 '$TEST_DIR/429_status.log'"
-
-echo "HTTP 429: rate_limit_exceeded" > "$TEST_DIR/http_429.log"
-assert_true "detects 'HTTP 429'" "has_transient_429 '$TEST_DIR/http_429.log'"
-
-echo "Error: rate limit exceeded, please retry" > "$TEST_DIR/rate_limit.log"
-assert_true "detects 'rate limit'" "has_transient_429 '$TEST_DIR/rate_limit.log'"
-
-echo "too.many.requests" > "$TEST_DIR/too_many.log"
-assert_true "detects 'too many requests'" "has_transient_429 '$TEST_DIR/too_many.log'"
-
-echo "Request was throttled by the API" > "$TEST_DIR/throttled.log"
-assert_true "detects 'request was throttled'" "has_transient_429 '$TEST_DIR/throttled.log'"
-
-echo "Rate limit exceeded for this endpoint" > "$TEST_DIR/rl_exceeded.log"
-assert_true "detects 'Rate limit exceeded'" "has_transient_429 '$TEST_DIR/rl_exceeded.log'"
-
-echo "API rate limit reached, backing off" > "$TEST_DIR/api_rl.log"
-assert_true "detects 'API rate limit'" "has_transient_429 '$TEST_DIR/api_rl.log'"
-
-# No rate limit
-echo "The code looks good, score 85/100" > "$TEST_DIR/normal.log"
-assert_false "no false positive on normal output" "has_transient_429 '$TEST_DIR/normal.log'"
-
-# Empty file
-touch "$TEST_DIR/empty.log"
-assert_false "no false positive on empty file" "has_transient_429 '$TEST_DIR/empty.log'"
-
-echo ""
-echo "--- has_quota_exceeded() ---"
-
-echo "Error: quota exceeded for this month" > "$TEST_DIR/quota.log"
-assert_true "detects 'quota exceeded'" "has_quota_exceeded '$TEST_DIR/quota.log'"
-
-echo "billing hard limit has been reached" > "$TEST_DIR/billing.log"
-assert_true "detects 'billing hard limit'" "has_quota_exceeded '$TEST_DIR/billing.log'"
-
-echo "Error: billing limit reached" > "$TEST_DIR/billing_limit.log"
-assert_true "detects 'billing limit reached'" "has_quota_exceeded '$TEST_DIR/billing_limit.log'"
-
-echo "monthly spending limit reached" > "$TEST_DIR/monthly.log"
-assert_true "detects 'monthly spending limit'" "has_quota_exceeded '$TEST_DIR/monthly.log'"
-
-echo "Usage cap exceeded for your plan" > "$TEST_DIR/usage_cap.log"
-assert_true "detects 'usage cap exceeded'" "has_quota_exceeded '$TEST_DIR/usage_cap.log'"
-
-echo "Plan limit exceeded" > "$TEST_DIR/plan_limit.log"
-assert_true "detects 'plan limit exceeded'" "has_quota_exceeded '$TEST_DIR/plan_limit.log'"
-
-echo "insufficient quota" > "$TEST_DIR/insufficient.log"
-assert_true "detects 'insufficient quota'" "has_quota_exceeded '$TEST_DIR/insufficient.log'"
-
-# No quota exceeded
-echo "status 429 rate limited" > "$TEST_DIR/only_429.log"
-assert_false "no false positive on 429-only output" "has_quota_exceeded '$TEST_DIR/only_429.log'"
-
-echo ""
-echo "--- classify_rate_limit() ---"
-
-# No rate limit → return 0
-classify_rate_limit "$TEST_DIR/normal.log"
-assert_eq "classify: normal file returns 0" "0" "$?"
-
-# Transient 429 → return 1
-rl_code=0
-classify_rate_limit "$TEST_DIR/429_status.log" || rl_code=$?
-assert_eq "classify: 429 file returns 1" "1" "$rl_code"
-
-# Quota exceeded → return 2
-rl_code=0
-classify_rate_limit "$TEST_DIR/quota.log" || rl_code=$?
-assert_eq "classify: quota file returns 2" "2" "$rl_code"
-
-# Priority: quota exceeded wins over 429
-cat > "$TEST_DIR/both.log" << 'EOF'
-status 429 and quota exceeded
-EOF
-rl_code=0
-classify_rate_limit "$TEST_DIR/both.log" || rl_code=$?
-assert_eq "classify: both patterns → quota wins (2)" "2" "$rl_code"
-
-# ==================== Tests: Shared State Marker ====================
-
-echo ""
-echo "=== Shared State Marker Tests ==="
-echo ""
-
-# Use a sub-directory as WORK_DIR
-MARKER_DIR="$TEST_DIR/workdir"
-mkdir -p "$MARKER_DIR"
-
-# Initially not rate limited
-assert_false "initially not rate limited" "is_rate_limited '$MARKER_DIR'"
-
-# Set transient marker
-set_rate_limit_marker "$MARKER_DIR" "transient_429"
-assert_true "rate limited after setting marker" "is_rate_limited '$MARKER_DIR'"
-
-rl_type=$(get_rate_limit_type "$MARKER_DIR")
-assert_eq "marker type is transient_429" "transient_429" "$rl_type"
-
-# Timestamp should be a valid epoch
-rl_ts=$(get_rate_limit_timestamp "$MARKER_DIR")
-assert_true "timestamp is non-empty" "[ -n '$rl_ts' ]"
-assert_true "timestamp is numeric" "[ '$rl_ts' -gt 0 ] 2>/dev/null"
-
-# Clear marker
-clear_rate_limit_marker "$MARKER_DIR"
-assert_false "not rate limited after clearing" "is_rate_limited '$MARKER_DIR'"
-
-# Set quota exceeded marker
-set_rate_limit_marker "$MARKER_DIR" "quota_exceeded"
-assert_true "rate limited with quota marker" "is_rate_limited '$MARKER_DIR'"
-rl_type=$(get_rate_limit_type "$MARKER_DIR")
-assert_eq "marker type is quota_exceeded" "quota_exceeded" "$rl_type"
-
-# Clear
-clear_rate_limit_marker "$MARKER_DIR"
-
-# Get type on no marker returns empty
-rl_type=$(get_rate_limit_type "$MARKER_DIR")
-assert_eq "no marker type is empty" "" "$rl_type"
-
-rl_ts=$(get_rate_limit_timestamp "$MARKER_DIR")
-assert_eq "no marker timestamp is empty" "" "$rl_ts"
-
-# ==================== Tests: Global Cooldown ====================
-
-echo ""
-echo "=== Global Cooldown Tests ==="
-echo ""
-
-# Test that global_rate_limit_wait respects remaining time
-# Set marker with timestamp 1 second ago
-set_rate_limit_marker "$MARKER_DIR" "transient_429"
-
-# With RATE_LIMIT_COOLDOWN=1, the wait should be very brief
-start_time=$(date +%s)
-global_rate_limit_wait "$MARKER_DIR" "$RATE_LIMIT_COOLDOWN"
-end_time=$(date +%s)
-elapsed=$((end_time - start_time))
-# Should have waited at most 1-2 seconds (may already have elapsed)
-assert_true "cooldown completes (elapsed=$elapsed)" "[ $elapsed -le 3 ]"
-
-clear_rate_limit_marker "$MARKER_DIR"
-
-# Test that expired marker results in no wait
-# Set marker with a very old timestamp (simulate)
-echo "transient_429 1000000000" > "$MARKER_DIR/$RATE_LIMIT_MARKER"
-start_time=$(date +%s)
-global_rate_limit_wait "$MARKER_DIR" "$RATE_LIMIT_COOLDOWN"
-end_time=$(date +%s)
-elapsed=$((end_time - start_time))
-assert_true "expired marker → no wait (elapsed=$elapsed)" "[ $elapsed -le 1 ]"
-
-clear_rate_limit_marker "$MARKER_DIR"
-
-# ==================== Tests: Integration Scenario ====================
-
-echo ""
-echo "=== Integration Scenario Tests ==="
-echo ""
-
-# Scenario 1: Agent A hits 429, Agent B should see the marker
-set_rate_limit_marker "$MARKER_DIR" "transient_429"
-assert_true "Agent B sees rate limit marker from Agent A" "is_rate_limited '$MARKER_DIR'"
-rl_type=$(get_rate_limit_type "$MARKER_DIR")
-assert_eq "Agent B sees correct type" "transient_429" "$rl_type"
-clear_rate_limit_marker "$MARKER_DIR"
-
-# Scenario 2: Agent A hits quota, Agent B should hard-stop
-set_rate_limit_marker "$MARKER_DIR" "quota_exceeded"
-rl_type=$(get_rate_limit_type "$MARKER_DIR")
-assert_eq "Agent B sees quota exceeded" "quota_exceeded" "$rl_type"
-clear_rate_limit_marker "$MARKER_DIR"
-
-# Scenario 3: Marker file persistence across operations
-set_rate_limit_marker "$MARKER_DIR" "transient_429"
-assert_true "marker persists" "is_rate_limited '$MARKER_DIR'"
-# Verify file exists and has expected format
-assert_true "marker file exists" "[ -f '$MARKER_DIR/$RATE_LIMIT_MARKER' ]"
-marker_content=$(cat "$MARKER_DIR/$RATE_LIMIT_MARKER")
-assert_true "marker content has type" "echo '$marker_content' | grep -q 'transient_429'"
-assert_true "marker content has timestamp" "echo '$marker_content' | grep -qE '[0-9]+'"
-clear_rate_limit_marker "$MARKER_DIR"
-
-# ==================== Summary ====================
-
-echo ""
-echo "=========================================="
-echo "Total: $TOTAL  Passed: $PASS  Failed: $FAIL"
-echo "=========================================="
-
-if [ "$FAIL" -gt 0 ]; then
-    exit 1
-fi
