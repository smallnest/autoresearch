    local marker_file="$marker_dir/$RATE_LIMIT_MARKER"
    if [ -f "$marker_file" ]; then
        # Validate marker format: "transient_429 <timestamp>"
        local g_line
        g_line=$(head -1 "$marker_file" 2>/dev/null)
        if echo "$g_line" | grep -qE '"'"'^transient_429 [0-9]+$'"'; then
            echo \"transient_429\"
            return
        else
