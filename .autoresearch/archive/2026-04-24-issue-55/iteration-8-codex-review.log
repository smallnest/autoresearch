#!/bin/bash
# lib/rate_limit.sh - Per-agent rate limit awareness for multi-agent retry coordination
#
# Problem: Each agent retries independently (5×), so a single rate limit event can
# burn 15 retries (3 agents × 5), wasting time and quota.
#
# Solution:
#   1. Detect rate limit errors (transient 429 vs quota exceeded)
#   2. Write a per-agent marker file so only the affected agent is blocked
#   3. Global cooldown (sleep) instead of per-agent retries for transient 429
#   4. Quota exceeded → hard stop for the affected agent only (other agents use different LLMs)
#
# Marker files:
#   .rate_limit_state              — global transient 429 marker (all agents share API endpoint)
#   .rate_limit_quota_<agent>      — per-agent quota exceeded marker (different LLMs, independent)
#
# Usage in run.sh:
#   source "$SCRIPT_DIR/lib/rate_limit.sh"
#   RATE_LIMIT_COOLDOWN=${RATE_LIMIT_COOLDOWN:-60}
#
#   # Inside run_with_retry, before agent call:
#   if is_rate_limited "$WORK_DIR" "$agent"; then
#       ...
#   fi
#
#   # After agent call:
#   classify_rate_limit "$log_file"
#   local rl_type=$?
