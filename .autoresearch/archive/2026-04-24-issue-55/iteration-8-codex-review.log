#       set_rate_limit_marker "$WORK_DIR" "quota_exceeded" "$agent"
#       return 3
#   elif [ "$rl_type" -eq 1 ]; then
#       set_rate_limit_marker "$WORK_DIR" "transient_429"
#       global_rate_limit_wait "$WORK_DIR" "$RATE_LIMIT_COOLDOWN"
#       clear_rate_limit_marker "$WORK_DIR" ""
#   fi

# ==================== Configuration ====================

# Default cooldown in seconds; override via RATE_LIMIT_COOLDOWN env var
RATE_LIMIT_COOLDOWN="${RATE_LIMIT_COOLDOWN:-60}"

# ==================== Detection ====================

# Detect transient 429 (rate limited but retryable).
# Returns 0 if a transient 429 pattern is found.
has_transient_429() {
    local log_file="$1"
    # Improved: match only error-context lines to avoid false positives on discussion text
    local pattern='^(Error|ERROR|Fatal|Panic|Exception)[: ].*(status.429|HTTP.429|rate.limit|too.many.requests|request.was.throttled|Rate.limit.exceeded|API.rate.limit)'
    pattern+='|^HTTP/[0-9.]+ 429'
    pattern+='|^status.*429'
    pattern+='|.*429.*(error|Error|ERROR)'
    pattern+='|.*rate.limit.*(error|exceeded|limited)'
    grep -qiE "$pattern" "$log_file" 2>/dev/null
}

# Detect quota exceeded (non-retryable, should hard-stop the affected agent).
# Returns 0 if a quota exceeded pattern is found.
has_quota_exceeded() {
    local log_file="$1"
    # Broad patterns: false positives are acceptable (only trigger cooldown)
    local pattern='quota.exceeded'
    pattern+='|billing.hard.limit'
    pattern+='|billing.limit.reached'
    pattern+='|monthly.spending.limit'
    pattern+='|usage.cap.exceeded'
    pattern+='|plan.limit.exceeded'
    pattern+='|insufficient.quota'
    grep -qiE "$pattern" "$log_file" 2>/dev/null
}

# Classify the rate limit type from a log file.
# Returns:
#   0 = no rate limit detected
#   1 = transient 429 (retryable with cooldown)
#   2 = quota exceeded (hard stop for this agent)
classify_rate_limit() {
    local log_file="$1"

    # Check quota exceeded first (higher severity)
    if has_quota_exceeded "$log_file"; then
        return 2
    fi

    # Check transient 429
    if has_transient_429 "$log_file"; then
        return 1
    fi

    return 0
}

# ==================== Shared State (file-based marker) ====================

# Global marker for transient 429 (all agents share the same API endpoint)
RATE_LIMIT_MARKER=".rate_limit_state"

# Set the rate limit marker with type and timestamp.
# Usage: set_rate_limit_marker "$WORK_DIR" "transient_429" ["agent_name"]
#   - transient_429: global marker (no agent needed)
#   - quota_exceeded: per-agent marker (agent name required)
set_rate_limit_marker() {
    local marker_dir="$1"
    local rl_type="$2"  # "transient_429" or "quota_exceeded"
    local agent="${3:-}"

    if [ "$rl_type" = "quota_exceeded" ] && [ -n "$agent" ]; then
        # Per-agent quota marker
        local marker_file="$marker_dir/.rate_limit_quota_${agent}"
        echo "quota_exceeded $(date +%s)" > "$marker_file"
    else
        # Global transient marker
        local marker_file="$marker_dir/$RATE_LIMIT_MARKER"
        echo "${rl_type} $(date +%s)" > "$marker_file"
    fi
}

# Clear the rate limit marker.
# Usage: clear_rate_limit_marker "$WORK_DIR" ["agent_name"]
#   - With agent: clear per-agent quota marker
#   - Without agent: clear global transient marker
clear_rate_limit_marker() {
    local marker_dir="$1"
    local agent="${2:-}"
    if [ -n "$agent" ]; then
        rm -f "$marker_dir/.rate_limit_quota_${agent}" 2>/dev/null || true
    else
        rm -f "$marker_dir/$RATE_LIMIT_MARKER" 2>/dev/null || true
    fi
}

# Check if currently rate limited for a specific agent.
# Usage: is_rate_limited "$WORK_DIR" "$agent"
# Returns 0 if rate limited, 1 otherwise.
# Global marker only counts for transient_429 (shared API endpoint).
# Quota exceeded is per-agent (different LLMs).
is_rate_limited() {
    local marker_dir="$1"
    local agent="${2:-}"

    # Check per-agent quota exceeded marker first (specific to this agent)
    if [ -n "$agent" ] && [ -f "$marker_dir/.rate_limit_quota_${agent}" ]; then
        return 0
    fi

    # Check global marker — only transient_429 is truly global
    local marker_file="$marker_dir/$RATE_LIMIT_MARKER"
    if [ -f "$marker_file" ]; then
        local global_type
        global_type=$(cut -d' ' -f1 "$marker_file" 2>/dev/null)
        if [ "$global_type" = "transient_429" ]; then
            return 0
        fi
        # Legacy: global marker with quota_exceeded type — treat as stale, ignore
        # Quota is per-agent, global quota marker is meaningless
    fi

    return 1
}

# Get the rate limit type for a specific agent.
# Usage: get_rate_limit_type "$WORK_DIR" ["agent_name"]
# Prints "transient_429", "quota_exceeded", or "" if no marker.
get_rate_limit_type() {
    local marker_dir="$1"
    local agent="${2:-}"

    # Check per-agent quota marker first (higher severity)
    if [ -n "$agent" ] && [ -f "$marker_dir/.rate_limit_quota_${agent}" ]; then
        echo "quota_exceeded"
        return
    fi

    # Check global transient marker
    local marker_file="$marker_dir/$RATE_LIMIT_MARKER"
    if [ -f "$marker_file" ]; then
        local global_type
        global_type=$(cut -d' ' -f1 "$marker_file" 2>/dev/null)
        if [ "$global_type" = "transient_429" ]; then
            echo "transient_429"
            return
        fi
    fi
}

# Get the timestamp (epoch seconds) when rate limit was detected.
# Prints the timestamp or "" if no marker.
get_rate_limit_timestamp() {
    local marker_dir="$1"
    local agent="${2:-}"

    # Check per-agent quota marker first
    if [ -n "$agent" ] && [ -f "$marker_dir/.rate_limit_quota_${agent}" ]; then
        cut -d' ' -f2 "$marker_dir/.rate_limit_quota_${agent}" 2>/dev/null
        return
    fi

    # Check global transient marker
    local marker_file="$marker_dir/$RATE_LIMIT_MARKER"
    if [ -f "$marker_file" ]; then
        local line ts
        line=$(head -1 "$marker_file" 2>/dev/null)
        ts=$(echo "$line" | cut -d' ' -f2 2>/dev/null)
        # Validate timestamp is a valid number
        if [[ "$ts" =~ ^[0-9]+$ ]]; then
            echo "$ts"
        else
            clear_rate_limit_marker "$marker_dir"
            echo ""
        fi
    fi
}

# ==================== Global Cooldown ====================

# Wait for the global rate limit cooldown.
# If the marker was set recently, sleeps only the remaining time.
# Usage: global_rate_limit_wait "$WORK_DIR" [cooldown_seconds] ["agent_name"]
global_rate_limit_wait() {
    local marker_dir="$1"
    local cooldown="${2:-$RATE_LIMIT_COOLDOWN}"
    local agent="${3:-}"

    local now
    now=$(date +%s)

    local timestamp
    timestamp=$(get_rate_limit_timestamp "$marker_dir" "$agent")

    local remaining=$cooldown
    if [ -n "$timestamp" ] && [ "$timestamp" -gt 0 ] 2>/dev/null; then
        local elapsed=$((now - timestamp))
        remaining=$((cooldown - elapsed))
    fi

    if [ "$remaining" -le 0 ]; then
        return 0
    fi

    echo "⏳ 全局限速冷却中，等待 ${remaining} 秒..."
    sleep "$remaining"
}

