# Clear the rate limit marker.
# Usage: clear_rate_limit_marker "$WORK_DIR" ["agent_name"]
#   - With agent: clear per-agent quota marker
#   - Without agent: clear global transient marker
clear_rate_limit_marker() {
    local marker_dir="$1"
    local agent="${2:-}"
    if [ -n "$agent" ]; then
        rm -f "$marker_dir/.rate_limit_quota_${agent}" 2>/dev/null || true
    else
        rm -f "$marker_dir/$RATE_LIMIT_MARKER" 2>/dev/null || true
    fi
