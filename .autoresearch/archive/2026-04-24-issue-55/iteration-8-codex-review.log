run_with_retry() {
    local agent=$1
    local prompt="$2"
    local log_file="$3"
    local retry=0
    local success=0
    local skip_agent=0
    local rl_hard_stop=0

    while [ $retry -lt $MAX_RETRIES ]; do
        retry=$((retry + 1))

        # Before each attempt, check if a previous agent hit a rate limit.
        # If so, handle accordingly instead of per-agent backoff.
        if [ -n "$WORK_DIR" ] && is_rate_limited "$WORK_DIR" "$agent"; then
            local existing_type
            existing_type=$(get_rate_limit_type "$WORK_DIR" "$agent")
            if [ "$existing_type" = "quota_exceeded" ]; then
                # Per-agent quota exceeded — this agent should stop immediately
                log_console "🛑 $agent 检测到 quota exceeded 标记，立即停止"
                clear_rate_limit_marker "$WORK_DIR" "$agent"
                rl_hard_stop=1
                break
            elif [ "$existing_type" = "transient_429" ]; then
                log_console "⏳ 检测到全局限速状态 (transient 429)，执行全局冷却"
                global_rate_limit_wait "$WORK_DIR" "$RATE_LIMIT_COOLDOWN"
                clear_rate_limit_marker "$WORK_DIR"
                # 不消耗重试次数，继续重试
                retry=$((retry - 1))
                continue
            fi
        fi

        if [ $retry -gt 1 ]; then
            local delay
            delay=$(annealing_delay $retry)
            log_console "重试 $retry/$MAX_RETRIES，等待 ${delay} 秒..."
            sleep $delay
