get_rate_limit_type() {
    local marker_dir="$1"
    local agent="${2:-}"

    # Check per-agent quota marker first (higher severity)
    if [ -n "$agent" ] && [ -f "$marker_dir/.rate_limit_quota_${agent}" ]; then
