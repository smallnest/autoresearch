assert_true "rate limited with per-agent quota marker" "is_rate_limited '$MARKER_DIR' test_agent"
rl_type=$(get_rate_limit_type "$MARKER_DIR" test_agent)
assert_eq "marker type is quota_exceeded" "quota_exceeded" "$rl_type"
# Other agent should NOT see this marker
assert_false "other agent not rate limited" "is_rate_limited '$MARKER_DIR' other_agent"

# Clear per-agent marker
clear_rate_limit_marker "$MARKER_DIR" "test_agent"

# Get type on no marker returns empty
rl_type=$(get_rate_limit_type "$MARKER_DIR" test_agent)
assert_eq "no marker type is empty" "" "$rl_type"

rl_ts=$(get_rate_limit_timestamp "$MARKER_DIR")
assert_eq "no marker timestamp is empty" "" "$rl_ts"

echo "--- Marker file robustness tests ---"

# Test malformed marker: missing timestamp
echo "transient_429" > "$MARKER_DIR/$RATE_LIMIT_MARKER"
rl_type=$(get_rate_limit_type "$MARKER_DIR")
assert_eq "malformed marker (no timestamp): type empty" "" "$rl_type"
assert_false "malformed marker: file removed" "is_rate_limited '$MARKER_DIR'"

# Test malformed marker: invalid type
echo "invalid_type 123456" > "$MARKER_DIR/$RATE_LIMIT_MARKER"
rl_type=$(get_rate_limit_type "$MARKER_DIR")
assert_eq "invalid type: type empty" "" "$rl_type"
assert_false "invalid type: file removed" "is_rate_limited '$MARKER_DIR'"

# Test malformed marker: invalid timestamp
echo "transient_429 abc" > "$MARKER_DIR/$RATE_LIMIT_MARKER"
rl_ts=$(get_rate_limit_timestamp "$MARKER_DIR")
assert_eq "invalid timestamp: ts empty" "" "$rl_ts"
assert_false "invalid timestamp: file removed" "is_rate_limited '$MARKER_DIR'"

# Test valid marker works after cleanup
set_rate_limit_marker "$MARKER_DIR" "transient_429"
assert_true "valid marker after cleanup" "is_rate_limited '$MARKER_DIR'"
clear_rate_limit_marker "$MARKER_DIR"


# ==================== Tests: Global Cooldown ====================

echo ""
echo "=== Global Cooldown Tests ==="
echo ""

# Test that global_rate_limit_wait respects remaining time
# Set marker with timestamp 1 second ago
set_rate_limit_marker "$MARKER_DIR" "transient_429"

# With RATE_LIMIT_COOLDOWN=1, the wait should be very brief
start_time=$(date +%s)
global_rate_limit_wait "$MARKER_DIR" "$RATE_LIMIT_COOLDOWN"
end_time=$(date +%s)
elapsed=$((end_time - start_time))
# Should have waited at most 1-2 seconds (may already have elapsed)
assert_true "cooldown completes (elapsed=$elapsed)" "[ $elapsed -le 3 ]"

clear_rate_limit_marker "$MARKER_DIR"

# Test that expired marker results in no wait
# Set marker with a very old timestamp (simulate)
echo "transient_429 1000000000" > "$MARKER_DIR/$RATE_LIMIT_MARKER"
start_time=$(date +%s)
global_rate_limit_wait "$MARKER_DIR" "$RATE_LIMIT_COOLDOWN"
end_time=$(date +%s)
elapsed=$((end_time - start_time))
assert_true "expired marker → no wait (elapsed=$elapsed)" "[ $elapsed -le 1 ]"

clear_rate_limit_marker "$MARKER_DIR"

# ==================== Tests: Integration Scenario ====================

echo ""
echo "=== Integration Scenario Tests ==="
echo ""

# Scenario 1: transient 429 is global — Agent B sees Agent A's marker
set_rate_limit_marker "$MARKER_DIR" "transient_429"
assert_true "Agent B sees global transient marker from Agent A" "is_rate_limited '$MARKER_DIR' agent_b"
rl_type=$(get_rate_limit_type "$MARKER_DIR" agent_b)
assert_eq "Agent B sees correct type" "transient_429" "$rl_type"
clear_rate_limit_marker "$MARKER_DIR"

# Scenario 2: quota exceeded is per-agent — Agent B does NOT see Agent A's quota
set_rate_limit_marker "$MARKER_DIR" "quota_exceeded" "agent_a"
assert_true "Agent A sees own quota marker" "is_rate_limited '$MARKER_DIR' agent_a"
assert_false "Agent B does NOT see Agent A's quota marker" "is_rate_limited '$MARKER_DIR' agent_b"
rl_type=$(get_rate_limit_type "$MARKER_DIR" agent_a)
assert_eq "Agent A quota type" "quota_exceeded" "$rl_type"
rl_type=$(get_rate_limit_type "$MARKER_DIR" agent_b)
assert_eq "Agent B no quota type" "" "$rl_type"
clear_rate_limit_marker "$MARKER_DIR" "agent_a"

# Scenario 3: Marker file persistence across operations
set_rate_limit_marker "$MARKER_DIR" "transient_429"
assert_true "marker persists" "is_rate_limited '$MARKER_DIR'"
# Verify file exists and has expected format
assert_true "marker file exists" "[ -f '$MARKER_DIR/$RATE_LIMIT_MARKER' ]"
marker_content=$(cat "$MARKER_DIR/$RATE_LIMIT_MARKER")
assert_true "marker content has type" "echo '$marker_content' | grep -q 'transient_429'"
assert_true "marker content has timestamp" "echo '$marker_content' | grep -qE '[0-9]+'"
clear_rate_limit_marker "$MARKER_DIR"

# ==================== Tests: False Positive Prevention ====================

echo ""
echo "=== False Positive Prevention Tests ==="
echo ""

# Verify that agent output DISCUSSING rate limits (not actual errors) does NOT trigger
# has_fatal_error.  This was the root cause of the issue-55 terminal.log failure where
# has_fatal_error() in run.sh matched planning text containing "RATE_LIMIT_MAX_BACKOFF",
# "rate limit", "quota exceeded", etc. — those patterns are now removed from has_fatal_error()
# since classify_rate_limit() handles them first in run_with_retry().

# Simulate agent planning output that mentions rate limit concepts (from actual terminal.log)
cat > "$TEST_DIR/planning_output.log" << 'PLANEOF'
Here is the task breakdown:

{
  "subtasks": [
    {
      "id": "T-001",
      "title": "Rate limit detection",
      "description": "Implement RATE_LIMIT_MAX_BACKOFF environment variable (default 300s)",
      "acceptanceCriteria": [
        "Detect transient 429 and quota exceeded patterns",
        "Non-rate-limit errors still use annealing_delay()",
        "New test: tests/test_rate_limit_backoff.sh validates backoff logic"
      ]
    }
  ]
}
PLANEOF

# classify_rate_limit WILL match "rate limit" and "quota exceeded" in planning text because
# it uses broad grep patterns. In run_with_retry(), this would trigger the rate limit path,
# which does global cooldown then retries without consuming a retry slot. This is acceptable
# behavior — a brief cooldown is better than burning all retries as "fatal error".
# The key fix is that has_fatal_error() no longer contains rate limit patterns, so after
# classify_rate_limit processes the output, run_with_retry won't ALSO fail via has_fatal_error.

# Verify that has_fatal_error does NOT match planning text (the core fix)
# We extract has_fatal_error from run.sh to test it in isolation
has_fatal_error_test() {
    local log_file="$1"
    local pattern='^(Error|ERROR|Fatal|Panic|Exception)[: ]'
    pattern+='|^(timeout|authentication|unauthorized|API.key).*error'
    pattern+='|context.length.exceeded'
    pattern+='|maximum.context.length'
    pattern+='|token.limit.exceeded'
    pattern+='|model.is.overloaded'
    pattern+='|server.error'
    pattern+='|service.unavailable'
    pattern+='|internal.server.error'
    pattern+='|connection.refused'
    pattern+='|network.error'
    pattern+='|DNS.resolution'
    pattern+='|Timed.out'
    pattern+='|Command.timed.out'
    grep -qE "$pattern" "$log_file" 2>/dev/null
}

assert_false "planning output: has_fatal_error does NOT match" "has_fatal_error_test '$TEST_DIR/planning_output.log'"

# Simulate agent output discussing rate limit design (from terminal.log iteration 1)
cat > "$TEST_DIR/design_discussion.log" << 'DESIGNEOF'
## Implementation Plan

- **`run.sh`** — 在 `run_with_retry()` 中集成：
- 每次调用前检查全局标记（其他 agent 的限速状态）
- 调用后分类错误：429 → 全局冷却（不消耗重试次数），quota exceeded → 立即停止（返回码 3）
- 新增 `RATE_LIMIT_COOLDOWN` 环境变量（默认 60 秒）

## Learnings

- **模式**: Shell 脚本中跨进程状态共享最适合用文件标记
- **踩坑**: `classify_rate_limit` 通过 exit code 返回分类结果
- **经验**: 限速冷却不消耗重试次数是关键设计
DESIGNEOF

assert_false "design discussion: has_fatal_error does NOT match" "has_fatal_error_test '$TEST_DIR/design_discussion.log'"

# Verify has_fatal_error still catches real errors
echo "Error: connection refused" > "$TEST_DIR/real_conn_error.log"
assert_true "real connection error: has_fatal_error DOES match" "has_fatal_error_test '$TEST_DIR/real_conn_error.log'"

echo "Error: server error 500" > "$TEST_DIR/real_server_error.log"
assert_true "real server error: has_fatal_error DOES match" "has_fatal_error_test '$TEST_DIR/real_server_error.log'"

echo "Fatal: model is overloaded" > "$TEST_DIR/real_overload.log"
assert_true "real overload: has_fatal_error DOES match" "has_fatal_error_test '$TEST_DIR/real_overload.log'"

# ==================== Summary ====================

echo ""
echo "=========================================="
echo "Total: $TOTAL  Passed: $PASS  Failed: $FAIL"
echo "=========================================="

if [ "$FAIL" -gt 0 ]; then
    exit 1
fi

