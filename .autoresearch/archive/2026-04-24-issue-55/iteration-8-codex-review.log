#!/bin/bash
# lib/rate_limit.sh - Per-agent rate limit awareness for multi-agent retry coordination
#
# Problem: Each agent retries independently (5×), so a single rate limit event can
# burn 15 retries (3 agents × 5), wasting time and quota.
#
# Solution:
#   1. Detect rate limit errors (transient 429 vs quota exceeded)
#   2. Write a per-agent marker file so only the affected agent is blocked
#   3. Global cooldown (sleep) instead of per-agent retries for transient 429
#   4. Quota exceeded → hard stop for the affected agent only (other agents use different LLMs)
#
# Marker files:
#   .rate_limit_state              — global transient 429 marker (all agents share API endpoint)
#   .rate_limit_quota_<agent>      — per-agent quota exceeded marker (different LLMs, independent)
#
# Usage in run.sh:
#   source "$SCRIPT_DIR/lib/rate_limit.sh"
#   RATE_LIMIT_COOLDOWN=${RATE_LIMIT_COOLDOWN:-60}
#
#   # Inside run_with_retry, before agent call:
#   if is_rate_limited "$WORK_DIR" "$agent"; then
#       ...
#   fi
#
#   # After agent call:
#   classify_rate_limit "$log_file"
#   local rl_type=$?
#   if [ "$rl_type" -eq 2 ]; then
#       set_rate_limit_marker "$WORK_DIR" "quota_exceeded" "$agent"
#       return 3
#   elif [ "$rl_type" -eq 1 ]; then
#       set_rate_limit_marker "$WORK_DIR" "transient_429"
#       global_rate_limit_wait "$WORK_DIR" "$RATE_LIMIT_COOLDOWN"
#       clear_rate_limit_marker "$WORK_DIR" ""
#   fi

# ==================== Configuration ====================

# Default cooldown in seconds; override via RATE_LIMIT_COOLDOWN env var
RATE_LIMIT_COOLDOWN="${RATE_LIMIT_COOLDOWN:-60}"

# ==================== Detection ====================

# Detect transient 429 (rate limited but retryable).
# Returns 0 if a transient 429 pattern is found.
has_transient_429() {
    local log_file="$1"
    # Match error-context patterns (avoid false positives on discussion/code text)
    # Key: require either an error prefix, HTTP status, or "too many" phrasing
    local pattern='(Error|ERROR|error)[: ].*(429|rate.limit|too.many.requests|throttle)'
    pattern+='|HTTP.429'
    pattern+='|status.429'
    pattern+='|too.many.requests'
    pattern+='|request.was.throttled'
    pattern+='|Rate.limit.exceeded'
    pattern+='|API.rate.limit'
    pattern+='|rate.limit.exceeded'
    pattern+='|rate.limit.*error'
    pattern+='|429.*(error|Error|ERROR|Too.Many)'
    grep -qiE "$pattern" "$log_file" 2>/dev/null
}

# Detect quota exceeded (non-retryable, should hard-stop the affected agent).
# Returns 0 if a quota exceeded pattern is found.
has_quota_exceeded() {
    local log_file="$1"
    # Require error context to avoid matching discussion text
    local pattern='(Error|ERROR|error)[: ].*quota.exceeded'
    pattern+='|quota.exceeded.*(error|Error|ERROR|limit|reached|this)'
    pattern+='|billing.hard.limit'
    pattern+='|billing.limit.reached'
    pattern+='|monthly.spending.limit'
    pattern+='|usage.cap.exceeded'
    pattern+='|plan.limit.exceeded'
    pattern+='|insufficient.quota'
    grep -qiE "$pattern" "$log_file" 2>/dev/null
}

# Classify the rate limit type from a log file.
# Returns:
#   0 = no rate limit detected
#   1 = transient 429 (retryable with cooldown)
#   2 = quota exceeded (hard stop for this agent)
classify_rate_limit() {
    local log_file="$1"

    # Check quota exceeded first (higher severity)
    if has_quota_exceeded "$log_file"; then
        return 2
    fi

    # Check transient 429
    if has_transient_429 "$log_file"; then
        return 1
    fi

    return 0
}


