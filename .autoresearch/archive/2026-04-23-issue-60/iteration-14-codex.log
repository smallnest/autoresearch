                    /^## Agent Persona/ { in_persona=1; next }
                    /^## [^#]/ { in_persona=0 }
                    in_persona { next }
                    { print }
                '
                ;;
            *)
                trim_prompt_for_overflow "$prompt"
                ;;
        esac
    else
        echo "$prompt"
    fi
}

estimate_prompt_tokens() {
    local text="$1"
    if [ -z "$text" ]; then
        echo 0
        return
    fi
    local char_count
    char_count=${#text}
    echo $(( char_count / 3 ))
}

