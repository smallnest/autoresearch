start_spinner() {
    local msg="$1"
    (
        i=0
        while true; do
            local frame=$((i % 8))
            local rocket="${SPINNER_ROCKET[$frame]}"
            printf "\r  %s %s  " "$rocket" "$msg"
            sleep 0.12
            i=$((i + 1))
        done
    ) &
    SPINNER_PID=$!
}

