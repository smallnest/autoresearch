            BEGIN { in_program=0 }
            /^# Program/ { in_program=1; next }
            /^# [A-Z]/ { in_program=0 }
            in_program { next }
            { print }
        ')
    fi

--
    if [ "$PROMPT_TRIMMED" -ge 1 ]; then
        local trim_level=$PROMPT_TRIMMED
        PROMPT_TRIMMED=0
        case $trim_level in
