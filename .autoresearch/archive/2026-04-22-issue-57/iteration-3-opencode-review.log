+# ==================== Prompt 智能裁剪 ====================
+
+# PROMPT_TRIMMED 标志位：确保裁剪只触发一次
+PROMPT_TRIMMED=0
+
+# 智能裁剪 prompt：保留关键上下文，去掉冗余内容
+# 只在上下文溢出场景触发，其他错误场景不裁剪
+# 参数:
+#   $1 - prompt 内容
+# 输出: 裁剪后的 prompt
+trim_prompt_smart() {
+    local prompt="$1"
+
+    # 如果已经裁剪过，直接返回原始内容（防止逐次缩短）
+    if [ "$PROMPT_TRIMMED" -eq 1 ]; then
+        echo "$prompt"
+        return
+    fi
+
+    PROMPT_TRIMMED=1
+    log_console "⚠️ 执行智能 prompt 裁剪：保留关键上下文，去掉冗余内容"
+
+    local trimmed="$prompt"
+
+    # 1. 去掉 program.md 内容（以 "# Program" 开头的一级标题段落）
+    # 用 awk 删除从 "# Program" 到下一个一级标题之间的内容
+    if echo "$trimmed" | grep -q "^# Program"; then
+        trimmed=$(echo "$trimmed" | awk '
+            BEGIN { in_program=0 }
+            /^# Program/ { in_program=1; next }
+            /^# [A-Z]/ { in_program=0 }
+            in_program { next }
+            { print }
+        ')
+    fi
+
+    # 2. 去掉 agent persona 中的冗长示例代码块
+    # 删除超过 20 行的代码块（通常是 agent instructions 中的示例）
+    trimmed=$(echo "$trimmed" | awk '
+        BEGIN { in_block=0; block_lines=0; block_buf="" }
+        /^```/ {
+            if (in_block) {
+                in_block=0
+                if (block_lines <= 20) {
+                    print block_buf
+                    print "```"
+                }
+                block_buf=""; block_lines=0
+            } else {
+                in_block=1; block_buf="```"; block_lines=0
+            }
+            next
+        }
+        in_block {
+            block_lines++
+            block_buf = block_buf "\n" $0
+            next
+        }
+        { print }
+    ')
+
+    log "智能裁剪完成，原始长度: ${#prompt}, 裁剪后长度: ${#trimmed}"
+    echo "$trimmed"
+}
+
+# 获取 program.md 内容（支持裁剪模式）
+# 当 PROMPT_TRIMMED=1 时，返回空字符串以减少 token 使用
+get_program_instructions_trimmed() {
+    if [ "$PROMPT_TRIMMED" -eq 1 ]; then
+        log "PROMPT_TRIMMED=1，跳过 program.md"
+        echo ""
+        return
+    fi
+    get_program_instructions
+}
