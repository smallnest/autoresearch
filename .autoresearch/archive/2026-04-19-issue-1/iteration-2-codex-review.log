   706	run_opencode_review() {
   707	    local issue_number=$1
   708	    local iteration=$2
   709	
   710	    log "迭代 $iteration: OpenCode 审核..."
   711	
   712	    local opencode_instructions_file
   713	    opencode_instructions_file=$(get_agent_instructions "opencode")
   714	
   715	    local opencode_instructions=""
   716	    if [ -n "$opencode_instructions_file" ]; then
   717	        opencode_instructions=$(cat "$opencode_instructions_file")
   718	        log "使用指令文件: $opencode_instructions_file"
   719	    fi
   720	
   721	    local prompt="审核 Issue #$issue_number 的实现
   722	
   723	项目路径: $PROJECT_ROOT
   724	项目语言: $(detect_language)
   725	Issue 标题: $ISSUE_TITLE
   726	
   727	---
   728	请按照以下指令执行审核。
   729	
   730	评分格式要求: 必须在审核报告的总体评价中使用 **评分: X/100** 格式输出分数，其中 X 为 0-100 的整数。
   731	
   732	评分维度与权重:
   733	- 正确性 (35%): 功能是否符合需求、边界情况处理、错误处理
   734	- 测试质量 (25%): 核心逻辑覆盖、边界测试、错误路径测试
   735	- 代码质量 (20%): 命名清晰、结构清晰、遵循项目规范
   736	- 安全性 (10%): 输入验证、无注入风险、无敏感信息泄露
   737	- 性能 (10%): 无明显性能问题、无不必要的内存分配
   738	
   739	评分标准: 90-100 优秀 | 85-89 良好(达标) | 70-84 及格偏上 | 50-69 及格 | 30-49 较差 | 0-29 不合格
   740	注意: 评分 ≥ 85 才算达标。
   741	
   742	$opencode_instructions
   743	"
   744	
   745	    local log_file="$WORK_DIR/iteration-$iteration-opencode-review.log"
   746	
   747	    cd "$PROJECT_ROOT"
   748	    if ! run_with_retry opencode "$prompt" "$log_file"; then
   749	        echo "0" > "$WORK_DIR/.last_score"
   750	        return 1
   751	    fi
   752	
   753	    local score=0
   754	    local review_result
   755	    review_result=$(cat "$log_file")
   756	
   757	    score=$(extract_score "$review_result")
   758	
   759	    if [ -z "$score" ] || [ "$score" = "0" ]; then
   760	        log "警告: 无法从审核结果中提取评分，默认为 50"
   761	        score=50
   762	    fi
   763	
   764	    echo "- 审核评分 (OpenCode): $score/100" >> "$WORK_DIR/log.md"
   765	
   766	    log "审核评分: $score/100"
   767	
   768	    echo "$review_result"
   769	    echo "$score" > "$WORK_DIR/.last_score"
   770	    return 0
   771	}
