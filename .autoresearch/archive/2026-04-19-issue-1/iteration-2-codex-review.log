  1068	# ==================== 继续模式：恢复状态 ====================
  1069	
  1070	find_last_iteration() {
  1071	    local last=0
  1072	    for f in "$WORK_DIR"/iteration-*.log; do
  1073	        [ -f "$f" ] || continue
  1074	        local num
  1075	        num=$(basename "$f" | grep -oE 'iteration-[0-9]+' | grep -oE '[0-9]+')
  1076	        if [ -n "$num" ] && [ "$num" -gt "$last" ]; then
  1077	            last=$num
  1078	        fi
  1079	    done
  1080	    echo $last
  1081	}
  1082	
  1083	restore_continue_state() {
  1084	    local last_iter
  1085	    last_iter=$(find_last_iteration)
  1086	
  1087	    if [ "$last_iter" -eq 0 ]; then
  1088	        error "未找到任何迭代记录，无法继续"
  1089	        exit 1
  1090	    fi
  1091	
  1092	    log "上次运行到迭代 $last_iter，从迭代 $((last_iter + 1)) 继续"
  1093	
  1094	    # 恢复迭代计数
  1095	    ITERATION=$last_iter
  1096	
  1097	    # 恢复最终评分
  1098	    if [ -f "$WORK_DIR/.last_score" ]; then
  1099	        FINAL_SCORE=$(cat "$WORK_DIR/.last_score")
  1100	        log "上次评分: $FINAL_SCORE/100"
  1101	    fi
  1102	
  1103	    # 恢复连续失败计数：从日志中统计最近连续失败的迭代数
  1104	    if [ -f "$WORK_DIR/log.md" ]; then
  1105	        CONSECUTIVE_ITERATION_FAILURES=0
  1106	        # 从最近的迭代往回数，直到遇到非失败的迭代
  1107	        local iter=$last_iter
  1108	        while [ $iter -gt 0 ]; do
  1109	            local iter_log_header
  1110	            iter_log_header=$(grep -A1 "### 迭代 $iter " "$WORK_DIR/log.md" 2>/dev/null | head -2)
  1111	            # 检查该迭代是否有失败标记（测试失败或审核失败）
  1112	            if echo "$iter_log_header" | grep -qiE '失败|failed|❌'; then
  1113	                CONSECUTIVE_ITERATION_FAILURES=$((CONSECUTIVE_ITERATION_FAILURES + 1))
  1114	            else
  1115	                break
  1116	            fi
  1117	            iter=$((iter - 1))
  1118	        done
  1119	        log "恢复连续失败计数: $CONSECUTIVE_ITERATION_FAILURES"
  1120	    fi
