   985	
   986	    # 格式5: **评分: X** 或 **Score: X**
   987	    score_line=$(echo "$review_result" | grep -E '\*\*(评分|Score)' | head -1)
   988	    if [ -n "$score_line" ]; then
   989	        score=$(echo "$score_line" | grep -oE '[0-9]+\.?[0-9]*' | head -1)
