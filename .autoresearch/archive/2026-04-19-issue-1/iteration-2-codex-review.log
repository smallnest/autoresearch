   936	# ==================== 评分相关 ====================
   937	
   938	extract_score() {
   939	    local review_result="$1"
   940	    local score=0
   941	    local score_line
   942	
   943	    # 格式1: 明确的百分制 X/100
   944	    score_line=$(echo "$review_result" | grep -Eo '[0-9]+\.?[0-9]*(\s*/\s*100)' | head -1)
   945	    if [ -n "$score_line" ]; then
   946	        score=$(echo "$score_line" | grep -oE '[0-9]+\.?[0-9]*' | head -1)
   947	        score=$(awk -v s="$score" 'BEGIN { printf "%.0f", s }')
   948	        echo "$score"
   949	        return
   950	    fi
   951	
   952	    # 格式2: **评分: X/100** 或 **Score: X/100**
   953	    score_line=$(echo "$review_result" | grep -E '\*\*(评分|Score)[^*]*100' | head -1)
   954	    if [ -n "$score_line" ]; then
   955	        score=$(echo "$score_line" | grep -oE '[0-9]+\.?[0-9]*' | head -1)
   956	        score=$(awk -v s="$score" 'BEGIN { printf "%.0f", s }')
   957	        echo "$score"
   958	        return
   959	    fi
   960	
   961	    # 格式3: 总分行
   962	    score_line=$(echo "$review_result" | grep -E '(\*\*)?总分(\*\*)?\s*\|.*\*\*[0-9]' | head -1)
   963	    if [ -z "$score_line" ]; then
   964	        score_line=$(echo "$review_result" | grep -E '总分.*→' | head -1)
   965	    fi
   966	    if [ -n "$score_line" ]; then
   967	        score=$(echo "$score_line" | grep -oE '[0-9]+\.?[0-9]*' | tail -1)
   968	        if [ -n "$score" ]; then
   969	            score=$(awk -v s="$score" 'BEGIN { printf "%.0f", s * 10 }')
   970	            echo "$score"
   971	            return
   972	        fi
   973	    fi
   974	
   975	    # 格式4: X/10
   976	    score_line=$(echo "$review_result" | grep -Eo '[0-9]+\.?[0-9]*(\s*/\s*10)' | head -1)
   977	    if [ -n "$score_line" ]; then
   978	        score=$(echo "$score_line" | grep -oE '[0-9]+\.?[0-9]*' | head -1)
   979	        if [ -n "$score" ]; then
   980	            score=$(awk -v s="$score" 'BEGIN { printf "%.0f", s * 10 }')

