diff --git a/tests/test_git_push.sh b/tests/test_git_push.sh
new file mode 100644
index 0000000000000000000000000000000000000000..664a6878d7475e2f469bc254945da93b71ddf2d7
--- /dev/null
+++ b/tests/test_git_push.sh
@@ -0,0 +1,241 @@
+#!/bin/bash
+# tests/test_git_push.sh - Unit tests for git push recovery logic
+#
+# Usage: bash tests/test_git_push.sh
+
+set -e
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
+
+# ==================== Load production function ====================
+
+# shellcheck source=/dev/null
+source "$PROJECT_DIR/lib/git_push.sh"
+
+# ==================== Test Framework ====================
+
+PASS=0
+FAIL=0
+TOTAL=0
+
+assert_eq() {
+    local test_name="$1"
+    local expected="$2"
+    local actual="$3"
+    TOTAL=$((TOTAL + 1))
+    if [ "$expected" = "$actual" ]; then
+        PASS=$((PASS + 1))
+        echo "  PASS: $test_name (expected=$expected, actual=$actual)"
+    else
+        FAIL=$((FAIL + 1))
+        echo "  FAIL: $test_name (expected=$expected, actual=$actual)"
+    fi
+}
+
+assert_true() {
+    local test_name="$1"
+    local cmd="$2"
+    TOTAL=$((TOTAL + 1))
+    if eval "$cmd"; then
+        PASS=$((PASS + 1))
+        echo "  PASS: $test_name"
+    else
+        FAIL=$((FAIL + 1))
+        echo "  FAIL: $test_name"
+    fi
+}
+
+# ==================== Mocks ====================
+
+TEST_ROOT=""
+WORK_DIR=""
+PROJECT_ROOT=""
+BRANCH_NAME="feature/test-branch"
+CONSOLE_LOG=""
+ERROR_LOG=""
+MOCK_DIRTY=0
+MOCK_PUSH_FAILS=1
+MOCK_PUSH_ERROR_1="fatal: first push failed"
+MOCK_PUSH_ERROR_2="fatal: retry push failed"
+STATE_DIR=""
+
+write_counter() {
+    local name="$1"
+    local value="$2"
+    printf '%s' "$value" > "$STATE_DIR/$name"
+}
+
+read_counter() {
+    local name="$1"
+    if [ -f "$STATE_DIR/$name" ]; then
+        cat "$STATE_DIR/$name"
+    else
+        echo "0"
+    fi
+}
+
+log_console() {
+    CONSOLE_LOG="${CONSOLE_LOG}$1
+"
+}
+
+error() {
+    ERROR_LOG="${ERROR_LOG}$1
+"
+}
+
+git() {
+    local cmd="$1"
+    shift
+
+    case "$cmd" in
+        push)
+            local push_calls
+            push_calls=$(read_counter "push_calls")
+            push_calls=$((push_calls + 1))
+            write_counter "push_calls" "$push_calls"
+            if [ $push_calls -le $MOCK_PUSH_FAILS ]; then
+                if [ $push_calls -eq 1 ]; then
+                    echo "$MOCK_PUSH_ERROR_1" >&2
+                else
+                    echo "$MOCK_PUSH_ERROR_2" >&2
+                fi
+                return 1
+            fi
+            echo "branch pushed"
+            return 0
+            ;;
+        status)
+            if [ "$1" = "--porcelain" ] && [ $MOCK_DIRTY -eq 1 ]; then
+                echo " M run.sh"
+            fi
+            return 0
+            ;;
+        stash)
+            case "$1" in
+                list)
+                    local stash_count
+                    local i=0
+                    stash_count=$(read_counter "stash_count")
+                    while [ $i -lt $stash_count ]; do
+                        echo "stash@{$i}: On mock branch: autoresearch"
+                        i=$((i + 1))
+                    done
+                    return 0
+                    ;;
+                push)
+                    local stash_push_calls
+                    local stash_count
+                    stash_push_calls=$(read_counter "stash_push_calls")
+                    stash_count=$(read_counter "stash_count")
+                    write_counter "stash_push_calls" $((stash_push_calls + 1))
+                    write_counter "stash_count" $((stash_count + 1))
+                    echo "Saved working directory and index state"
+                    return 0
+                    ;;
+                pop)
+                    local stash_pop_calls
+                    local stash_count
+                    stash_pop_calls=$(read_counter "stash_pop_calls")
+                    stash_count=$(read_counter "stash_count")
+                    write_counter "stash_pop_calls" $((stash_pop_calls + 1))
+                    if [ $stash_count -gt 0 ]; then
+                        write_counter "stash_count" $((stash_count - 1))
+                    fi
+                    echo "Dropped refs/stash@{0}"
+                    return 0
+                    ;;
+            esac
+            ;;
+    esac
+
+    command git "$cmd" "$@"
+}
+
+# ==================== Setup/Teardown ====================
+
+setup() {
+    TEST_ROOT=$(mktemp -d)
+    STATE_DIR="$TEST_ROOT/state"
+    WORK_DIR="$TEST_ROOT/work"
+    PROJECT_ROOT="$TEST_ROOT/project"
+    mkdir -p "$STATE_DIR" "$WORK_DIR" "$PROJECT_ROOT"
+    : > "$WORK_DIR/log.md"
+
+    CONSOLE_LOG=""
+    ERROR_LOG=""
+    MOCK_DIRTY=0
+    MOCK_PUSH_FAILS=1
+    MOCK_PUSH_ERROR_1="fatal: first push failed"
+    MOCK_PUSH_ERROR_2="fatal: retry push failed"
+    write_counter "push_calls" "0"
+    write_counter "stash_push_calls" "0"
+    write_counter "stash_pop_calls" "0"
+    write_counter "stash_count" "0"
+}
+
+cleanup() {
+    if [ -n "$TEST_ROOT" ] && [ -d "$TEST_ROOT" ]; then
+        rm -rf "$TEST_ROOT"
+    fi
+}
+
+# ==================== Tests ====================
+
+echo "=== push_branch_with_recovery() Tests ==="
+echo ""
+
+setup
+echo "Scenario 1: first push failure logs details and suggestions"
+rc=0
+push_branch_with_recovery || rc=$?
+assert_eq "returns non-zero on unrecoverable push failure" "1" "$rc"
+assert_eq "push attempted once" "1" "$(read_counter "push_calls")"
+assert_eq "stash not attempted when working tree clean" "0" "$(read_counter "stash_push_calls")"
+assert_true "log.md records initial push failure" "grep -q '## ❌ Git Push 失败' '$WORK_DIR/log.md'"
+assert_true "log.md records git error output" "grep -q 'fatal: first push failed' '$WORK_DIR/log.md'"
+assert_true "console prints recovery suggestions" "printf '%s' \"\$CONSOLE_LOG\" | grep -q '📋 恢复建议'"
+assert_true "console prints manual push command" "printf '%s' \"\$CONSOLE_LOG\" | grep -q 'git push -u origin $BRANCH_NAME'"
+cleanup
+
+setup
+echo "Scenario 2: dirty tree triggers stash and successful retry"
+MOCK_DIRTY=1
+MOCK_PUSH_FAILS=1
+rc=0
+push_branch_with_recovery || rc=$?
+assert_eq "returns zero after successful retry" "0" "$rc"
+assert_eq "push attempted twice" "2" "$(read_counter "push_calls")"
+assert_eq "stash push called once" "1" "$(read_counter "stash_push_calls")"
+assert_eq "stash pop called once" "1" "$(read_counter "stash_pop_calls")"
+assert_true "console confirms retry success" "printf '%s' \"\$CONSOLE_LOG\" | grep -q '✅ Stash 后重试成功！'"
+cleanup
+
+setup
+echo "Scenario 3: retry failure still records retry output"
+MOCK_DIRTY=1
+MOCK_PUSH_FAILS=2
+rc=0
+push_branch_with_recovery || rc=$?
+assert_eq "returns non-zero after retry failure" "1" "$rc"
+assert_eq "push attempted twice before giving up" "2" "$(read_counter "push_calls")"
+assert_eq "stash push called for retry failure path" "1" "$(read_counter "stash_push_calls")"
+assert_eq "stash pop still called after retry failure" "1" "$(read_counter "stash_pop_calls")"
+assert_true "log.md records retry failure block" "grep -q '重试结果' '$WORK_DIR/log.md'"
+assert_true "log.md records retry stderr" "grep -q 'fatal: retry push failed' '$WORK_DIR/log.md'"
+assert_true "console reports retry failure" "printf '%s' \"\$CONSOLE_LOG\" | grep -q '❌ 重试仍然失败'"
+cleanup
+
+# ==================== Summary ====================
+
+echo ""
+echo "=========================================="
+echo "Total: $TOTAL  Passed: $PASS  Failed: $FAIL"
+echo "=========================================="
+
+if [ $FAIL -gt 0 ]; then
+    exit 1
+fi
+
+exit 0

