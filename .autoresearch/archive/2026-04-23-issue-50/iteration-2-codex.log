+        log_console "   gh pr create --title '<issue-title> (#<issue-number>)'"
+        log_console ""
+        log_console "6. 如果 stash 未自动恢复，运行:"
+        log_console "   git stash list"
+        log_console "   git stash pop"
+        log_console "═══════════════════════════════════════════════════════════"
+        log_console ""
+        log_console "📂 工作目录: $WORK_DIR"
+        log_console "📄 详细日志: $WORK_DIR/log.md"
+        log_console ""
+
+        return 1
+    }
+
+    return 0
+}
