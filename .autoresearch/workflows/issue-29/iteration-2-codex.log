}

function clamp(value: number, min: number, max: number): number {
  return Math.max(min, Math.min(max, value));
}

export const useRunConfigStore = create<RunConfigState>()(
  persist(
    (set) => ({
      maxIterations: DEFAULT_MAX_ITERATIONS,
      passingScore: DEFAULT_PASSING_SCORE,
      continueMode: DEFAULT_CONTINUE_MODE,

      setMaxIterations: (value: number) => {
        const clampedValue = clamp(value, MAX_ITERATIONS_MIN, MAX_ITERATIONS_MAX);
        set({ maxIterations: clampedValue });
      },

      setPassingScore: (value: number) => {
        const clampedValue = clamp(value, PASSING_SCORE_MIN, PASSING_SCORE_MAX);
        set({ passingScore: clampedValue });
      },

      setContinueMode: (value: boolean) => {
        set({ continueMode: value });
      },

      resetToDefaults: () => {
        set({
          maxIterations: DEFAULT_MAX_ITERATIONS,
          passingScore: DEFAULT_PASSING_SCORE,
          continueMode: DEFAULT_CONTINUE_MODE,
        });
      },
    }),
    {
      name: 'autoresearch-run-config',
    }
  )
);

// Export constants for external use
export const RUN_CONFIG_DEFAULTS = {
  maxIterations: DEFAULT_MAX_ITERATIONS,
  passingScore: DEFAULT_PASSING_SCORE,
  continueMode: DEFAULT_CONTINUE_MODE,
} as const;

export const RUN_CONFIG_CONSTRAINTS = {
  maxIterations: { min: MAX_ITERATIONS_MIN, max: MAX_ITERATIONS_MAX },
  passingScore: { min: PASSING_SCORE_MIN, max: PASSING_SCORE_MAX },
} as const;
