diff --git a/desktop_app/tests/runConfigStore.test.mjs b/desktop_app/tests/runConfigStore.test.mjs
new file mode 100644
index 0000000000000000000000000000000000000000..71a3dbcc0bf83053f5157e68f9345accdc6d8122
--- /dev/null
+++ b/desktop_app/tests/runConfigStore.test.mjs
@@ -0,0 +1,84 @@
+import test from 'node:test';
+import assert from 'node:assert/strict';
+import { createJSONStorage } from 'zustand/middleware';
+import {
+  createRunConfigStore,
+  RUN_CONFIG_DEFAULTS,
+} from '../src/stores/runConfigStore.ts';
+
+function createMemoryStateStorage(initialData = {}) {
+  const data = new Map(Object.entries(initialData));
+
+  return {
+    getItem: (name) => data.get(name) ?? null,
+    setItem: (name, value) => {
+      data.set(name, value);
+    },
+    removeItem: (name) => {
+      data.delete(name);
+    },
+  };
+}
+
+test('runConfigStore exposes the expected defaults', () => {
+  const store = createRunConfigStore({ skipHydration: true });
+
+  assert.equal(store.getState().maxIterations, RUN_CONFIG_DEFAULTS.maxIterations);
+  assert.equal(store.getState().passingScore, RUN_CONFIG_DEFAULTS.passingScore);
+  assert.equal(store.getState().continueMode, RUN_CONFIG_DEFAULTS.continueMode);
+});
+
+test('runConfigStore clamps numeric values to configured bounds', () => {
+  const store = createRunConfigStore({ skipHydration: true });
+
+  store.getState().setMaxIterations(0);
+  store.getState().setPassingScore(101);
+
+  assert.equal(store.getState().maxIterations, 1);
+  assert.equal(store.getState().passingScore, 100);
+
+  store.getState().setMaxIterations(51);
+  store.getState().setPassingScore(-1);
+
+  assert.equal(store.getState().maxIterations, 50);
+  assert.equal(store.getState().passingScore, 1);
+});
+
+test('runConfigStore resetToDefaults restores all fields', () => {
+  const store = createRunConfigStore({ skipHydration: true });
+
+  store.getState().setMaxIterations(22);
+  store.getState().setPassingScore(90);
+  store.getState().setContinueMode(true);
+  store.getState().resetToDefaults();
+
+  assert.equal(store.getState().maxIterations, RUN_CONFIG_DEFAULTS.maxIterations);
+  assert.equal(store.getState().passingScore, RUN_CONFIG_DEFAULTS.passingScore);
+  assert.equal(store.getState().continueMode, RUN_CONFIG_DEFAULTS.continueMode);
+});
+
+test('runConfigStore sanitizes invalid persisted state during hydration', async () => {
+  const storage = createJSONStorage(() =>
+    createMemoryStateStorage({
+      'autoresearch-run-config': JSON.stringify({
+        state: {
+          maxIterations: 0,
+          passingScore: 999,
+          continueMode: 'yes',
+        },
+        version: 0,
+      }),
+    })
+  );
+
+  const store = createRunConfigStore({
+    storage,
+    skipHydration: true,
+  });
+
+  await store.persist.rehydrate();
+
+  assert.equal(store.getState().maxIterations, 1);
+  assert.equal(store.getState().passingScore, 100);
+  assert.equal(store.getState().continueMode, false);
+});

