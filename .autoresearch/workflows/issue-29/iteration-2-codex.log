+} as const;
+
+function clamp(value: number, min: number, max: number): number {
+  return Math.max(min, Math.min(max, value));
+}
+
+function sanitizeNumber(
+  value: unknown,
+  fallback: number,
+  min: number,
+  max: number
+): number {
+  return typeof value === 'number' && Number.isFinite(value)
+    ? clamp(value, min, max)
+    : fallback;
+}
+
+function sanitizePersistedState(
+  persistedState: Partial<RunConfigPersistedState> | undefined
+): RunConfigPersistedState {
+  return {
+    maxIterations: sanitizeNumber(
+      persistedState?.maxIterations,
+      DEFAULT_MAX_ITERATIONS,
+      MAX_ITERATIONS_MIN,
+      MAX_ITERATIONS_MAX
+    ),
+    passingScore: sanitizeNumber(
+      persistedState?.passingScore,
+      DEFAULT_PASSING_SCORE,
+      PASSING_SCORE_MIN,
+      PASSING_SCORE_MAX
+    ),
+    continueMode:
+      typeof persistedState?.continueMode === 'boolean'
+        ? persistedState.continueMode
+        : DEFAULT_CONTINUE_MODE,
+  };
+}
+
+function createRunConfigState(set: (partial: Partial<RunConfigState>) => void): RunConfigState {
+  return {
+    ...RUN_CONFIG_DEFAULTS,
+
+    setMaxIterations: (value: number) => {
+      set({
+        maxIterations: sanitizeNumber(
+          value,
+          DEFAULT_MAX_ITERATIONS,
+          MAX_ITERATIONS_MIN,
+          MAX_ITERATIONS_MAX
+        ),
+      });
+    },
+
+    setPassingScore: (value: number) => {
+      set({
+        passingScore: sanitizeNumber(
+          value,
+          DEFAULT_PASSING_SCORE,
+          PASSING_SCORE_MIN,
+          PASSING_SCORE_MAX
+        ),
+      });
+    },
+
+    setContinueMode: (value: boolean) => {
+      set({ continueMode: value });
+    },
+
+    resetToDefaults: () => {
+      set({ ...RUN_CONFIG_DEFAULTS });
+    },
+  };
+}
+
+export function createRunConfigStore(persistOptions: RunConfigPersistOptions = {}) {
+  return create<RunConfigState>()(
+    persist(
+      (set) => createRunConfigState(set),
+      {
+        name: RUN_CONFIG_STORE_NAME,
+        partialize: (state) => ({
+          maxIterations: state.maxIterations,
+          passingScore: state.passingScore,
+          continueMode: state.continueMode,
+        }),
+        merge: (persistedState, currentState) => ({
+          ...currentState,
+          ...sanitizePersistedState(
+            persistedState as Partial<RunConfigPersistedState> | undefined
+          ),
+        }),
+        ...persistOptions,
+      }
+    )
+  );
+}
+
+export const useRunConfigStore = createRunConfigStore();
