   102	export function classifyLogLevel(line: string): LogLevel {
   103	  const normalized = line.toLowerCase();
   104	  if (
   105	    normalized.includes('error') ||
   106	    normalized.includes('failed') ||
   107	    normalized.includes('failure') ||
   108	    normalized.includes('fatal') ||
   109	    normalized.includes('❌') ||
   110	    normalized.includes('错误') ||
   111	    normalized.includes('失败')
   112	  ) {
   113	    return 'error';
   114	  }
   115	
   116	  if (
   117	    normalized.includes('warn') ||
   118	    normalized.includes('warning') ||
   119	    normalized.includes('⚠️') ||
   120	    normalized.includes('警告')
   121	  ) {
   122	    return 'warn';
   123	  }
   124	
   125	  return 'info';
   126	}
