   158	            error:
   159	              killed || exitCode === 0
   160	                ? null
   161	                : `运行失败${exitCode === null ? '' : `（退出码 ${exitCode}）`}`,
   162	          }));
   163	        }),
   164	      ]);
   165	
   166	      set({ subscriptionsReady: true });
   167	      await get().refreshStatus();
   168	    },
