   130	export function buildLogEntries(text: string): LogEntry[] {
   131	  if (!text) {
   132	    return [];
   133	  }
   134	
   135	  const lines = text.split(/\r?\n/);
   136	  const start = Math.max(0, lines.length - MAX_LOG_LINES);
   137	  return lines.slice(start).map((line, index) => ({
   138	    lineNumber: start + index + 1,
   139	    text: line,
   140	    level: classifyLogLevel(line),
   141	  }));
   142	}
