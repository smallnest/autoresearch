                >
                  {label.name}
                </span>
              ))}
            </div>
          )}

          {/* Created date */}
          <p className="text-xs text-gray-500">
            创建于 {formatDate(issue.createdAt)}
          </p>
        </div>

        {/* Selection indicator */}
        {isSelected && (
          <div className="flex-shrink-0 self-center">
            <CheckIcon className="w-5 h-5 text-blue-400" />
          </div>
        )}
      </div>
    </div>
  );
}

