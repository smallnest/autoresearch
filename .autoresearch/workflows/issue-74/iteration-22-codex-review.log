    sources,
    selectedSourceId,
    searchQuery,
    levelFilters,
    autoScroll,
    hasPendingScroll,
    sourceContents,
    isLoadingSources,
    isLoadingContent,
    error,
    loadSources,
    refreshSelectedSource,
    selectSource,
    setSearchQuery,
    toggleLevel,
    setAutoScroll,
    markScrollPending,
    clearError,
    clearIssue,
  } = useLogViewerStore();

  const isCurrentIssueRunning =
    activeIssueNumber === issueNumber &&
    (runStatus === 'running' || runStatus === 'stopping');
  const selectedSource =
    sources.find((source) => source.id === selectedSourceId) ?? sources[0];

