  }
}

function formatUpdatedAt(value: string | null): string {
  if (!value) {
    return '未记录';
  }

  const timestamp = Number(value) * 1000;
  if (Number.isNaN(timestamp)) {
    return value;
  }

  return new Date(timestamp).toLocaleString('zh-CN', {
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
  });
}

