  );
}

export function ReviewScoreSection({
  score,
  passingScore,
  summary,
}: ReviewScoreSectionProps): ReactElement | null {
  if (score == null) {
    return null;
  }

  return createElement(
    Fragment,
    null,
    createElement(ScoreDisplay, { score, passingScore }),
    summary != null ? createElement(ReviewSummaryCard, { summary }) : null,
  );
}

