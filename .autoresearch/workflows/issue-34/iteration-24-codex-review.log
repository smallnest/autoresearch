   336	  isInteractionLocked,
   337	  confirmPendingAction,
   338	  clearFeedback,
   339	  bumpReloadKey,
   340	}: ReloadConfigEditorFileOptions): boolean {
   341	  if (!projectPath || isInteractionLocked) {
   342	    return false;
   343	  }
   344	
