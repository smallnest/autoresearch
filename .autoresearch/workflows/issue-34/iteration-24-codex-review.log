export function resolveConfigEditorProjectPath({
  projectPath,
  loadedProjectPath,
  pendingProjectPath,
}: {
  projectPath: string | null;
  loadedProjectPath: string | null;
  pendingProjectPath: string | null;
}): string | null {
  if (pendingProjectPath && loadedProjectPath) {
    return loadedProjectPath;
  }

  return projectPath;
}

