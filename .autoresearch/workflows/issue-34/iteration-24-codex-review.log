   245	export function saveTargetPath(projectPath: string, relativePath: string): string {
   246	  const separator =
   247	    projectPath.includes('\\') || /^[A-Za-z]:/.test(projectPath) ? '\\' : '/';
   248	  const trimmedProjectPath = projectPath.replace(/[\\/]+$/, '');
   249	  const normalizedProjectPath = trimmedProjectPath.replace(/[\\/]+/g, separator);
   250	  const normalizedRelativePath = relativePath.replace(/[\\/]+/g, separator);
   251	  return `${normalizedProjectPath}${separator}.autoresearch${separator}${normalizedRelativePath}`;
   252	}
