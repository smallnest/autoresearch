   354	export function resolveConfigEditorLoadPlan({
   355	  projectPath,
   356	  loadedProjectPath,
   357	  isDirty,
   358	  confirmDiscard,
   359	}: {
   360	  projectPath: string | null;
   361	  loadedProjectPath: string | null;
   362	  isDirty: boolean;
   363	  confirmDiscard: (message: string) => boolean;
   364	}): ConfigEditorLoadPlan {
   365	  if (!projectPath) {
   366	    return { type: 'clear' };
   367	  }
   368	
   369	  if (
   370	    loadedProjectPath &&
   371	    projectPath !== loadedProjectPath &&
   372	    !shouldProceedWithPendingAction(
   373	      isDirty,
   374	      { type: 'switch-project', nextProjectPath: projectPath },
   375	      confirmDiscard
   376	    )
   377	  ) {
   378	    return {
   379	      type: 'block-project-switch',
   380	      nextProjectPath: projectPath,
   381	      statusMessage: pendingProjectSwitchMessage(projectPath),
   382	    };
   383	  }
   384	
   385	  return {
   386	    type: 'load',
   387	    projectPath,
   388	  };
   389	}
