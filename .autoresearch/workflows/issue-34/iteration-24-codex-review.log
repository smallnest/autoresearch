   308	export function switchConfigEditorFile({
   309	  activeFileId,
   310	  nextFileId,
   311	  isInteractionLocked,
   312	  confirmPendingAction,
   313	  clearFeedback,
   314	  setActiveFileId,
   315	}: SwitchConfigEditorFileOptions): boolean {
   316	  if (activeFileId === nextFileId || isInteractionLocked) {
   317	    return false;
   318	  }
   319	
   320	  if (
   321	    !confirmPendingAction({
   322	      type: 'switch-file',
   323	      nextFileId,
   324	    })
   325	  ) {
   326	    return false;
   327	  }
