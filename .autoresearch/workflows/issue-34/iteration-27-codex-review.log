  1100	fn backup_existing_file(path: &Path) -> Result<(), String> {
  1101	    if !path.exists() {
  1102	        return Ok(());
  1103	    }
  1104	
  1105	    if !path.is_file() {
  1106	        return Err(format!(
  1107	            "Cannot back up config file because path is not a file: {}",
  1108	            path.display()
  1109	        ));
  1110	    }
  1111	
  1112	    let file_name = path
  1113	        .file_name()
  1114	        .and_then(|name| name.to_str())
  1115	        .ok_or_else(|| format!("Invalid config filename: {}", path.display()))?;
  1116	    let backup_path = path.with_file_name(format!("{file_name}.bak"));
  1117	    if backup_path.exists() {
  1118	        let metadata = fs::symlink_metadata(&backup_path).map_err(|e| {
  1119	            format!(
  1120	                "Failed to inspect backup path {}: {e}",
  1121	                backup_path.display()
  1122	            )
  1123	        })?;
  1124	        if metadata.file_type().is_symlink() {
  1125	            return Err(format!(
  1126	                "Backup path contains symlink: {}",
  1127	                backup_path.display()
  1128	            ));
  1129	        }
  1130	        if !metadata.is_file() {
  1131	            return Err(format!(
  1132	                "Backup path is not a file: {}",
  1133	                backup_path.display()
  1134	            ));
  1135	        }
  1136	    }
  1137	
  1138	    fs::copy(path, &backup_path).map_err(|e| {
  1139	        format!(
  1140	            "Failed to create backup {} from {}: {e}",
  1141	            backup_path.display(),
  1142	            path.display()
  1143	        )
  1144	    })?;
  1145	
  1146	    Ok(())
  1147	}
  1148	
  1149	fn write_config_file_sync(
  1150	    base: &Path,
  1151	    project_path: &str,
  1152	    file_id: &str,
  1153	    content: &str,
  1154	) -> Result<ConfigFileContent, String> {
  1155	    if !base.is_dir() {
  1156	        return Err(format!("Path is not a directory: {project_path}"));
  1157	    }
  1158	
  1159	    let target_path = resolve_project_config_file_path(base, file_id)?;
  1160	    ensure_parent_dir(base, &target_path, "config file")?;
  1161	    backup_existing_file(&target_path)?;
  1162	    fs::write(&target_path, content)
  1163	        .map_err(|e| format!("Failed to write config file {}: {e}", target_path.display()))?;
  1164	
  1165	    read_config_file_sync(base, project_path, file_id)
  1166	}
  1167	
  1168	fn reset_config_file_sync(
  1169	    base: &Path,
  1170	    project_path: &str,
  1171	    file_id: &str,
  1172	) -> Result<ConfigFileContent, String> {
  1173	    let (_, default_content) = supported_config_file(file_id)
  1174	        .ok_or_else(|| format!("Unsupported config file: {file_id}"))?;
  1175	    write_config_file_sync(base, project_path, file_id, default_content)
  1176	}
