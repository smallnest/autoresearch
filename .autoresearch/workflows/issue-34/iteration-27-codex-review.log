  1600	/// Parameters are mapped to run.sh CLI arguments:
  1601	/// - `issue_number` -> positional argument
  1602	/// - `max_iter` -> positional argument (after issue_number)
  1603	/// - `agents` -> `-a` option
  1604	/// - `passing_score` -> `PASSING_SCORE` environment variable
  1605	/// - `continue_mode` -> `-c` flag
  1606	///
  1607	/// The process's stdout/stderr are streamed via `run-output` Tauri events.
  1608	/// When the process exits, a `run-exit` event is emitted.
  1609	#[cfg(unix)]
  1610	#[tauri::command]
  1611	async fn start_run(app: tauri::AppHandle, request: StartRunRequest) -> Result<(), String> {
  1612	    let state = get_run_state();
  1613	    let mut state_guard = state.lock().await;
  1614	
  1615	    // Check if a process is already running
  1616	    if state_guard.process.is_some() {
  1617	        return Err(
  1618	            "A run is already in progress. Stop the current run before starting a new one."
  1619	                .to_string(),
  1620	        );
  1621	    }
  1622	
  1623	    // Validate project path
  1624	    let project_path = Path::new(&request.project_path);
  1625	    if !project_path.is_dir() {
  1626	        return Err(format!(
  1627	            "Project path is not a directory: {}",
  1628	            request.project_path
  1629	        ));
  1630	    }
  1631	
  1632	    // Find run.sh in autoresearch directory (relative to the app)
  1633	    // run.sh is in the autoresearch project root, which is the parent of desktop_app
  1634	    let autoresearch_root = project_path
  1635	        .parent()
  1636	        .ok_or("Cannot determine autoresearch root directory")?;
  1637	    let run_sh_path = autoresearch_root.join("run.sh");
  1638	    if !run_sh_path.is_file() {
  1639	        return Err(format!("run.sh not found at: {}", run_sh_path.display()));
  1640	    }
  1641	
  1642	    // Build command arguments and environment variables
  1643	    let args = build_run_args(&request);
  1644	    let env_vars = build_run_env_vars(&request);
  1645	
  1646	    // Spawn the process with a new process group
  1647	    let mut cmd = TokioCommand::new(&run_sh_path);
  1648	    cmd.args(&args)
  1649	        .current_dir(autoresearch_root)
  1650	        .stdout(StdStdio::piped())
  1651	        .stderr(StdStdio::piped())
  1652	        .kill_on_drop(false); // Don't kill on drop - we want to manage the process lifecycle
  1653	
  1654	    // Set environment variables
  1655	    for (key, value) in &env_vars {
  1656	        cmd.env(key, value);
  1657	    }
  1658	
  1659	    // Set up process group on Unix
  1660	    // SAFETY: pre_exec is safe as long as the closure doesn't panic or call unsafe code
  1661	    unsafe {
  1662	        cmd.pre_exec(move || {
  1663	            // Create a new process group with the child's PID as the PGID
  1664	            let pid = libc::getpid();
  1665	            if libc::setpgid(pid, pid) < 0 {
  1666	                // Log error but don't fail the spawn
  1667	                eprintln!(
  1668	                    "Warning: Failed to set process group: {}",
  1669	                    std::io::Error::last_os_error()
  1670	                );
  1671	            }
  1672	            Ok(())
  1673	        });
  1674	    }
  1675	
  1676	    // Spawn the process
  1677	    let mut child = cmd
  1678	        .spawn()
  1679	        .map_err(|e| format!("Failed to start run.sh: {e}"))?;
  1680	
  1681	    let pid = child.id().ok_or("Failed to get process ID")?;
  1682	
  1683	    // Store the PID for process group management
  1684	    state_guard.process = Some(RunProcess {
  1685	        pid,
  1686	        project_path: request.project_path.clone(),
  1687	        issue_number: request.issue_number,
  1688	        last_progress: None,
  1689	    });
  1690	    drop(state_guard);
  1691	
  1692	    // Reset the killed flag
  1693	    get_was_killed().store(false, Ordering::SeqCst);
  1694	
  1695	    emit_iteration_progress(&app).await;
  1696	
  1697	    // Clone app handle for the spawned task
  1698	    let app_clone = app.clone();
  1699	    let state_clone = get_run_state();
  1700	
  1701	    // Take stdout/stderr before waiting on the process
  1702	    let stdout = child.stdout.take();
  1703	    let stderr = child.stderr.take();
  1704	
  1705	    // Spawn a task to wait for process exit and emit event
  1706	    tokio::spawn(async move {
  1707	        let status = child.wait().await;
  1708	
  1709	        emit_iteration_progress(&app_clone).await;
  1710	
  1711	        // Check if we were killed by stop_run
  1712	        let was_killed = get_was_killed().swap(false, Ordering::SeqCst);
  1713	
  1714	        // Clear the process state
  1715	        {
  1716	            let mut state_guard = state_clone.lock().await;
  1717	            state_guard.process = None;
  1718	        }
  1719	
  1720	        // Only emit exit event if we weren't killed by stop_run
  1721	        // (stop_run emits its own event)
  1722	        if !was_killed {
  1723	            let exit_event = match status {
  1724	                Ok(status) => RunExitEvent {
  1725	                    exit_code: status.code(),
  1726	                    killed: false,
  1727	                },
  1728	                Err(_) => RunExitEvent {
  1729	                    exit_code: None,
  1730	                    killed: false,
  1731	                },
  1732	            };
  1733	
  1734	            let _ = app_clone.emit("run-exit", &exit_event);
  1735	        }
  1736	    });
  1737	
  1738	    // Handle stdout streaming
  1739	    if let Some(stdout) = stdout {
  1740	        let app_clone = app.clone();
  1741	        tokio::spawn(async move {
  1742	            let mut reader = TokioBufReader::new(stdout).lines();
  1743	            while let Ok(Some(line)) = reader.next_line().await {
  1744	                let _ = app_clone.emit("run-output", &line);
  1745	                emit_iteration_progress(&app_clone).await;
  1746	            }
  1747	        });
  1748	    }
  1749	
  1750	    // Handle stderr streaming
  1751	    if let Some(stderr) = stderr {
  1752	        let app_clone = app.clone();
  1753	        tokio::spawn(async move {
  1754	            let mut reader = TokioBufReader::new(stderr).lines();
  1755	            while let Ok(Some(line)) = reader.next_line().await {
  1756	                let _ = app_clone.emit("run-output", &line);
  1757	                emit_iteration_progress(&app_clone).await;
  1758	            }
  1759	        });
  1760	    }
  1761	
  1762	    Ok(())
  1763	}
