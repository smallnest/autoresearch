  1050	fn read_config_file_sync(
  1051	    base: &Path,
  1052	    project_path: &str,
  1053	    file_id: &str,
  1054	) -> Result<ConfigFileContent, String> {
  1055	    let (relative_path, default_content) = supported_config_file(file_id)
  1056	        .ok_or_else(|| format!("Unsupported config file: {file_id}"))?;
  1057	
  1058	    if !base.is_dir() {
  1059	        return Err(format!("Path is not a directory: {project_path}"));
  1060	    }
  1061	
  1062	    let project_config_path = resolve_project_config_file_path(base, file_id)?;
  1063	    validate_config_path(base, &project_config_path)?;
  1064	
  1065	    let (content, source) = if project_config_path.is_file() {
  1066	        (
  1067	            fs::read_to_string(&project_config_path).map_err(|e| {
  1068	                format!(
  1069	                    "Failed to read config file {}: {e}",
  1070	                    project_config_path.display()
  1071	                )
  1072	            })?,
  1073	            "project",
  1074	        )
  1075	    } else {
  1076	        (default_content.to_string(), "default")
  1077	    };
  1078	
  1079	    Ok(ConfigFileContent {
