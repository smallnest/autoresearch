  1765	/// Stops the currently running run.sh process by sending SIGTERM to its process group.
  1766	#[cfg(unix)]
  1767	#[tauri::command]
  1768	async fn stop_run(app: tauri::AppHandle) -> Result<(), String> {
  1769	    let state = get_run_state();
  1770	    let mut state_guard = state.lock().await;
  1771	
  1772	    let process = state_guard.process.take().ok_or("No run is in progress")?;
  1773	    let pid = process.pid;
  1774	
  1775	    // Mark that we're killing via stop_run, so the wait task doesn't emit duplicate event
  1776	    get_was_killed().store(true, Ordering::SeqCst);
  1777	
  1778	    // Send SIGTERM to the process group
  1779	    // Use the PID as PGID since we set it in pre_exec
  1780	    let pgid = pid as i32;
  1781	
  1782	    // Use nix to send signal to process group
  1783	    use nix::sys::signal::{killpg, Signal};
  1784	    use nix::unistd::Pid;
  1785	
  1786	    match killpg(Pid::from_raw(pgid), Signal::SIGTERM) {
  1787	        Ok(()) => {
  1788	            emit_iteration_progress(&app).await;
  1789	            // Emit exit event with killed flag
  1790	            let exit_event = RunExitEvent {
  1791	                exit_code: None,
  1792	                killed: true,
  1793	            };
  1794	            let _ = app.emit("run-exit", &exit_event);
  1795	            Ok(())
  1796	        }
  1797	        Err(e) => {
  1798	            // Restore process state on error
  1799	            state_guard.process = Some(process);
  1800	            get_was_killed().store(false, Ordering::SeqCst);
  1801	            Err(format!("Failed to stop process: {e}"))
  1802	        }
  1803	    }
  1804	}
