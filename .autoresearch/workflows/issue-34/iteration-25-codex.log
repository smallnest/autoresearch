const BROWSER_FALLBACK_CONTENT: Record<ConfigFileId, string> = {
  'program.md': '# program.md\n\n浏览器模式下无法读取本地项目配置。\n',
  'agents/claude.md': '# claude.md\n\n浏览器模式下仅展示本地占位内容。\n',
