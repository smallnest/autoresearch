+          projectPath,
+        });
+        set({ config });
+      } else {
+        set({ config: detectConfigBrowser(projectPath) });
+      }
+    } catch (e) {
+      set({ error: normalizeProjectError(e) });
+    }
+  },
+
   clearError: () => set({ error: null }),
