    normalizeError: () => 'unexpected',
    feedback: {
      setError: (value) => calls.push(['error', value]),
      setStatusMessage: (value) => calls.push(['status', value]),
    },
  });

  assert.equal(succeeded, false);
  assert.deepEqual(calls, [['confirm', { type: 'reset' }]]);
});

