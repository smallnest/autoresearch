+fn resolve_project_config_file_path(
+    base: &Path,
+    file_id: &str,
+) -> Result<std::path::PathBuf, String> {
+    let (relative_path, _) = supported_config_file(file_id)
+        .ok_or_else(|| format!("Unsupported config file: {file_id}"))?;
+
