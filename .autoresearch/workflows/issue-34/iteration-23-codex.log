   425	  fileId,
   426	  content,
   427	  editorMode,
   428	  writeConfigFile,
   429	  refreshConfig,
   430	  setIsSaving,
   431	  setCurrentFile,
   432	  setEditorContent,
   433	  normalizeError,
   434	  feedback,
   435	}: SubmitConfigEditorSaveOptions): Promise<boolean> {
   436	  if (!projectPath || !currentFile) {
   437	    return false;
   438	  }
   439	
   440	  if (!editorMode.canPersist) {
   441	    feedback.setError(editorMode.hint);
