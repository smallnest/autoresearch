   229	export function saveTargetPath(projectPath: string, relativePath: string): string {
   230	  const separator =
   231	    projectPath.includes('\\') || /^[A-Za-z]:/.test(projectPath) ? '\\' : '/';
   232	  const trimmedProjectPath = projectPath.replace(/[\\/]+$/, '');
   233	  const normalizedProjectPath = trimmedProjectPath.replace(/[\\/]+/g, separator);
   234	  const normalizedRelativePath = relativePath.replace(/[\\/]+/g, separator);
   235	  return `${normalizedProjectPath}${separator}.autoresearch${separator}${normalizedRelativePath}`;
   236	}
