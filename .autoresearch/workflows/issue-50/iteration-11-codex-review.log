   148	# Simulate the git push failure handling logic from run.sh
   149	# Returns 0 on success, 1 on failure
   150	simulate_push_with_failure_handling() {
   151	    local BRANCH_NAME="feature/test-issue"
   152	    local PUSH_OUTPUT
   153	    local PUSH_EXIT_CODE
   154	
   155	    # Capture push output (command substitution doesn't trigger set -e exit)
   156	    PUSH_OUTPUT=$(git push -u origin "$BRANCH_NAME" 2>&1) || PUSH_EXIT_CODE=$?
   157	
   158	    if [ "${PUSH_EXIT_CODE:-0}" -ne 0 ]; then
   159	        error "git push 失败 (exit code: ${PUSH_EXIT_CODE:-unknown})"
   160	        log_console ""
   161	        log_console "❌ git push 失败！"
   162	        log_console ""
   163	        log_console "错误输出:"
   164	        log_console "$PUSH_OUTPUT"
   165	        log_console ""
   166	
   167	        # Record error to log.md
   168	        cat >> "$WORK_DIR/log.md" << EOF
   169	
   170	---
   171	
   172	## ❌ Git Push 失败
   173	
   174	**时间**: $(date '+%Y-%m-%d %H:%M:%S')
   175	**分支**: $BRANCH_NAME
   176	**错误码**: ${PUSH_EXIT_CODE:-unknown}
   177	
   178	**错误输出**:
   179	\`\`\`
   180	$PUSH_OUTPUT
   181	\`\`\`
   182	
   183	EOF
   184	
   185	        # Check for uncommitted changes and retry
   186	        if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
   187	            log_console "检测到未提交的更改，尝试 stash 后重试..."
   188	            STASH_MSG="autoresearch-push-retry-$(date +%s)"
   189	            git stash push -m "$STASH_MSG" 2>/dev/null
   190	
   191	            log_console "重试 git push..."
   192	            local RETRY_OUTPUT
   193	            local RETRY_EXIT_CODE
   194	            RETRY_OUTPUT=$(git push -u origin "$BRANCH_NAME" 2>&1) || RETRY_EXIT_CODE=$?
   195	
   196	            if [ "${RETRY_EXIT_CODE:-0}" -eq 0 ]; then
   197	                log_console "✅ Stash 后重试成功！"
   198	                git stash pop 2>/dev/null || true
   199	                return 0
   200	            else
   201	                # Retry still failed, restore stash and output suggestions
   202	                git stash pop 2>/dev/null || true
   203	
   204	                log_console "❌ 重试仍然失败"
   205	                log_console ""
   206	
   207	                # Append retry failure info to log.md
   208	                cat >> "$WORK_DIR/log.md" << EOF
   209	
   210	**重试结果**: 失败 (exit code: ${RETRY_EXIT_CODE:-unknown})
   211	
   212	**重试输出**:
   213	\`\`\`
   214	$RETRY_OUTPUT
   215	\`\`\`
   216	
   217	EOF
   218	            fi
   219	        fi
   220	
   221	        # Output recovery suggestions
   222	        log_console ""
   223	        log_console "═══════════════════════════════════════════════════════════"
   224	        log_console "📋 恢复建议："
   225	        log_console "═══════════════════════════════════════════════════════════"
   226	        log_console ""
   227	        log_console "1. 检查网络连接和 GitHub 访问"
   228	        log_console "2. 检查认证状态: gh auth status"
   229	        log_console "3. 手动推送: git push -u origin $BRANCH_NAME"
   230	        log_console "═══════════════════════════════════════════════════════════"
   231	
   232	        return 1
   233	    fi
   234	
   235	    return 0
   236	}
