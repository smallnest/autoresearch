# Extract just the function we need
extract_function() {
    local func_name="$1"
    local start_line=$(grep -n "^${func_name}() {" tests/test_context_overflow.sh | head -1 | cut -d: -f1)
    if [ -z "$start_line" ]; then
        return 1
    fi
    
    local end_line=""
    local line_num=$((start_line + 1))
    local brace_count=1
    
    while IFS= read -r line; do
        if [ "$line_num" -le "$start_line" ]; then
            line_num=$((line_num + 1))
            continue
        fi
        
        # Count braces
        opens=$(echo "$line" | grep -o '{' | wc -l)
        closes=$(echo "$line" | grep -o '}' | wc -l)
        brace_count=$((brace_count + opens - closes))
        
        if [ "$brace_count" -eq 0 ]; then
            end_line=$line_num
            break
        fi
        line_num=$((line_num + 1))
    done < tests/test_context_overflow.sh
    
    sed -n "${start_line},${end_line}p" tests/test_context_overflow.sh
}

# Extract and source the function
func_code=$(extract_function "generate_iteration_summary")
eval "$func_code"

