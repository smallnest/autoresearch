   190	
   191	/// Parses tasks.json and returns a list of SubtaskInfo.
   192	fn parse_tasks_json(workflow_dir: &Path) -> Vec<SubtaskInfo> {
   193	    let tasks_path = workflow_dir.join("tasks.json");
   194	    let bytes = match fs::read(&tasks_path) {
   195	        Ok(b) => b,
   196	        Err(_) => return Vec::new(),
   197	    };
   198	    let tasks_file: TasksFile = match serde_json::from_slice(&bytes) {
   199	        Ok(t) => t,
   200	        Err(_) => return Vec::new(),
   201	    };
   202	    tasks_file
   203	        .subtasks
   204	        .into_iter()
   205	        .map(|s| SubtaskInfo {
   206	            id: s.id,
   207	            title: s.title,
   208	            passes: s.passes,
   209	        })
   210	        .collect()
   211	}
   212	
   213	/// Infers the current phase by examining files in the workflow directory.
   214	///
   215	/// Logic:
   216	/// 1. Find the highest iteration number N from `iteration-N-*.log` files.
   217	/// 2. If no iteration logs exist but `planning.log` exists → Planning.
   218	/// 3. If no iteration logs and no planning.log → Idle.
   219	/// 4. If `hard-gate-N.log` exists → BuildLintTest.
   220	/// 5. If `iteration-N-*-review.log` exists → Review.
   221	/// 6. Otherwise → Implementation.
   222	fn infer_phase(workflow_dir: &Path) -> Phase {
   223	    let entries = match fs::read_dir(workflow_dir) {
   224	        Ok(e) => e,
   225	        Err(_) => return Phase::Idle,
   226	    };
   227	
   228	    let mut max_iteration: i32 = 0;
   229	    let mut has_planning = false;
   230	    let mut review_iterations = std::collections::HashSet::new();
   231	    let mut hard_gate_iterations = std::collections::HashSet::new();
   232	
   233	    for entry in entries.flatten() {
   234	        let name = entry.file_name().to_string_lossy().to_string();
   235	        if name == "planning.log" {
   236	            has_planning = true;
   237	            continue;
   238	        }
   239	        if let Some(n) = iteration_number(&name) {
   240	            if n > max_iteration {
   241	                max_iteration = n;
   242	            }
   243	            if name.contains("-review.log") {
   244	                review_iterations.insert(n);
   245	            }
   246	        }
   247	        if name.starts_with("hard-gate-") && name.ends_with(".log") {
   248	            if let Some(n) = name
   249	                .strip_prefix("hard-gate-")
   250	                .and_then(|s| s.strip_suffix(".log"))
   251	                .and_then(|s| s.parse::<i32>().ok())
   252	            {
   253	                hard_gate_iterations.insert(n);
   254	            }
   255	        }
   256	    }
   257	
   258	    if max_iteration == 0 {
   259	        return if has_planning { Phase::Planning } else { Phase::Idle };
   260	    }
   261	
   262	    if hard_gate_iterations.contains(&max_iteration) {
   263	        return Phase::BuildLintTest;
   264	    }
   265	    if review_iterations.contains(&max_iteration) {
   266	        return Phase::Review;
   267	    }
   268	    Phase::Implementation
   269	}
   270	
   271	/// Extracts the current iteration and total iterations from terminal.log.
   272	///
   273	/// Looks for the pattern `🔄 迭代 N/M` in terminal.log lines (last match wins).
   274	/// Falls back to parsing log.md if terminal.log is missing or has no match.
   275	fn extract_iteration_numbers(workflow_dir: &Path) -> (i32, i32) {
   276	    // Try terminal.log first (most reliable for iteration markers)
   277	    let terminal_path = workflow_dir.join("terminal.log");
   278	    if let Ok(content) = fs::read_to_string(&terminal_path) {
   279	        if let Some((current, total)) = parse_iteration_from_terminal(&content) {
   280	            return (current, total);
   281	        }
   282	    }
   283	
   284	    let log_md_path = workflow_dir.join("log.md");
   285	    if let Ok(content) = fs::read_to_string(&log_md_path) {
   286	        if let Some((current, total)) = parse_iteration_from_log_md(&content) {
   287	            return (current, total);
   288	        }
   289	    }
   290	
   291	    (0, 0)
   292	}
   293	
   294	/// Parses "迭代 N/M" from terminal.log content. Returns the last match.
   295	fn parse_iteration_from_terminal(content: &str) -> Option<(i32, i32)> {
   296	    let mut result = None;
   297	    for line in content.lines() {
   298	        // Look for "迭代 N/M" pattern
   299	        if let Some(pos) = line.find("迭代 ") {
   300	            let rest = &line[pos + "迭代 ".len()..];
   301	            if let Some(slash_pos) = rest.find('/') {
   302	                let current_str = rest[..slash_pos].trim();
   303	                let total_rest = &rest[slash_pos + 1..];
   304	                // Total might be followed by other characters or end of line
   305	                let total_str: String = total_rest.chars().take_while(|c| c.is_ascii_digit()).collect();
   306	                if let (Ok(current), Ok(total)) = (current_str.parse::<i32>(), total_str.parse::<i32>()) {
   307	                    result = Some((current, total));
   308	                }
   309	            }
   310	        }
   311	    }
   312	    result
   313	}
   314	
   315	/// Parses iteration progress from log.md content.
   316	///
   317	/// Current iteration is inferred from the last `### 迭代 N - ...` heading.
   318	/// Total iterations is inferred from the last `总迭代次数: N` entry.
   319	/// If only one value is present, the other defaults to 0.
   320	fn parse_iteration_from_log_md(content: &str) -> Option<(i32, i32)> {
   321	    let mut current_iteration = 0;
   322	    let mut total_iterations = 0;
   323	
   324	    for line in content.lines() {
   325	        if let Some(rest) = line.strip_prefix("### 迭代 ") {
   326	            let iteration_str: String = rest
   327	                .chars()
   328	                .take_while(|c| c.is_ascii_digit())
   329	                .collect();
   330	            if let Ok(iteration) = iteration_str.parse::<i32>() {
   331	                current_iteration = iteration;
   332	            }
   333	        }
   334	
   335	        if let Some(pos) = line.find("总迭代次数:") {
   336	            let total_str: String = line[pos + "总迭代次数:".len()..]
   337	                .chars()
   338	                .skip_while(|c| c.is_whitespace())
   339	                .take_while(|c| c.is_ascii_digit())
   340	                .collect();
   341	            if let Ok(total) = total_str.parse::<i32>() {
   342	                total_iterations = total;
   343	            }
   344	        }
   345	    }
   346	
   347	    if current_iteration == 0 && total_iterations == 0 {
   348	        None
   349	    } else {
   350	        Some((current_iteration, total_iterations))
   351	    }
   352	}
   353	
   354	/// Builds a complete IterationProgress for a given workflow directory.
   355	fn build_iteration_progress(workflow_dir: &Path) -> IterationProgress {
   356	    let subtasks = parse_tasks_json(workflow_dir);
   357	    let passed_count = subtasks.iter().filter(|s| s.passes).count();
   358	    let total_count = subtasks.len();
   359	    let phase = infer_phase(workflow_dir);
   360	    let (current_iteration, total_iterations) = extract_iteration_numbers(workflow_dir);
   361	
   362	    IterationProgress {
   363	        current_iteration,
   364	        total_iterations,
   365	        phase,
   366	        subtasks,
   367	        passed_count,
   368	        total_count,
   369	    }
   370	}
   371	
   372	/// Returns the iteration progress for a given issue's workflow.
   373	fn get_iteration_progress_sync(
   374	    project_path: &str,
   375	    issue_number: i64,
   376	) -> Result<IterationProgress, String> {
   377	    let base = Path::new(project_path);
   378	    if !base.is_dir() {
   379	        return Err(format!("Path is not a directory: {project_path}"));
   380	    }
   381	
   382	    let workflow_dir = base
   383	        .join(".autoresearch")
   384	        .join("workflows")
   385	        .join(format!("issue-{issue_number}"));
   386	
   387	    if !workflow_dir.is_dir() {
   388	        // Return idle progress with empty data
   389	        return Ok(IterationProgress {
   390	            current_iteration: 0,
   391	            total_iterations: 0,
   392	            phase: Phase::Idle,
   393	            subtasks: Vec::new(),
   394	            passed_count: 0,
   395	            total_count: 0,
   396	        });
   397	    }
   398	
   399	    Ok(build_iteration_progress(&workflow_dir))
   400	}
   401	
   402	/// Returns the current iteration progress for a specific issue.
   403	#[tauri::command]
   404	async fn get_iteration_progress(
   405	    project_path: String,
   406	    issue_number: i64,
   407	) -> Result<IterationProgress, String> {
   408	    tokio::task::spawn_blocking(move || get_iteration_progress_sync(&project_path, issue_number))
   409	        .await
   410	        .map_err(|e| format!("Task join error: {e}"))?
   411	}
