   964	/// Stops the currently running run.sh process by sending SIGTERM to its process group.
   965	#[cfg(unix)]
   966	#[tauri::command]
   967	async fn stop_run(app: tauri::AppHandle) -> Result<(), String> {
   968	    let state = get_run_state();
   969	    let mut state_guard = state.lock().await;
   970	
   971	    let process = state_guard.process.take().ok_or("No run is in progress")?;
   972	    let pid = process.pid;
   973	
   974	    // Mark that we're killing via stop_run, so the wait task doesn't emit duplicate event
   975	    get_was_killed().store(true, Ordering::SeqCst);
   976	
   977	    // Send SIGTERM to the process group
   978	    // Use the PID as PGID since we set it in pre_exec
   979	    let pgid = pid as i32;
   980	
   981	    // Use nix to send signal to process group
   982	    use nix::sys::signal::{killpg, Signal};
   983	    use nix::unistd::Pid;
   984	
   985	    match killpg(Pid::from_raw(pgid), Signal::SIGTERM) {
   986	        Ok(()) => {
   987	            // Emit exit event with killed flag
   988	            let exit_event = RunExitEvent {
   989	                exit_code: None,
   990	                killed: true,
   991	            };
   992	            let _ = app.emit("run-exit", &exit_event);
   993	            Ok(())
   994	        }
   995	        Err(e) => {
   996	            // Restore process state on error
   997	            state_guard.process = Some(process);
   998	            get_was_killed().store(false, Ordering::SeqCst);
   999	            Err(format!("Failed to stop process: {e}"))
  1000	        }
  1001	    }
  1002	}
