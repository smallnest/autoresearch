import test from 'node:test';
import assert from 'node:assert/strict';
import { createIterationStore } from '../src/stores/iterationStore.ts';

function createInvokeMock(handlers) {
  return async (cmd, args) => {
    const handler = handlers[cmd];
    if (!handler) {
      throw new Error(`Unhandled command: ${cmd}`);
    }
    return handler(args);
  };
}

const SAMPLE_PROGRESS = {
  current_iteration: 3,
  total_iterations: 16,
  phase: 'Review',
  subtasks: [
    { id: 'T-001', title: 'Backend data model', passes: true },
    { id: 'T-002', title: 'File watcher', passes: true },
    { id: 'T-003', title: 'Frontend UI', passes: false },
  ],
  passed_count: 2,
  total_count: 3,
};

test('fetchProgress stores iteration data from backend', async () => {
  const store = createIterationStore({
    isTauri: true,
    invoke: createInvokeMock({
      get_iteration_progress: () => SAMPLE_PROGRESS,
    }),
  });

  await store.getState().fetchProgress('/tmp/project', 31);

  const state = store.getState();
  assert.equal(state.progress.current_iteration, 3);
  assert.equal(state.progress.total_iterations, 16);
  assert.equal(state.progress.phase, 'Review');
  assert.equal(state.progress.subtasks.length, 3);
  assert.equal(state.progress.passed_count, 2);
  assert.equal(state.progress.total_count, 3);
  assert.equal(state.isLoading, false);
  assert.equal(state.error, null);
});

test('fetchProgress sets error on backend failure', async () => {
  const store = createIterationStore({
    isTauri: true,
    invoke: createInvokeMock({
      get_iteration_progress: () => {
        throw new Error('Workflow dir not found');
      },
    }),
  });

  await store.getState().fetchProgress('/tmp/project', 99);

  const state = store.getState();
  assert.equal(state.error, 'Workflow dir not found');
  assert.equal(state.isLoading, false);
  // progress should remain at idle defaults
  assert.equal(state.progress.current_iteration, 0);
  assert.equal(state.progress.phase, 'Idle');
});

test('fetchProgress is a no-op when isTauri is false', async () => {
  const invoked = [];
  const store = createIterationStore({
    isTauri: false,
    invoke: async (cmd) => {
      invoked.push(cmd);
      return {};
    },
  });

  await store.getState().fetchProgress('/tmp/project', 31);

  assert.equal(invoked.length, 0);
  assert.equal(store.getState().progress.phase, 'Idle');
});

test('reset restores idle state after data was loaded', async () => {
  const store = createIterationStore({
    isTauri: true,
    invoke: createInvokeMock({
      get_iteration_progress: () => SAMPLE_PROGRESS,
    }),
  });

  await store.getState().fetchProgress('/tmp/project', 31);
  assert.equal(store.getState().progress.current_iteration, 3);

  store.getState().reset();

  const state = store.getState();
  assert.equal(state.progress.current_iteration, 0);
  assert.equal(state.progress.phase, 'Idle');
  assert.equal(state.progress.subtasks.length, 0);
  assert.equal(state.isLoading, false);
  assert.equal(state.error, null);
});

test('fetchProgress passes correct args to invoke', async () => {
  let receivedArgs = null;
  const store = createIterationStore({
    isTauri: true,
    invoke: async (cmd, args) => {
      if (cmd === 'get_iteration_progress') {
        receivedArgs = args;
        return SAMPLE_PROGRESS;
      }
      throw new Error(`Unhandled: ${cmd}`);
    },
  });

  await store.getState().fetchProgress('/my/project', 42);

  assert.deepEqual(receivedArgs, {
    projectPath: '/my/project',
    issueNumber: 42,
  });
});

test('fetchProgress handles non-Error thrown values', async () => {
  const store = createIterationStore({
    isTauri: true,
    invoke: async () => {
      throw 'raw string error';
    },
  });

  await store.getState().fetchProgress('/tmp/project', 1);

  assert.equal(store.getState().error, 'raw string error');
});

