   187	// ========================================
   188	// Iteration progress helpers
   189	// ========================================
   190	
   191	/// Parses tasks.json and returns a list of SubtaskInfo.
   192	fn parse_tasks_json(workflow_dir: &Path) -> Vec<SubtaskInfo> {
   193	    let tasks_path = workflow_dir.join("tasks.json");
   194	    let bytes = match fs::read(&tasks_path) {
   195	        Ok(b) => b,
   196	        Err(_) => return Vec::new(),
   197	    };
   198	    let tasks_file: TasksFile = match serde_json::from_slice(&bytes) {
   199	        Ok(t) => t,
   200	        Err(_) => return Vec::new(),
   201	    };
   202	    tasks_file
   203	        .subtasks
   204	        .into_iter()
   205	        .map(|s| SubtaskInfo {
   206	            id: s.id,
   207	            title: s.title,
   208	            passes: s.passes,
   209	        })
   210	        .collect()
   211	}
   212	
   213	/// Infers the current phase by examining files in the workflow directory.
   214	///
   215	/// Logic:
   216	/// 1. Find the highest iteration number N from `iteration-N-*.log` files.
   217	/// 2. If no iteration logs exist but `planning.log` exists → Planning.
   218	/// 3. If no iteration logs and no planning.log → Idle.
   219	/// 4. If `hard-gate-N.log` exists → BuildLintTest.
   220	/// 5. If `iteration-N-*-review.log` exists → Review.
   221	/// 6. Otherwise → Implementation.
   222	fn infer_phase(workflow_dir: &Path) -> Phase {
   223	    let entries = match fs::read_dir(workflow_dir) {
   224	        Ok(e) => e,
   225	        Err(_) => return Phase::Idle,
   226	    };
   227	
   228	    let mut max_iteration: i32 = 0;
   229	    let mut has_planning = false;
   230	    let mut review_iterations = std::collections::HashSet::new();
   231	    let mut hard_gate_iterations = std::collections::HashSet::new();
   232	
   233	    for entry in entries.flatten() {
   234	        let name = entry.file_name().to_string_lossy().to_string();
   235	        if name == "planning.log" {
   236	            has_planning = true;
   237	            continue;
   238	        }
   239	        if let Some(n) = iteration_number(&name) {
   240	            if n > max_iteration {
   241	                max_iteration = n;
   242	            }
   243	            if name.contains("-review.log") {
   244	                review_iterations.insert(n);
   245	            }
   246	        }
   247	        if name.starts_with("hard-gate-") && name.ends_with(".log") {
   248	            if let Some(n) = name
   249	                .strip_prefix("hard-gate-")
   250	                .and_then(|s| s.strip_suffix(".log"))
   251	                .and_then(|s| s.parse::<i32>().ok())
   252	            {
   253	                hard_gate_iterations.insert(n);
   254	            }
   255	        }
   256	    }
   257	
   258	    if max_iteration == 0 {
   259	        return if has_planning { Phase::Planning } else { Phase::Idle };
   260	    }
   261	
   262	    if hard_gate_iterations.contains(&max_iteration) {
   263	        return Phase::BuildLintTest;
   264	    }
   265	    if review_iterations.contains(&max_iteration) {
   266	        return Phase::Review;
   267	    }
   268	    Phase::Implementation
   269	}
   270	
   271	/// Extracts the current iteration and total iterations from terminal.log.
   272	///
   273	/// Looks for the pattern `🔄 迭代 N/M` in terminal.log lines (last match wins).
   274	/// Falls back to (0, 0) if the file is missing or no match found.
   275	fn extract_iteration_numbers(workflow_dir: &Path) -> (i32, i32) {
   276	    // Try terminal.log first (most reliable for iteration markers)
   277	    let terminal_path = workflow_dir.join("terminal.log");
   278	    if let Ok(content) = fs::read_to_string(&terminal_path) {
   279	        if let Some((current, total)) = parse_iteration_from_terminal(&content) {
   280	            return (current, total);
   281	        }
   282	    }
   283	    (0, 0)
   284	}
   285	
   286	/// Parses "迭代 N/M" from terminal.log content. Returns the last match.
   287	fn parse_iteration_from_terminal(content: &str) -> Option<(i32, i32)> {
   288	    let mut result = None;
   289	    for line in content.lines() {
   290	        // Look for "迭代 N/M" pattern
   291	        if let Some(pos) = line.find("迭代 ") {
   292	            let rest = &line[pos + "迭代 ".len()..];
   293	            if let Some(slash_pos) = rest.find('/') {
   294	                let current_str = rest[..slash_pos].trim();
   295	                let total_rest = &rest[slash_pos + 1..];
   296	                // Total might be followed by other characters or end of line
   297	                let total_str: String = total_rest.chars().take_while(|c| c.is_ascii_digit()).collect();
   298	                if let (Ok(current), Ok(total)) = (current_str.parse::<i32>(), total_str.parse::<i32>()) {
   299	                    result = Some((current, total));
   300	                }
   301	            }
   302	        }
   303	    }
   304	    result
   305	}
   306	
   307	/// Builds a complete IterationProgress for a given workflow directory.
   308	fn build_iteration_progress(workflow_dir: &Path) -> IterationProgress {
   309	    let subtasks = parse_tasks_json(workflow_dir);
   310	    let passed_count = subtasks.iter().filter(|s| s.passes).count();
   311	    let total_count = subtasks.len();
   312	    let phase = infer_phase(workflow_dir);
   313	    let (current_iteration, total_iterations) = extract_iteration_numbers(workflow_dir);
   314	
   315	    IterationProgress {
   316	        current_iteration,
   317	        total_iterations,
   318	        phase,
   319	        subtasks,
   320	        passed_count,
   321	        total_count,
   322	    }
   323	}
   324	
   325	/// Returns the iteration progress for a given issue's workflow.
   326	fn get_iteration_progress_sync(
   327	    project_path: &str,
   328	    issue_number: i64,
   329	) -> Result<IterationProgress, String> {
   330	    let base = Path::new(project_path);
   331	    if !base.is_dir() {
   332	        return Err(format!("Path is not a directory: {project_path}"));
   333	    }
   334	
   335	    let workflow_dir = base
   336	        .join(".autoresearch")
   337	        .join("workflows")
   338	        .join(format!("issue-{issue_number}"));
   339	
   340	    if !workflow_dir.is_dir() {
   341	        // Return idle progress with empty data
   342	        return Ok(IterationProgress {
   343	            current_iteration: 0,
   344	            total_iterations: 0,
   345	            phase: Phase::Idle,
   346	            subtasks: Vec::new(),
   347	            passed_count: 0,
   348	            total_count: 0,
   349	        });
   350	    }
   351	
   352	    Ok(build_iteration_progress(&workflow_dir))
   353	}
   354	
   355	/// Returns the current iteration progress for a specific issue.
   356	#[tauri::command]
   357	async fn get_iteration_progress(
   358	    project_path: String,
   359	    issue_number: i64,
   360	) -> Result<IterationProgress, String> {
   361	    tokio::task::spawn_blocking(move || get_iteration_progress_sync(&project_path, issue_number))
   362	        .await
   363	        .map_err(|e| format!("Task join error: {e}"))?
   364	}
