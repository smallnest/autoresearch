+            false
+        } else {
+            process.last_progress = Some(progress.clone());
+            true
+        }
+    };
+
+    if should_emit {
+        let _ = app.emit(
+            "iteration-progress",
+            &IterationProgressEvent {
+                issue_number,
+                progress,
+            },
+        );
+    }
