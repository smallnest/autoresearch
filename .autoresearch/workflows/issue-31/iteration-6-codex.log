import { create } from 'zustand';

const isTauri =
  typeof window !== 'undefined' && '__TAURI_INTERNALS__' in window;

// ── Types matching Rust backend (snake_case serialization) ──

export type Phase = 'Planning' | 'Implementation' | 'Review' | 'BuildLintTest' | 'Idle';

export interface SubtaskInfo {
  id: string;
  title: string;
  passes: boolean;
}

export interface IterationProgress {
  current_iteration: number;
  total_iterations: number;
  phase: Phase;
  subtasks: SubtaskInfo[];
  passed_count: number;
  total_count: number;
}

// ── Dependency injection (matches runStore pattern) ──

interface IterationStoreDeps {
  isTauri: boolean;
  invoke: <T>(cmd: string, args?: Record<string, unknown>) => Promise<T>;
}

async function tauriInvoke<T>(
  cmd: string,
  args?: Record<string, unknown>,
): Promise<T> {
  const { invoke } = await import('@tauri-apps/api/core');
  return invoke<T>(cmd, args);
}

function createIterationStoreDeps(
  overrides: Partial<IterationStoreDeps> = {},
): IterationStoreDeps {
  return {
    isTauri,
    invoke: tauriInvoke,
    ...overrides,
  };
}

// ── Default idle state ──

const IDLE_PROGRESS: IterationProgress = {
  current_iteration: 0,
  total_iterations: 0,
  phase: 'Idle',
  subtasks: [],
  passed_count: 0,
  total_count: 0,
};

export const POLL_INTERVAL_MS = 2000;

// ── Store ──

export interface IterationState {
  progress: IterationProgress;
  isLoading: boolean;
  error: string | null;
  /** Fetch progress once from the backend. */
  fetchProgress: (projectPath: string, issueNumber: number) => Promise<void>;
  /** Reset to idle state. */
  reset: () => void;
}

export function createIterationStore(overrides: Partial<IterationStoreDeps> = {}) {
  const deps = createIterationStoreDeps(overrides);

  return create<IterationState>((set) => ({
    progress: IDLE_PROGRESS,
    isLoading: false,
    error: null,

    fetchProgress: async (projectPath: string, issueNumber: number) => {
      if (!deps.isTauri) {
        return;
      }

      set({ isLoading: true });

      try {
        const data = await deps.invoke<IterationProgress>(
          'get_iteration_progress',
          { projectPath, issueNumber },
        );
        set({ progress: data, isLoading: false, error: null });
      } catch (err) {
        const message = err instanceof Error ? err.message : String(err);
        set({ isLoading: false, error: message });
      }
    },

    reset: () => {
      set({ progress: IDLE_PROGRESS, isLoading: false, error: null });
    },
  }));
}

export const useIterationStore = createIterationStore();

