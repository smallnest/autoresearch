+  assert.equal(idleMessage(true, false), '正在加载迭代进度…');
+  assert.equal(idleMessage(false, true), '正在加载迭代进度…');
+  assert.equal(idleMessage(false, false), '暂无迭代进度，当前为 idle 状态。');
+});
