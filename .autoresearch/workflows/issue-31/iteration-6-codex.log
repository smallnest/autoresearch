index 0000000000000000000000000000000000000000..725a6a7c30e2aebbf8f9a39441ae6ed1d343151d
--- /dev/null
+++ b/desktop_app/tests/iterationProgressPanel.test.mjs
@@ -0,0 +1,69 @@
+import test from 'node:test';
+import assert from 'node:assert/strict';
+import React from 'react';
+import { renderToStaticMarkup } from 'react-dom/server';
+import IterationProgressPanel from '../src/components/IterationProgressPanel.tsx';
+import { IDLE_PROGRESS, useIterationStore } from '../src/stores/iterationStore.ts';
+
+function renderPanel(props = {}) {
+  return renderToStaticMarkup(
+    React.createElement(IterationProgressPanel, {
+      issueNumber: 31,
+      projectPath: '/tmp/project',
+      isRunning: false,
+      ...props,
+    }),
+  );
+}
+
+test.afterEach(() => {
+  useIterationStore.setState({
+    currentIssueNumber: null,
+    requestKey: 0,
+    subscriptionsReady: false,
+    progress: IDLE_PROGRESS,
+    isLoading: false,
+    error: null,
+  });
+});
+
+test('IterationProgressPanel renders idle state', () => {
+  useIterationStore.setState({
+    progress: IDLE_PROGRESS,
+    isLoading: false,
+    error: null,
+  });
+
+  const html = renderPanel();
+  assert.match(html, /暂无迭代进度，当前为 idle 状态/);
+});
+
+test('IterationProgressPanel renders iteration summary, phases, and subtask statuses', () => {
+  useIterationStore.setState({
+    progress: {
+      current_iteration: 3,
+      total_iterations: 16,
+      phase: 'Review',
+      subtasks: [
+        { id: 'T-001', title: 'Backend data model', status: 'passing' },
+        { id: 'T-002', title: 'File watcher', status: 'pending' },
+        { id: 'T-003', title: 'Frontend UI', status: 'failing' },
+      ],
+      passed_count: 1,
+      total_count: 3,
+    },
+    isLoading: false,
+    error: null,
+  });
+
+  const html = renderPanel();
+  assert.match(html, /3 \/ 16/);
+  assert.match(html, /Planning/);
+  assert.match(html, /Implementation/);
+  assert.match(html, /Review/);
+  assert.match(html, /Build·Lint·Test/);
+  assert.match(html, /1\/3 subtasks passed/);
+  assert.match(html, /passing/);
+  assert.match(html, /pending/);
+  assert.match(html, /failing/);
+});
