import { useEffect, useRef, type JSX } from 'react';
import {
  type Phase,
  type SubtaskInfo,
  POLL_INTERVAL_MS,
  useIterationStore,
} from '../stores/iterationStore';

interface IterationProgressPanelProps {
  issueNumber: number;
  projectPath: string | null;
  isRunning: boolean;
}

// ── Phase pipeline ──

const PHASE_STEPS: { key: Phase; label: string }[] = [
  { key: 'Planning', label: 'Planning' },
  { key: 'Implementation', label: 'Implementation' },
  { key: 'Review', label: 'Review' },
  { key: 'BuildLintTest', label: 'Build·Lint·Test' },
];

function phaseIndex(phase: Phase): number {
  const idx = PHASE_STEPS.findIndex((s) => s.key === phase);
  return idx === -1 ? -1 : idx;
}

function PhaseSteps({ currentPhase }: { currentPhase: Phase }): JSX.Element {
  const activeIdx = phaseIndex(currentPhase);

  return (
    <div className="flex items-center gap-1">
      {PHASE_STEPS.map((step, idx) => {
        const isActive = idx === activeIdx;
        const isPast = activeIdx > idx;

        let pillClass =
          'rounded-full px-2.5 py-1 text-xs font-medium transition-colors';
        if (isActive) {
          pillClass += ' bg-blue-600 text-white';
        } else if (isPast) {
          pillClass += ' bg-blue-100 text-blue-700';
        } else {
          pillClass += ' bg-gray-100 text-gray-400';
        }

        return (
          <span key={step.key}>
            {idx > 0 && (
              <span
                className={`mx-1 inline-block text-xs ${
                  isPast || isActive ? 'text-blue-400' : 'text-gray-300'
                }`}
              >
                →
              </span>
            )}
            <span className={pillClass}>{step.label}</span>
          </span>
        );
      })}
    </div>
  );
}

// ── Subtask status badge ──

function subtaskStatusLabel(passes: boolean, isIdle: boolean): string {
  if (isIdle) return 'pending';
  return passes ? 'passing' : 'failing';
}

function subtaskBadgeClass(passes: boolean, isIdle: boolean): string {
  if (isIdle) {
    return 'border-gray-200 bg-gray-100 text-gray-500';
  }
  return passes
    ? 'border-green-200 bg-green-50 text-green-700'
    : 'border-red-200 bg-red-50 text-red-700';
}

function SubtaskList({
  subtasks,
  isIdle,
}: {
  subtasks: SubtaskInfo[];
  isIdle: boolean;
}): JSX.Element {
  if (subtasks.length === 0) {
    return (
      <p className="text-xs text-gray-400">暂无 subtask 信息。</p>
    );
  }

  return (
    <ul className="space-y-1.5">
      {subtasks.map((st) => {
        const status = subtaskStatusLabel(st.passes, isIdle);
        const badge = subtaskBadgeClass(st.passes, isIdle);
        return (
          <li
            key={st.id}
            className="flex items-center justify-between rounded-lg border border-gray-100 bg-white px-3 py-2 text-sm"
          >
            <span className="min-w-0 truncate text-gray-700">
              <span className="mr-1.5 font-mono text-xs text-gray-400">{st.id}</span>
              {st.title}
            </span>
            <span
              className={`ml-2 shrink-0 rounded-full border px-2 py-0.5 text-xs font-medium ${badge}`}
            >
              {status}
            </span>
          </li>
        );
      })}
    </ul>
  );
}

// ── Progress bar ──

function ProgressBar({
  passed,
  total,
}: {
  passed: number;
  total: number;
}): JSX.Element {
  const pct = total > 0 ? Math.round((passed / total) * 100) : 0;

  return (
    <div>
      <div className="mb-1 flex items-center justify-between text-xs">
        <span className="font-medium text-gray-600">
          {passed}/{total} subtasks passed
        </span>
        <span className="text-gray-400">{pct}%</span>
      </div>
      <div className="h-2 overflow-hidden rounded-full bg-gray-200">
        <div
          className="h-full rounded-full bg-blue-500 transition-all"
          style={{ width: `${pct}%` }}
        />
      </div>
    </div>
  );
}

// ── Main component ──

export default function IterationProgressPanel({
  issueNumber,
  projectPath,
  isRunning,
}: IterationProgressPanelProps): JSX.Element {
  const { progress, error, fetchProgress, reset } = useIterationStore();
  const timerRef = useRef<number | null>(null);

  // Polling: fetch immediately + every POLL_INTERVAL_MS while running
  useEffect(() => {
    if (!projectPath) {
      reset();
      return;
    }

    void fetchProgress(projectPath, issueNumber);

    if (timerRef.current !== null) {
      window.clearInterval(timerRef.current);
    }

    if (isRunning) {
      timerRef.current = window.setInterval(() => {
        void fetchProgress(projectPath, issueNumber);
      }, POLL_INTERVAL_MS);
    }

    return () => {
      if (timerRef.current !== null) {
        window.clearInterval(timerRef.current);
        timerRef.current = null;
      }
    };
  }, [projectPath, issueNumber, isRunning, fetchProgress, reset]);

  const isIdle = progress.phase === 'Idle';

  // Idle / no data state
  if (isIdle && progress.current_iteration === 0) {
    return (
      <div className="mt-4 rounded-xl border border-dashed border-gray-300 bg-gray-50 px-4 py-5 text-center text-sm text-gray-400">
        暂无迭代进度 — 启动运行后将自动展示。
        {error && (
          <p className="mt-2 text-xs text-red-400">{error}</p>
        )}
      </div>
    );
  }

  return (
    <div className="mt-4 space-y-4 rounded-xl border border-gray-200 bg-white p-4">
      {/* Iteration number */}
      <div className="flex items-center justify-between">
        <h4 className="text-sm font-semibold text-gray-700">迭代进度</h4>
        <span className="rounded-full bg-gray-100 px-3 py-1 text-sm font-mono font-medium text-gray-700">
          {progress.current_iteration} / {progress.total_iterations}
        </span>
      </div>

      {/* Phase steps */}
      <PhaseSteps currentPhase={progress.phase} />

      {/* Subtask progress bar */}
      <ProgressBar passed={progress.passed_count} total={progress.total_count} />

      {/* Subtask list */}
      <SubtaskList subtasks={progress.subtasks} isIdle={isIdle} />

      {error && (
        <p className="text-xs text-red-500">{error}</p>
      )}
    </div>
  );
}

