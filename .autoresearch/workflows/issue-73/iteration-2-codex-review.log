   840	        return Err(format!("Path is not a directory: {project_path}"));
   841	    }
   842	
   843	    let ar = base.join(".autoresearch");
   844	    Ok(ProjectConfig {
   845	        has_autoresearch_dir: ar.is_dir(),
   846	        has_program_md: ar.join("program.md").is_file() || base.join("program.md").is_file(),
   847	        has_agents_dir: ar.join("agents").is_dir() || base.join("agents").is_dir(),
   848	    })
   849	}
