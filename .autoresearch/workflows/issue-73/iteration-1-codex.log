    fn create_temp_project_dir(test_name: &str) -> PathBuf {
        let root = std::env::temp_dir().join(format!(
            "autoresearch-log-viewer-{test_name}-{}",
            std::process::id()
        ));
        let _ = fs::remove_dir_all(&root);
