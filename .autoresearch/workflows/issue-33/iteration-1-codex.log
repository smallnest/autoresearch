   726	
   727	        if let Some(pos) = line.find("总迭代次数:") {
   728	            let total_str: String = line[pos + "总迭代次数:".len()..]
   729	                .chars()
   730	                .skip_while(|c| c.is_whitespace())
   731	                .take_while(|c| c.is_ascii_digit())
   732	                .collect();
   733	            if let Ok(total) = total_str.parse::<i32>() {
   734	                total_iterations = total;
   735	            }
   736	        }
   737	    }
   738	
   739	    if current_iteration == 0 && total_iterations == 0 {
   740	        None
   741	    } else {
   742	        Some((current_iteration, total_iterations))
   743	    }
   744	}
   745	
   746	/// Builds a complete IterationProgress for a given workflow directory.
   747	fn build_iteration_progress(workflow_dir: &Path) -> IterationProgress {
   748	    let subtasks = build_subtask_infos(workflow_dir);
   749	    let passed_count = subtasks
   750	        .iter()
   751	        .filter(|s| s.status == SubtaskStatus::Passing)
   752	        .count();
   753	    let total_count = subtasks.len();
   754	    let phase = infer_phase(workflow_dir);
   755	    let (current_iteration, total_iterations) = extract_iteration_numbers(workflow_dir);
   756	
   757	    let review_content = find_latest_review_content(workflow_dir);
   758	    let last_score = review_content.as_deref().and_then(extract_score);
   759	    let review_summary = review_content.as_deref().and_then(extract_review_summary);
   760	    let passing_score = get_passing_score();
   761	    let score_history = build_score_history(workflow_dir);
   762	
   763	    IterationProgress {
   764	        current_iteration,
   765	        total_iterations,
   766	        phase,
   767	        subtasks,
   768	        passed_count,
   769	        total_count,
   770	        last_score,
   771	        passing_score,
   772	        review_summary,
   773	        score_history,
   774	    }
   775	}
   776	
   777	/// Returns the iteration progress for a given issue's workflow.
   778	fn get_iteration_progress_sync(
   779	    project_path: &str,
   780	    issue_number: i64,
   781	) -> Result<IterationProgress, String> {
   782	    let base = Path::new(project_path);
   783	    if !base.is_dir() {
   784	        return Err(format!("Path is not a directory: {project_path}"));
   785	    }
   786	
   787	    let workflow_dir = base
   788	        .join(".autoresearch")
   789	        .join("workflows")
   790	        .join(format!("issue-{issue_number}"));


