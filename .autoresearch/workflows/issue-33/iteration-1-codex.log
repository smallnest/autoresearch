   684	/// Parses "迭代 N/M" from terminal.log content. Returns the last match.
   685	fn parse_iteration_from_terminal(content: &str) -> Option<(i32, i32)> {
   686	    let mut result = None;
   687	    for line in content.lines() {
   688	        // Look for "迭代 N/M" pattern
   689	        if let Some(pos) = line.find("迭代 ") {
   690	            let rest = &line[pos + "迭代 ".len()..];
   691	            if let Some(slash_pos) = rest.find('/') {
   692	                let current_str = rest[..slash_pos].trim();
   693	                let total_rest = &rest[slash_pos + 1..];
   694	                // Total might be followed by other characters or end of line
   695	                let total_str: String = total_rest
   696	                    .chars()
   697	                    .take_while(|c| c.is_ascii_digit())
   698	                    .collect();
   699	                if let (Ok(current), Ok(total)) =
   700	                    (current_str.parse::<i32>(), total_str.parse::<i32>())
   701	                {
   702	                    result = Some((current, total));
   703	                }
   704	            }
   705	        }
   706	    }
   707	    result
   708	}
