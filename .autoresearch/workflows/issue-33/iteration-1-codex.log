   661	/// Extracts the current iteration and total iterations from terminal.log.
   662	///
   663	/// Looks for the pattern `🔄 迭代 N/M` in terminal.log lines (last match wins).
   664	/// Falls back to parsing log.md if terminal.log is missing or has no match.
   665	fn extract_iteration_numbers(workflow_dir: &Path) -> (i32, i32) {
   666	    // Try terminal.log first (most reliable for iteration markers)
   667	    let terminal_path = workflow_dir.join("terminal.log");
   668	    if let Ok(content) = fs::read_to_string(&terminal_path) {
   669	        if let Some((current, total)) = parse_iteration_from_terminal(&content) {
   670	            return (current, total);
   671	        }
   672	    }
   673	
   674	    let log_md_path = workflow_dir.join("log.md");
   675	    if let Ok(content) = fs::read_to_string(&log_md_path) {
   676	        if let Some((current, total)) = parse_iteration_from_log_md(&content) {
   677	            return (current, total);
   678	        }
   679	    }
   680	
   681	    (0, 0)
   682	}
