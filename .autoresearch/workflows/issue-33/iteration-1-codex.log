+fn build_score_history(workflow_dir: &Path) -> Vec<ScoreHistoryPoint> {
+    let entries = match fs::read_dir(workflow_dir) {
+        Ok(entries) => entries,
+        Err(_) => return Vec::new(),
+    };
+
+    let mut best_by_iteration: std::collections::BTreeMap<i32, std::path::PathBuf> =
