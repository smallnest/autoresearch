diff --git a/desktop_app/tests/scoreTrendChart.test.mjs b/desktop_app/tests/scoreTrendChart.test.mjs
new file mode 100644
index 0000000000000000000000000000000000000000..7146aca209c773507eaa7517fc468ada3cee2c77
--- /dev/null
+++ b/desktop_app/tests/scoreTrendChart.test.mjs
@@ -0,0 +1,60 @@
+import test from 'node:test';
+import assert from 'node:assert/strict';
+import { createElement } from 'react';
+import { renderToStaticMarkup } from 'react-dom/server';
+import ScoreTrendChart, {
+  buildScoreTrendChartData,
+  buildScoreTrendTooltipContent,
+} from '../src/components/ScoreTrendChart.tsx';
+
+test('buildScoreTrendChartData preserves iteration order and review summaries', () => {
+  const data = buildScoreTrendChartData([
+    { iteration: 1, score: 71, review_summary: '需要补测试' },
+    { iteration: 2, score: 86, review_summary: null },
+  ]);
+
+  assert.deepEqual(data, [
+    { iteration: 1, score: 71, reviewSummary: '需要补测试' },
+    { iteration: 2, score: 86, reviewSummary: null },
+  ]);
+});
+
+test('buildScoreTrendTooltipContent exposes score and summary for hover card', () => {
+  const tooltip = buildScoreTrendTooltipContent({
+    iteration: 3,
+    score: 92,
+    reviewSummary: '边界条件已覆盖',
+  });
+
+  assert.equal(tooltip.iterationLabel, '第 3 次迭代');
+  assert.equal(tooltip.scoreLabel, '评分：92/100');
+  assert.equal(tooltip.summaryLabel, '边界条件已覆盖');
+});
+
+test('ScoreTrendChart renders heading and passing score legend', () => {
+  const markup = renderToStaticMarkup(
+    createElement(ScoreTrendChart, {
+      scoreHistory: [
+        { iteration: 1, score: 71, review_summary: '需要补测试' },
+        { iteration: 2, score: 86, review_summary: '达到通过线' },
+      ],
+      passingScore: 85,
+    }),
+  );
+
+  assert.match(markup, /评分趋势/);
+  assert.match(markup, /通过线 85/);
+  assert.match(markup, /迭代编号/);
+  assert.match(markup, /评分/);
+});
+
+test('ScoreTrendChart hides itself when there is no score history', () => {
+  const markup = renderToStaticMarkup(
+    createElement(ScoreTrendChart, {
+      scoreHistory: [],
+      passingScore: 85,
+    }),
+  );
+
+  assert.equal(markup, '');
+});

