   710	/// Parses iteration progress from log.md content.
   711	///
   712	/// Current iteration is inferred from the last `### 迭代 N - ...` heading.
   713	/// Total iterations is inferred from the last `总迭代次数: N` entry.
   714	/// If only one value is present, the other defaults to 0.
   715	fn parse_iteration_from_log_md(content: &str) -> Option<(i32, i32)> {
   716	    let mut current_iteration = 0;
