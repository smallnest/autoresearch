   599	/// Infers the current phase by examining files in the workflow directory.
   600	///
   601	/// Logic:
   602	/// 1. Find the highest iteration number N from `iteration-N-*.log` files.
   603	/// 2. If no iteration logs exist but `planning.log` exists → Planning.
   604	/// 3. If no iteration logs and no planning.log → Idle.
   605	/// 4. If `hard-gate-N.log` exists → BuildLintTest.
   606	/// 5. If `iteration-N-*-review.log` exists → Review.
   607	/// 6. Otherwise → Implementation.
   608	fn infer_phase(workflow_dir: &Path) -> Phase {
   609	    let entries = match fs::read_dir(workflow_dir) {
   610	        Ok(e) => e,
   611	        Err(_) => return Phase::Idle,
   612	    };
   613	
   614	    let mut max_iteration: i32 = 0;
   615	    let mut has_planning = false;
   616	    let mut review_iterations = std::collections::HashSet::new();
   617	    let mut hard_gate_iterations = std::collections::HashSet::new();
   618	
   619	    for entry in entries.flatten() {
   620	        let name = entry.file_name().to_string_lossy().to_string();
   621	        if name == "planning.log" {
   622	            has_planning = true;
   623	            continue;
   624	        }
   625	        if let Some(n) = iteration_number(&name) {
   626	            if n > max_iteration {
   627	                max_iteration = n;
   628	            }
   629	            if name.contains("-review.log") {
   630	                review_iterations.insert(n);
   631	            }
   632	        }
   633	        if name.starts_with("hard-gate-") && name.ends_with(".log") {
   634	            if let Some(n) = name
   635	                .strip_prefix("hard-gate-")
   636	                .and_then(|s| s.strip_suffix(".log"))
   637	                .and_then(|s| s.parse::<i32>().ok())
   638	            {
   639	                hard_gate_iterations.insert(n);
   640	            }
   641	        }
   642	    }
   643	
   644	    if max_iteration == 0 {
   645	        return if has_planning {
   646	            Phase::Planning
   647	        } else {
   648	            Phase::Idle
   649	        };
   650	    }
   651	
   652	    if hard_gate_iterations.contains(&max_iteration) {
   653	        return Phase::BuildLintTest;
   654	    }
   655	    if review_iterations.contains(&max_iteration) {
   656	        return Phase::Review;
   657	    }
   658	    Phase::Implementation
   659	}
