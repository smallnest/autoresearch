+            .map(|current| name.as_str() > current.to_string_lossy().as_ref())
+            .unwrap_or(true);
+
+        if replace {
+            best_by_iteration.insert(iteration, path);
+        }
+    }
+
+    best_by_iteration
+        .into_iter()
