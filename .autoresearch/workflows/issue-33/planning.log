            ) : (
              <polyline points="15 18 9 12 15 6" />
            )}
          </svg>
        </button>
      </div>
      {!collapsed && (
        <div className="p-4 text-sm text-gray-500">
          <p>选择一项后可在这里查看详情。</p>
        </div>
      )}
    </aside>
  );
}

