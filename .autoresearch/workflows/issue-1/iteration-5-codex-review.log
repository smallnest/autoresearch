   112	annealing_delay() {
   113	    local retry=$1
   114	    local delay=$((RETRY_BASE_DELAY * (1 << (retry - 1))))
   115	    local jitter=$((delay / 4))
   116	    if [ $jitter -gt 0 ]; then
   117	        jitter=$((RANDOM % jitter))
   118	    fi
   119	    delay=$((delay + jitter))
   120	    if [ $delay -gt $RETRY_MAX_DELAY ]; then
   121	        delay=$RETRY_MAX_DELAY
   122	    fi
   123	    echo $delay
   124	}
   125	
   126	# 检测 Agent 输出是否包含致命错误（区分代码讨论中的 "error" 与真正的运行时错误）
   127	has_fatal_error() {
   128	    local log_file="$1"
   129	    # 仅匹配行首的错误模式，避免误判代码中讨论 "error handling" 等正常内容
   130	    local pattern='^(Error|ERROR|Fatal|Panic|Exception)[: ]'
   131	    pattern+='|^(timeout|rate.limit|authentication|unauthorized|API.key).*error'
   132	    pattern+='|context.length.exceeded'
   133	    pattern+='|maximum.context.length'
   134	    pattern+='|token.limit.exceeded'
   135	    pattern+='|model.is.overloaded'
   136	    pattern+='|server.error'
   137	    pattern+='|service.unavailable'
   138	    pattern+='|internal.server.error'
   139	    pattern+='|too.many.requests'
   140	    pattern+='|quota.exceeded'
   141	    pattern+='|billing.hard.limit'
   142	    pattern+='|connection.refused'
   143	    pattern+='|network.error'
   144	    pattern+='|DNS.resolution'
   145	    grep -qE "$pattern" "$log_file" 2>/dev/null
   146	}
   147	
   148	# 检测 Agent 输出是否包含 API/网络级别的失败（区分于可恢复的内容错误）
   149	has_api_failure() {
   150	    local log_file="$1"
   151	    # 这些模式表示 API 调用本身失败，而非代码内容问题
   152	    local pattern='status.4[0-9][0-9]'
   153	    pattern+='|status.5[0-9][0-9]'
   154	    pattern+='|HTTP.4[0-9][0-9]'
   155	    pattern+='|HTTP.5[0-9][0-9]'
   156	    pattern+='|curl.*error'
   157	    pattern+='|fetch.failed'
   158	    pattern+='|request.failed'
   159	    pattern+='|response.is.empty'
   160	    pattern+='|no.response.received'
   161	    grep -qE "$pattern" "$log_file" 2>/dev/null
   162	}
   163	
   164	run_with_retry() {
   165	    local agent=$1
   166	    local prompt="$2"
   167	    local log_file="$3"
   168	    local retry=0
   169	    local success=0
   170	
   171	    while [ $retry -lt $MAX_RETRIES ]; do
   172	        retry=$((retry + 1))
   173	
   174	        if [ $retry -gt 1 ]; then
   175	            local delay
   176	            delay=$(annealing_delay $retry)
   177	            log "第 $retry/$MAX_RETRIES 次重试，等待 ${delay} 秒..."
   178	            sleep $delay
   179	        fi
   180	
   181	        log "调用 $agent (尝试 $retry/$MAX_RETRIES)..."
   182	
   183	        # Truncate log file before each attempt so we only capture this attempt's output
   184	        : > "$log_file"
   185	
   186	        local exit_code=1
   187	        if [ "$agent" = "codex" ]; then
   188	            codex exec --full-auto "$prompt" 2>&1 | tee "$log_file" || true
   189	            exit_code=${PIPESTATUS[0]}
   190	        elif [ "$agent" = "opencode" ]; then
   191	            opencode run "$prompt" 2>&1 | tee "$log_file" || true
   192	            exit_code=${PIPESTATUS[0]}
   193	        else
   194	            claude -p "$prompt" --dangerously-skip-permissions 2>&1 | tee "$log_file" || true
   195	            exit_code=${PIPESTATUS[0]}
   196	        fi
   197	
   198	        # Check for non-zero exit code from the agent
   199	        if [ $exit_code -ne 0 ]; then
   200	            log "Agent $agent 以非零退出码退出: $exit_code"
   201	            log "$agent 第 $retry 次调用失败"
   202	            continue
   203	        fi
   204	
   205	        # Check for fatal errors in output
   206	        if has_fatal_error "$log_file"; then
   207	            log "检测到致命错误，将重试"
   208	            log "$agent 第 $retry 次调用失败"
   209	            continue
   210	        fi
   211	
   212	        # Check for API failures in output
   213	        if has_api_failure "$log_file"; then
   214	            log "检测到 API 失败，将重试"
   215	            log "$agent 第 $retry 次调用失败"
   216	            continue
   217	        fi
   218	
   219	        # Check output quality: must have meaningful content
   220	        local content_lines
   221	        content_lines=$(grep -vE '^\s*$' "$log_file" | wc -l)
   222	        if [ "$content_lines" -lt 5 ]; then
   223	            log "警告: 输出内容过少 ($content_lines 行)，将重试"
   224	            log "$agent 第 $retry 次调用失败"
   225	            continue
   226	        fi
   227	
   228	        success=1
   229	        break
   230	    done
   231	
   232	    if [ $success -eq 1 ]; then
   233	        return 0
   234	    else
   235	        error "$agent 调用失败，已重试 $MAX_RETRIES 次"
   236	        return 1
   237	    fi
   238	}
