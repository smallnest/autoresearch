   370	setup_work_directory() {
   371	    local issue_number=$1
   372	
   373	    WORK_DIR="$PROJECT_ROOT/.autoresearch/workflows/issue-$issue_number"
   374	    mkdir -p "$WORK_DIR"
   375	
   376	    log "工作目录: $WORK_DIR"
   377	
   378	    if [ $CONTINUE_MODE -eq 1 ]; then
   379	        if [ ! -f "$WORK_DIR/log.md" ]; then
   380	            error "未找到 Issue #$issue_number 的工作日志，无法继续"
   381	            exit 1
   382	        fi
   383	        log "继续模式: 追加到已有日志"
   384	        return
   385	    fi
   386	
   387	    cat > "$WORK_DIR/log.md" << EOF
   388	# Issue #$issue_number 实现日志
   389	
   390	## 基本信息
   391	- Issue: #$issue_number - $ISSUE_TITLE
   392	- 项目: $PROJECT_ROOT
   393	- 语言: $(detect_language)
   394	- 开始时间: $(date '+%Y-%m-%d %H:%M:%S')
   395	- 标签: $ISSUE_LABELS
   396	
   397	## 迭代记录
   398	
   399	EOF
   400	}
