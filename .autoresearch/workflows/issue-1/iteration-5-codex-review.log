   305	check_dependencies() {
   306	    log "检查依赖..."
   307	
   308	    local missing=0
   309	
   310	    if ! command -v gh &> /dev/null; then
   311	        error "gh (GitHub CLI) 未安装"
   312	        missing=1
   313	    fi
   314	
   315	    if ! command -v claude &> /dev/null; then
   316	        error "claude (Claude Code CLI) 未安装"
   317	        missing=1
   318	    fi
   319	
   320	    if ! command -v codex &> /dev/null; then
   321	        error "codex (OpenAI Codex CLI) 未安装"
   322	        missing=1
   323	    fi
   324	
   325	    if ! command -v opencode &> /dev/null; then
   326	        error "opencode CLI 未安装"
   327	        missing=1
   328	    fi
   329	
   330	    # 检查语言特定工具
