   458	run_codex() {
   459	    local issue_number=$1
   460	    local iteration=$2
   461	    local previous_feedback=$3
   462	
   463	    log "迭代 $iteration: Codex 实现..."
   464	
   465	    local codex_instructions_file
   466	    codex_instructions_file=$(get_agent_instructions "codex")
   467	
   468	    local codex_instructions=""
   469	    if [ -n "$codex_instructions_file" ]; then
   470	        codex_instructions=$(cat "$codex_instructions_file")
   471	        log "使用指令文件: $codex_instructions_file"
   472	    fi
   473	
   474	    local program_instructions
   475	    program_instructions=$(get_program_instructions)
   476	
   477	    local prompt
   478	    if [ -z "$previous_feedback" ]; then
   479	        prompt="实现 GitHub Issue #$issue_number
   480	
   481	项目路径: $PROJECT_ROOT
   482	项目语言: $(detect_language)
   483	Issue 标题: $ISSUE_TITLE
   484	Issue 内容: $ISSUE_BODY
   485	
   486	迭代次数: $iteration
   487	
   488	---
   489	请按以下步骤执行:
   490	
   491	## 第一步：制定计划
   492	分析 Issue 需求，制定实现计划，拆解为具体的 tasks/todos，输出任务清单。
   493	
   494	## 第二步：逐步实现
   495	按照任务清单逐步实现，每完成一个任务标记为已完成。
   496	
   497	---
   498	$program_instructions
   499	
   500	$codex_instructions
   501	"
   502	    else
   503	        prompt="根据审核反馈改进 Issue #$issue_number 的实现
   504	
   505	项目路径: $PROJECT_ROOT
   506	项目语言: $(detect_language)
   507	Issue 标题: $ISSUE_TITLE
   508	
   509	审核反馈:
   510	$previous_feedback
   511	
   512	---
   513	请按以下步骤执行:
   514	
   515	## 第一步：制定计划
   516	分析审核反馈，制定修复计划，拆解为具体的 tasks/todos，输出任务清单。
   517	
   518	## 第二步：逐步实现
   519	按照任务清单逐步修复，每完成一个任务标记为已完成。
   520	
   521	---
   522	$codex_instructions
   523	"
   524	    fi
   525	
   526	    local log_file="$WORK_DIR/iteration-$iteration-codex.log"
   527	
   528	    cd "$PROJECT_ROOT"
   529	    if ! run_with_retry codex "$prompt" "$log_file"; then
   530	        return 1
   531	    fi
   532	
   533	    echo "" >> "$WORK_DIR/log.md"
   534	    echo "### 迭代 $iteration - Codex (实现)" >> "$WORK_DIR/log.md"
   535	    echo "" >> "$WORK_DIR/log.md"
   536	    echo "详见: [iteration-$iteration-codex.log](./iteration-$iteration-codex.log)" >> "$WORK_DIR/log.md"
   537	    return 0
   538	}
