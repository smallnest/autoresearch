   344	get_issue_info() {
   345	    local issue_number=$1
   346	
   347	    log "获取 Issue #$issue_number 信息..."
   348	
   349	    ISSUE_INFO=$(gh issue view $issue_number --json number,title,body,state,labels 2>&1)
   350	
   351	    if [ $? -ne 0 ]; then
   352	        error "无法获取 Issue #$issue_number: $ISSUE_INFO"
   353	        exit 1
   354	    fi
   355	
   356	    ISSUE_TITLE=$(echo "$ISSUE_INFO" | jq -r '.title')
   357	    ISSUE_BODY=$(echo "$ISSUE_INFO" | jq -r '.body')
   358	    ISSUE_STATE=$(echo "$ISSUE_INFO" | jq -r '.state')
   359	    ISSUE_LABELS=$(echo "$ISSUE_INFO" | jq -r '.labels[].name' | tr '\n' ',' | sed 's/,$//')
   360	
   361	    if [ "$ISSUE_STATE" != "OPEN" ]; then
   362	        error "Issue #$issue_number 状态为 $ISSUE_STATE，不是 OPEN"
   363	        exit 1
   364	    fi
   365	
   366	    log "Issue 标题: $ISSUE_TITLE"
   367	    log "Issue 标签: $ISSUE_LABELS"
   368	}
