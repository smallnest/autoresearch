    57	# 检测项目使用的编程语言
    58	detect_language() {
    59	    if [ -f "$PROJECT_ROOT/go.mod" ]; then
    60	        echo "go"
    61	    elif [ -f "$PROJECT_ROOT/package.json" ]; then
    62	        echo "node"
    63	    elif [ -f "$PROJECT_ROOT/requirements.txt" ] || [ -f "$PROJECT_ROOT/pyproject.toml" ] || [ -f "$PROJECT_ROOT/setup.py" ]; then
    64	        echo "python"
    65	    elif [ -f "$PROJECT_ROOT/Cargo.toml" ]; then
    66	        echo "rust"
    67	    elif [ -f "$PROJECT_ROOT/pom.xml" ] || [ -f "$PROJECT_ROOT/build.gradle" ]; then
    68	        echo "java"
    69	    else
    70	        echo "unknown"
    71	    fi
