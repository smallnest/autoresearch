   332	    if [ -n "$required" ] && ! command -v "$required" &> /dev/null; then
   333	        error "$required 未安装 (项目语言: $(detect_language))"
   334	        missing=1
   335	    fi
   336	
   337	    if [ $missing -eq 1 ]; then
   338	        exit 1
   339	    fi
