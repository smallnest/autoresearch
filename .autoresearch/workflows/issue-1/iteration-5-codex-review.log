   136	annealing_delay() {
   137	    local retry=$1
   138	    local delay=$((RETRY_BASE_DELAY * (1 << (retry - 1))))
   139	    local jitter=$((delay / 4))
   140	    if [ $jitter -gt 0 ]; then
   141	        jitter=$((RANDOM % jitter))
   142	    fi
   143	    delay=$((delay + jitter))
   144	    if [ $delay -gt $RETRY_MAX_DELAY ]; then
   145	        delay=$RETRY_MAX_DELAY
   146	    fi
   147	    echo $delay
   148	}
