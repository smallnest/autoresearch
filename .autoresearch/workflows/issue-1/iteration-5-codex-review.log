   240	usage() {
   241	    echo "用法: $0 [-p project_path] [-c] <issue_number> [max_iterations]"
   242	    echo ""
   243	    echo "通用自动化 Issue 处理工具，支持任意 Git + GitHub 项目。"
   244	    echo ""
   245	    echo "参数:"
   246	    echo "  -p <path>        项目路径 (默认: 当前目录)"
   247	    echo "  -c               继续模式，从上次中断的迭代继续"
   248	    echo "  issue_number     GitHub Issue 编号"
   249	    echo "  max_iterations   最大迭代次数 (默认: $DEFAULT_MAX_ITERATIONS)"
   250	    echo ""
   251	    echo "配置 (环境变量):"
   252	    echo "  PASSING_SCORE=85              达标评分线 (百分制)"
   253	    echo "  MAX_CONSECUTIVE_FAILURES=3    连续失败最大次数"
   254	    echo ""
   255	    echo "自定义配置文件 (放在项目目录 .autoresearch/ 下):"
   256	    echo "  agents/codex.md              Codex 指令"
   257	    echo "  agents/claude.md             Claude 指令"
   258	    echo "  agents/opencode.md           OpenCode 指令"
   259	    echo "  program.md                   实现规则与约束"
   260	    echo ""

 succeeded in 0ms:
   260	    echo ""
   261	    echo "示例:"
   262	    echo "  $0 42                                  # 处理当前项目的 Issue #42"
   263	    echo "  $0 -p /path/to/project 42             # 处理指定项目的 Issue #42"
   264	    echo "  $0 -p /path/to/project 42 10          # 最多迭代 10 次"
   265	    echo "  $0 -c 42                              # 继续处理 Issue #42"
   266	    echo "  $0 -c 42 10                           # 继续处理，追加 10 次迭代"
   267	    echo "  PASSING_SCORE=90 $0 42                # 提高达标线到 90"
   268	    exit 1
   269	}
