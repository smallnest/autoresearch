  1068	# ==================== 继续模式：恢复状态 ====================
  1069	
  1070	find_last_iteration() {
  1071	    local last=0
  1072	    if [ ! -d "$WORK_DIR" ]; then
  1073	        echo 0
  1074	        return
  1075	    fi
  1076	    for f in "$WORK_DIR"/iteration-*.log; do
  1077	        [ -f "$f" ] || continue
  1078	        local num
  1079	        num=$(basename "$f" | grep -oE 'iteration-[0-9]+' | grep -oE '[0-9]+')
  1080	        if [ -n "$num" ] && [ "$num" -gt "$last" ] 2>/dev/null; then
  1081	            last=$num
  1082	        fi
  1083	    done
  1084	    echo "$last"
  1085	}
  1086	
  1087	restore_continue_state() {
  1088	    local last_iter
  1089	    last_iter=$(find_last_iteration)
  1090	
  1091	    # 清洗：只保留数字
  1092	    last_iter=$(echo "$last_iter" | tr -cd '0-9')
  1093	
  1094	    if [ -z "$last_iter" ] || ! [ "$last_iter" -gt 0 ] 2>/dev/null; then
  1095	        error "未找到任何迭代记录，无法继续 (last_iter='$last_iter')"
  1096	        exit 1
  1097	    fi
  1098	
  1099	    log "上次运行到迭代 $last_iter，从迭代 $((last_iter + 1)) 继续"
  1100	
  1101	    # 恢复迭代计数
  1102	    ITERATION=$last_iter
  1103	
  1104	    # 恢复最终评分
  1105	    if [ -f "$WORK_DIR/.last_score" ]; then
  1106	        FINAL_SCORE=$(cat "$WORK_DIR/.last_score" | tr -cd '0-9')
  1107	        [ -z "$FINAL_SCORE" ] && FINAL_SCORE=0
  1108	        log "上次评分: $FINAL_SCORE/100"
  1109	    fi
  1110	
  1111	    # 继续模式重置连续失败计数
  1112	    CONSECUTIVE_ITERATION_FAILURES=0
  1113	
  1114	    # 恢复上次的审核反馈：从最后一个 review log 中提取
  1115	    local last_review_log=""
  1116	    for agent_name in "${AGENT_NAMES[@]}"; do
  1117	        local f="$WORK_DIR/iteration-${last_iter}-${agent_name}-review.log"
  1118	        if [ -f "$f" ]; then
  1119	            last_review_log="$f"
  1120	        fi
  1121	    done
  1122	
  1123	    if [ -n "$last_review_log" ] && [ -f "$last_review_log" ]; then
  1124	        PREVIOUS_FEEDBACK=$(cat "$last_review_log")
  1125	        log "已恢复上次审核反馈"
  1126	    else
  1127	        # 没有审核反馈，可能是迭代 1 就中断了
  1128	        PREVIOUS_FEEDBACK="初始实现已完成，请审核代码质量并给出评分。如果有问题请直接修复。"
  1129	        log "未找到审核反馈，使用默认反馈"
  1130	    fi
  1131	
  1132	    # 确保在正确的分支上
  1133	    cd "$PROJECT_ROOT"
  1134	    local branch="feature/issue-$ISSUE_NUMBER"
  1135	    if git show-ref --verify --quiet "refs/heads/$branch"; then
  1136	        git checkout "$branch"
  1137	        BRANCH_NAME="$branch"
  1138	        log "已切换到分支: $branch"
  1139	    else
  1140	        error "未找到分支 $branch，无法继续"
  1141	        exit 1
  1142	    fi
  1143	
  1144	    # 追加继续标记到日志
  1145	    echo "" >> "$WORK_DIR/log.md"
  1146	    echo "---" >> "$WORK_DIR/log.md"
  1147	    echo "" >> "$WORK_DIR/log.md"
  1148	    echo "## 继续运行 (从迭代 $((last_iter + 1)) 继续)" >> "$WORK_DIR/log.md"
  1149	    echo "- 继续时间: $(date '+%Y-%m-%d %H:%M:%S')" >> "$WORK_DIR/log.md"
  1150	    echo "- 上次评分: $FINAL_SCORE/100" >> "$WORK_DIR/log.md"
  1151	    echo "" >> "$WORK_DIR/log.md"
  1152	}
  1153	
  1154	# ==================== 参数解析 ====================
  1155	
  1156	CONTINUE_MODE=0
  1157	
  1158	while getopts "p:c" opt; do
  1159	    case $opt in
  1160	        p) PROJECT_ROOT="$(cd "$OPTARG" && pwd)" ;;
  1161	        c) CONTINUE_MODE=1 ;;
  1162	        *) usage ;;
  1163	    esac
  1164	done
  1165	shift $((OPTIND - 1))
  1166	
  1167	if [ -z "$1" ]; then
  1168	    usage
  1169	fi
  1170	
  1171	ISSUE_NUMBER=$1
  1172	MAX_ITERATIONS=${2:-$DEFAULT_MAX_ITERATIONS}
