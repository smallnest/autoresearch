    99	# 检测项目语言用于依赖检查
   100	get_required_tools() {
   101	    local lang=$(detect_language)
   102	    case "$lang" in
   103	        go)     echo "go" ;;
   104	        node)   echo "node" ;;
   105	        python) echo "python3" ;;
   106	        rust)   echo "cargo" ;;
