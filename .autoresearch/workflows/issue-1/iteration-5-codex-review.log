   271	check_project() {
   272	    log "检查项目环境..."
   273	
   274	    if [ ! -d "$PROJECT_ROOT" ]; then
   275	        error "项目目录不存在: $PROJECT_ROOT"
   276	        exit 1
   277	    fi
   278	
   279	    cd "$PROJECT_ROOT"
   280	
   281	    if ! git rev-parse --is-inside-work-tree &> /dev/null; then
   282	        error "不是 git 仓库: $PROJECT_ROOT"
   283	        exit 1
   284	    fi
   285	
   286	    local remote_url
   287	    remote_url=$(git remote get-url origin 2>/dev/null || true)
   288	
   289	    if [ -z "$remote_url" ]; then
   290	        error "未找到 git remote origin"
   291	        exit 1
   292	    fi
   293	
   294	    if ! echo "$remote_url" | grep -qE 'github\.com|github\.baidu\.com'; then
   295	        error "origin 不是 GitHub 仓库: $remote_url"
   296	        exit 1
   297	    fi
   298	
   299	    local lang=$(detect_language)
   300	    log "项目目录: $PROJECT_ROOT"
   301	    log "Git remote: $remote_url"
   302	    log "项目语言: $lang"
   303	}
