### 建议 (T-001 实现方向)

需要实现以下内容：

**1. `build.rs`** — 构建前复制运行时文件:
```rust
use std::fs;
use std::path::Path;

fn main() {
    let manifest_dir = std::env::var("CARGO_MANIFEST_DIR").unwrap();
    let workspace_root = Path::new(&manifest_dir)
        .parent()  // desktop_app/
        .unwrap()
        .parent()  // autoresearch root
        .unwrap();

    let resources_dir = Path::new(&manifest_dir).join("resources").join("runtime");

    // Clean and recreate
    if resources_dir.exists() {
        fs::remove_dir_all(&resources_dir).unwrap();
    }
    fs::create_dir_all(&resources_dir).unwrap();

    // Copy run.sh
    fs::copy(workspace_root.join("run.sh"), resources_dir.join("run.sh")).unwrap();

    // Copy program.md
    fs::copy(workspace_root.join("program.md"), resources_dir.join("program.md")).unwrap();

    // Copy lib/
    copy_dir_recursive(
        &workspace_root.join("lib"),
        &resources_dir.join("lib"),
    );

    // Copy agents/
    copy_dir_recursive(
        &workspace_root.join("agents"),
        &resources_dir.join("agents"),
    );

    // Generate version.txt from tauri.conf.json
    let version = "0.1.0"; // or parse from tauri.conf.json
    fs::write(resources_dir.join("version.txt"), version).unwrap();

    tauri_build::build()
}
```

**2. `tauri.conf.json`** — 添加 bundle.resources:
```json
"bundle": {
    "resources": ["resources/runtime/*"],
    ...
}
```

