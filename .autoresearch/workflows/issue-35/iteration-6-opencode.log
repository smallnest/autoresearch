#[cfg(test)]
mod history_tests {
    use super::*;

    #[test]
    fn test_parse_completed_success() {
        let content = "...issue-27 真实 log.md 内容...";
        let entry = parse_workflow_log(content, 27);
        assert_eq!(entry.issue_title.as_deref(), Some("[desktop-app] Issue 详情查看"));
        assert_eq!(entry.final_score, Some(90));
        assert!(matches!(entry.status, HistoryRunStatus::Success));
    }

    #[test]
    fn test_parse_interrupted() {
        let content = "...包含 ⚠️ 脚本被中断 的内容...";
        let entry = parse_workflow_log(content, 28);
        assert!(matches!(entry.status, HistoryRunStatus::Interrupt));
    }

    #[test]
    fn test_parse_in_progress_no_final_result() {
        let content = "# Issue #99 ...\n## 迭代记录\n### 迭代 1";
        let entry = parse_workflow_log(content, 99);
        assert!(matches!(entry.status, HistoryRunStatus::InProgress));
    }

    #[test]
    fn test_list_history_empty_dir() {
