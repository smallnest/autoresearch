/// Scans `.autoresearch/workflows/issue-*` directories and returns Issue numbers that have been processed.
fn get_processed_issue_numbers(project_path: &Path) -> Result<Vec<i64>, String> {
    let workflows_dir = project_path.join(".autoresearch").join("workflows");
    if !workflows_dir.is_dir() {
        return Ok(Vec::new());
    }
    let mut numbers = Vec::new();
    let entries =
        fs::read_dir(&workflows_dir).map_err(|e| format!("Failed to read workflows dir: {e}"))?;
    for entry in entries.flatten() {
        let name = entry.file_name();
        let name_str = name.to_string_lossy();
        if let Some(suffix) = name_str.strip_prefix("issue-") {
            if let Ok(num) = suffix.parse::<i64>() {
                numbers.push(num);
            }
        }
    }
    numbers.sort();
    Ok(numbers)
}

/// Lists GitHub Issues for the repository at `project_path` using `gh issue list`.
/// Also returns which Issue numbers have already been processed (have workflow directories).
#[tauri::command]
async fn list_issues(project_path: String) -> Result<IssuesResult, String> {
    tokio::task::spawn_blocking(move || list_issues_sync(&project_path))
        .await
        .map_err(|e| format!("Task join error: {e}"))?
}

fn list_issues_sync(project_path: &str) -> Result<IssuesResult, String> {
    let base = Path::new(project_path);
    if !base.is_dir() {
        return Err(format!("Path is not a directory: {project_path}"));
    }

    // Execute gh issue list
    let output = Command::new("gh")
        .args([
            "issue",
            "list",
            "--json",
            "number,title,labels,createdAt,state",
            "--limit",
            "100",
        ])
        .current_dir(base)
        .output()
        .map_err(|e| format!("Failed to execute gh: {e}"))?;

    if !output.status.success() {
        let stderr = String::from_utf8_lossy(&output.stderr);
        return Err(format!("gh issue list failed: {}", stderr.trim()));
    }

    let stdout = String::from_utf8_lossy(&output.stdout);
    let issues: Vec<GhIssue> = serde_json::from_str(&stdout)
        .map_err(|e| format!("Failed to parse gh output: {e}. Output: {stdout}"))?;

    let processed_numbers = get_processed_issue_numbers(base)?;

    Ok(IssuesResult {
        issues,
        processed_numbers,
    })
}

/// Returns a list of Issue numbers that have already been processed by autoresearch.
#[tauri::command]
async fn check_processed_issues(project_path: String) -> Result<Vec<i64>, String> {
    tokio::task::spawn_blocking(move || {
        let base = Path::new(&project_path);
        if !base.is_dir() {
            return Err(format!("Path is not a directory: {project_path}"));
        }
        get_processed_issue_numbers(base)
    })
    .await
    .map_err(|e| format!("Task join error: {e}"))?
}

fn parse_issue_detail(stdout: &str) -> Result<IssueDetail, String> {
    serde_json::from_str(stdout)
        .map_err(|e| format!("Failed to parse gh output: {e}. Output: {stdout}"))
}

fn map_issue_detail_command_error(issue_number: i64, stderr: &str) -> String {
    if stderr.contains("not found") || stderr.contains("Could not resolve") {
        return format!("Issue #{issue_number} not found");
    }

    format!("gh issue view failed: {}", stderr.trim())
}

/// Retrieves detailed information about a specific GitHub Issue using `gh issue view`.
#[tauri::command]
async fn get_issue_detail(project_path: String, issue_number: i64) -> Result<IssueDetail, String> {
    tokio::task::spawn_blocking(move || get_issue_detail_sync(&project_path, issue_number))
        .await
        .map_err(|e| format!("Task join error: {e}"))?
}

fn get_issue_detail_sync(project_path: &str, issue_number: i64) -> Result<IssueDetail, String> {
    let base = Path::new(project_path);
    if !base.is_dir() {
        return Err(format!("Path is not a directory: {project_path}"));
    }

    // Execute gh issue view
    let output = Command::new("gh")
        .args([
            "issue",
            "view",
            &issue_number.to_string(),
            "--json",
            "body,comments",
        ])
        .current_dir(base)
        .output()
        .map_err(|e| format!("Failed to execute gh: {e}"))?;

    if !output.status.success() {
        let stderr = String::from_utf8_lossy(&output.stderr);
        return Err(map_issue_detail_command_error(issue_number, &stderr));
    }

    let stdout = String::from_utf8_lossy(&output.stdout);
    parse_issue_detail(&stdout)
}

/// Starts a run.sh process with the given parameters.
///
/// # Arguments
/// * `project_path` - Path to the autoresearch project directory
/// * `params` - Parameters for the run (issue number, max iterations, etc.)
///
/// # Returns
/// The process ID of the started process.
///
/// # Errors
/// Returns an error if a process is already running or if the process fails to start.
#[tauri::command]
async fn start_run(
    app: tauri::AppHandle,
    process_state: tauri::State<'_, SharedProcessState>,
    project_path: String,
    params: StartRunParams,
) -> Result<StartRunResult, String> {
    let process_state = process_state.inner().clone();
    ensure_no_running_process(&process_state)?;

    // Verify project path exists
    let base = Path::new(&project_path);
    if !base.is_dir() {
        return Err(format!("Path is not a directory: {project_path}"));
    }

    // Build the run.sh command arguments
    let run_sh = base.join("run.sh");
    if !run_sh.exists() {
        return Err(format!("run.sh not found at: {}", run_sh.display()));
    }

    let args = build_run_args(&params);

    // Note: passing_score is passed via environment variable PASSING_SCORE
    let passing_score = params.passing_score;

    // Start the process with a new process group
    let app_handle = app.clone();

    #[cfg(unix)]
    let (pid, handle) = start_run_unix(
        &run_sh,
        &args,
        &project_path,
        passing_score,
        app_handle,
        process_state.clone(),
    )?;

    #[cfg(not(unix))]
    let (pid, handle) = start_run_windows(
        &run_sh,
        &args,
        &project_path,
        passing_score,
        app_handle,
        process_state.clone(),
    )?;

    set_process_state(&process_state, pid, handle)?;

    Ok(StartRunResult { pid })
}

#[cfg(unix)]
fn start_run_unix(
    run_sh: &Path,
    args: &[String],
    project_path: &str,
    passing_score: Option<u32>,
    app_handle: tauri::AppHandle,
    process_state: SharedProcessState,
) -> Result<(u32, ChildHandle), String> {
    let mut cmd = TokioCommand::new(run_sh);
    cmd.args(args)
        .current_dir(project_path)
        .stdout(Stdio::piped())
        .stderr(Stdio::piped())
        .kill_on_drop(false);

    if let Some(score) = passing_score {
        cmd.env("PASSING_SCORE", score.to_string());
    }

    unsafe {
        cmd.pre_exec(|| {
            nix::unistd::setpgid(nix::unistd::Pid::from_raw(0), nix::unistd::Pid::from_raw(0))
                .map_err(io::Error::other)?;
            Ok(())
        });
    }

    let mut child = cmd
        .spawn()
        .map_err(|e| format!("Failed to spawn process: {e}"))?;
    let pid = child.id().ok_or("Failed to get process ID")?;

    let stdout = child.stdout.take().ok_or("Failed to capture stdout")?;
    let stderr = child.stderr.take().ok_or("Failed to capture stderr")?;
    let handle = Arc::new(tokio::sync::Mutex::new(child));

    emit_run_output(app_handle.clone(), stdout);
    emit_run_output(app_handle.clone(), stderr);
    spawn_exit_watcher(process_state, Arc::clone(&handle), pid, app_handle);

    Ok((pid, handle))
}

#[cfg(not(unix))]
fn start_run_windows(
    run_sh: &Path,
    args: &[String],
    project_path: &str,
    passing_score: Option<u32>,
    app_handle: tauri::AppHandle,
    process_state: SharedProcessState,
) -> Result<(u32, ChildHandle), String> {
    let mut cmd = TokioCommand::new(run_sh);
    cmd.args(args)
        .current_dir(project_path)
        .stdout(Stdio::piped())
        .stderr(Stdio::piped())
        .kill_on_drop(true);

    if let Some(score) = passing_score {
        cmd.env("PASSING_SCORE", score.to_string());
    }

    let mut child = cmd
        .spawn()
        .map_err(|e| format!("Failed to spawn process: {e}"))?;
    let pid = child.id().ok_or("Failed to get process ID")?;

    let stdout = child.stdout.take().ok_or("Failed to capture stdout")?;
    let stderr = child.stderr.take().ok_or("Failed to capture stderr")?;
    let handle = Arc::new(tokio::sync::Mutex::new(child));

    emit_run_output(app_handle.clone(), stdout);
    emit_run_output(app_handle.clone(), stderr);
    spawn_exit_watcher(process_state, Arc::clone(&handle), pid, app_handle);

    Ok((pid, handle))
}

/// Stops the currently running run.sh process.
///
/// # Returns
/// `true` if a process was stopped, `false` if no process was running.
///
/// # Errors
/// Returns an error if the lock cannot be acquired or the kill operation fails.
#[tauri::command]
async fn stop_run(process_state: tauri::State<'_, SharedProcessState>) -> Result<bool, String> {
    let process_state = process_state.inner().clone();
    let pid = current_process_pid(&process_state)?;
    let _handle = current_process_handle(&process_state)?;

    let Some(pid) = pid else {
        return Ok(false);
    };

    #[cfg(unix)]
    {
        use nix::sys::signal::{killpg, Signal};
        use nix::unistd::Pid;

        killpg(Pid::from_raw(pid as i32), Signal::SIGTERM)
            .map_err(|e| format!("Failed to send SIGTERM: {e}"))?;
        clear_process_state_if_pid_matches(&process_state, pid);
    }

    #[cfg(not(unix))]
    {
        // On Windows, we would need to use job objects or taskkill
        // For now, return an error indicating this is not implemented
        return Err("Process termination is not fully implemented on Windows. Please manually terminate the process.".to_string());
    }

    Ok(true)
}

/// Checks if a run.sh process is currently running.
#[tauri::command]
fn is_run_active(process_state: tauri::State<'_, SharedProcessState>) -> bool {
    process_state
        .lock()
        .map(|state| state.is_some())
        .unwrap_or(false)
}

#[cfg_attr(mobile, tauri::mobile_entry_point)]
pub fn run() {
    tauri::Builder::default()
        .plugin(tauri_plugin_opener::init())
        .plugin(tauri_plugin_dialog::init())
        .plugin(tauri_plugin_store::Builder::default().build())
        .manage(new_process_state())
        .invoke_handler(tauri::generate_handler![
            select_project_dir,
            detect_project_config,
            get_recent_project,
            save_recent_project,
            list_issues,
            check_processed_issues,
            get_issue_detail,
            start_run,
            stop_run,
            is_run_active,
        ])
        .run(tauri::generate_context!())
        .expect("error while running tauri application");
}

#[cfg(test)]
mod tests {
    use super::{
        build_run_args, clear_process_state_if_pid_matches, current_process_handle,
        current_process_pid, ensure_no_running_process, get_issue_detail_sync,
        map_issue_detail_command_error, new_process_state, parse_issue_detail, set_process_state,
        IssueDetail, StartRunParams,
    };
    use std::sync::Arc;

    #[cfg(unix)]
    use std::process::Stdio;

    #[cfg(unix)]
    use tokio::process::Command as TokioCommand;

    #[test]
    fn parse_issue_detail_returns_structured_data() {
        let detail = parse_issue_detail(
            r#"{
                "body": "Issue description",
                "comments": [
                    {
                        "id": "IC_kwDOA",
                        "author": { "login": "alice" },
                        "body": "first comment",
                        "createdAt": "2026-04-24T10:00:00Z"
                    }
                ]
            }"#,
        )
        .expect("issue detail should parse");

        assert_eq!(
            detail,
            IssueDetail {
                body: "Issue description".to_string(),
                comments: vec![super::GhComment {
                    id: "IC_kwDOA".to_string(),
                    author: super::GhCommentAuthor {
                        login: "alice".to_string(),
                    },
                    body: "first comment".to_string(),
                    created_at: "2026-04-24T10:00:00Z".to_string(),
                }],
            }
        );
    }

    #[test]
    fn parse_issue_detail_reports_invalid_json() {
        let error = parse_issue_detail("{invalid json").expect_err("invalid json should fail");

        assert!(error.contains("Failed to parse gh output"));
        assert!(error.contains("{invalid json"));
    }

    #[test]
    fn issue_detail_error_maps_missing_issue() {
        let error = map_issue_detail_command_error(
            27,
            "GraphQL: Could not resolve to an issue with the number of 27.",
        );

        assert_eq!(error, "Issue #27 not found");
    }

    #[test]
    fn issue_detail_error_preserves_other_gh_failures() {
        let error = map_issue_detail_command_error(27, "network timeout");

        assert_eq!(error, "gh issue view failed: network timeout");
    }

    #[test]
    fn get_issue_detail_rejects_non_directory_path() {
        let error = get_issue_detail_sync("/path/that/does/not/exist", 27)
            .expect_err("invalid path should fail");

        assert_eq!(error, "Path is not a directory: /path/that/does/not/exist");
    }

    #[test]
    fn build_run_args_keeps_flags_before_positionals() {
        let params = StartRunParams {
            issue_number: 28,
            max_iter: Some(3),
            agents: Some(vec!["alpha".to_string(), "beta".to_string()]),
            passing_score: Some(90),
            continue_mode: Some(true),
        };

        assert_eq!(
            build_run_args(&params),
            vec!["-c", "-a", "alpha,beta", "28", "3"]
        );
    }

    #[test]
    #[cfg(unix)]
    fn shared_process_state_stores_pid_and_handle() {
        let runtime = tokio::runtime::Runtime::new().expect("runtime should build");

        runtime.block_on(async {
            let child = TokioCommand::new("sh")
                .args(["-c", "exit 0"])
                .stdout(Stdio::null())
                .stderr(Stdio::null())
                .spawn()
                .expect("child should spawn");
            let pid = child.id().expect("child pid should exist");
            let handle = Arc::new(tokio::sync::Mutex::new(child));
            let process_state = new_process_state();

            set_process_state(&process_state, pid, Arc::clone(&handle))
                .expect("process state should store child handle");

            assert_eq!(current_process_pid(&process_state).unwrap(), Some(pid));
            let stored_handle = current_process_handle(&process_state)
                .unwrap()
                .expect("handle should be present");
            assert!(Arc::ptr_eq(&stored_handle, &handle));
            assert!(ensure_no_running_process(&process_state).is_err());

            let status = {
                let mut child = stored_handle.lock().await;
                child.wait().await.expect("wait should succeed")
            };

            assert!(status.success());
            clear_process_state_if_pid_matches(&process_state, pid);
            assert_eq!(current_process_pid(&process_state).unwrap(), None);
            assert!(ensure_no_running_process(&process_state).is_ok());
        });
    }
}

