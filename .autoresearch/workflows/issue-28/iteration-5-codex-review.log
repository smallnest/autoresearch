   474	#[cfg(unix)]
   475	fn start_run_unix(
   476	    run_sh: &Path,
   477	    args: &[String],
   478	    project_path: &str,
   479	    passing_score: Option<u32>,
   480	    app_handle: tauri::AppHandle,
   481	    process_state: SharedProcessState,
   482	) -> Result<(u32, ChildHandle), String> {
   483	    let mut cmd = TokioCommand::new(run_sh);
   484	    cmd.args(args)
   485	        .current_dir(project_path)
   486	        .stdout(Stdio::piped())
   487	        .stderr(Stdio::piped())
   488	        .kill_on_drop(false);
   489	
   490	    if let Some(score) = passing_score {
   491	        cmd.env("PASSING_SCORE", score.to_string());
   492	    }
   493	
   494	    unsafe {
   495	        cmd.pre_exec(|| {
   496	            nix::unistd::setpgid(nix::unistd::Pid::from_raw(0), nix::unistd::Pid::from_raw(0))
   497	                .map_err(io::Error::other)?;
   498	            Ok(())
   499	        });
   500	    }
   501	
   502	    let mut child = cmd
   503	        .spawn()
   504	        .map_err(|e| format!("Failed to spawn process: {e}"))?;
   505	    let pid = child.id().ok_or("Failed to get process ID")?;
   506	
   507	    let stdout = child.stdout.take().ok_or("Failed to capture stdout")?;
   508	    let stderr = child.stderr.take().ok_or("Failed to capture stderr")?;
   509	    let handle = Arc::new(tokio::sync::Mutex::new(child));
   510	
   511	    emit_run_output(app_handle.clone(), stdout);
   512	    emit_run_output(app_handle.clone(), stderr);
   513	    spawn_exit_watcher(process_state, Arc::clone(&handle), pid, app_handle);
   514	
   515	    Ok((pid, handle))
   516	}
