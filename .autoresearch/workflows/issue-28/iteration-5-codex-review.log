use std::fs;
use std::io;
use std::path::Path;
use std::process::{Command, Stdio};
use std::sync::{Arc, Mutex};

use tauri::Emitter;
use tokio::io::{AsyncBufReadExt, BufReader};
use tokio::process::{Child, Command as TokioCommand};

type ChildHandle = Arc<tokio::sync::Mutex<Child>>;
type SharedProcessState = Arc<Mutex<Option<ProcessState>>>;

/// Stores information about a running process.
struct ProcessState {
    /// Process ID (on Unix, this is the process group leader's PID).
    pid: u32,
    /// Shared handle used by async tasks that wait on or coordinate with the child.
    handle: ChildHandle,
}

/// Parameters for starting a run.sh process.
#[derive(serde::Deserialize, Debug)]
struct StartRunParams {
    issue_number: i64,
    #[serde(default)]
    max_iter: Option<u32>,
    #[serde(default)]
    agents: Option<Vec<String>>,
    #[serde(default)]
    passing_score: Option<u32>,
    #[serde(default)]
    continue_mode: Option<bool>,
}

/// Result of the start_run command.
#[derive(serde::Serialize)]
struct StartRunResult {
    pid: u32,
}

fn new_process_state() -> SharedProcessState {
    Arc::new(Mutex::new(None))
}

fn lock_process_state(
    process_state: &SharedProcessState,
) -> Result<std::sync::MutexGuard<'_, Option<ProcessState>>, String> {
    process_state
        .lock()
        .map_err(|e| format!("Failed to acquire lock: {e}"))
}

fn ensure_no_running_process(process_state: &SharedProcessState) -> Result<(), String> {
    if lock_process_state(process_state)?.is_some() {
        return Err("A process is already running. Stop it first.".to_string());
    }

    Ok(())
}

fn set_process_state(
    process_state: &SharedProcessState,
    pid: u32,
    handle: ChildHandle,
) -> Result<(), String> {
    *lock_process_state(process_state)? = Some(ProcessState { pid, handle });
    Ok(())
}

fn clear_process_state_if_pid_matches(process_state: &SharedProcessState, pid: u32) {
    if let Ok(mut state) = process_state.lock() {
        let should_clear = state.as_ref().map(|running| running.pid) == Some(pid);
        if should_clear {
            *state = None;
        }
    }
}

fn current_process_pid(process_state: &SharedProcessState) -> Result<Option<u32>, String> {
    Ok(lock_process_state(process_state)?
        .as_ref()
        .map(|state| state.pid))
}

fn current_process_handle(
    process_state: &SharedProcessState,
) -> Result<Option<ChildHandle>, String> {
    Ok(lock_process_state(process_state)?
        .as_ref()
        .map(|state| Arc::clone(&state.handle)))
}

fn build_run_args(params: &StartRunParams) -> Vec<String> {
    let mut args = Vec::new();

    if params.continue_mode.unwrap_or(false) {
        args.push("-c".to_string());
    }

    if let Some(agents) = &params.agents {
        if !agents.is_empty() {
            args.push("-a".to_string());
            args.push(agents.join(","));
        }
    }

    args.push(params.issue_number.to_string());

    if let Some(max_iter) = params.max_iter {
        args.push(max_iter.to_string());
    }

    args
}

fn emit_run_output(
    app_handle: tauri::AppHandle,
    stream: impl tokio::io::AsyncRead + Unpin + Send + 'static,
) {
    tokio::spawn(async move {
        let mut lines = BufReader::new(stream).lines();
        loop {
            match lines.next_line().await {
                Ok(Some(line)) => {
                    if let Err(e) = app_handle.emit("run-output", &line) {
                        eprintln!("Failed to emit run output event: {e}");
                        break;
                    }
                }
                Ok(None) => break,
                Err(e) => {
                    eprintln!("Failed to read process output: {e}");
                    break;
                }
            }
        }
    });
}

fn spawn_exit_watcher(
    process_state: SharedProcessState,
    handle: ChildHandle,
    pid: u32,
    app_handle: tauri::AppHandle,
) {
    tokio::spawn(async move {
        let status = {
            let mut child = handle.lock().await;
            child.wait().await
        };

        clear_process_state_if_pid_matches(&process_state, pid);

        match status {
            Ok(exit_status) => {
                let code = exit_status.code().unwrap_or(-1);
                if let Err(e) = app_handle.emit("run-exit", code) {
                    eprintln!("Failed to emit exit event: {e}");
                }
            }
            Err(e) => {
                eprintln!("Failed to wait for process: {e}");
                if let Err(emit_err) = app_handle.emit("run-exit", -1) {
                    eprintln!("Failed to emit exit event: {emit_err}");
                }
            }
        }
    });
}

/// Configuration detection result for a project directory.
#[derive(serde::Serialize)]
struct ProjectConfig {
    has_autoresearch_dir: bool,
    has_program_md: bool,
    has_agents_dir: bool,
}

/// A label attached to a GitHub Issue.
#[derive(serde::Serialize, serde::Deserialize, Debug, Clone)]
struct GhLabel {
    name: String,
    color: String,
}

/// A GitHub Issue returned by `gh issue list`.
#[derive(serde::Serialize, serde::Deserialize, Debug, Clone)]
struct GhIssue {
    number: i64,
    title: String,
    labels: Vec<GhLabel>,
    #[serde(rename = "createdAt")]
    created_at: String,
    state: String,
}

/// Author information for a GitHub comment.
#[derive(serde::Serialize, serde::Deserialize, Debug, Clone, PartialEq, Eq)]
struct GhCommentAuthor {
    login: String,
}

/// A comment on a GitHub Issue.
#[derive(serde::Serialize, serde::Deserialize, Debug, Clone, PartialEq, Eq)]
struct GhComment {
    id: String,
    author: GhCommentAuthor,
    body: String,
    #[serde(rename = "createdAt")]
    created_at: String,
}

/// Detailed information about a GitHub Issue.
#[derive(serde::Serialize, serde::Deserialize, Debug, PartialEq, Eq)]
struct IssueDetail {
    body: String,
    comments: Vec<GhComment>,
}

/// Result for the list_issues command, including processed status info.
#[derive(serde::Serialize)]
struct IssuesResult {
    issues: Vec<GhIssue>,
    processed_numbers: Vec<i64>,
}

