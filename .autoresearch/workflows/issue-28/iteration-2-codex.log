    94	fn build_run_args(params: &StartRunParams) -> Vec<String> {
    95	    let mut args = Vec::new();
    96	
    97	    if params.continue_mode.unwrap_or(false) {
    98	        args.push("-c".to_string());
    99	    }
   100	
   101	    if let Some(agents) = &params.agents {
   102	        if !agents.is_empty() {
   103	            args.push("-a".to_string());
   104	            args.push(agents.join(","));
   105	        }
   106	    }
   107	
   108	    args.push(params.issue_number.to_string());
   109	
   110	    if let Some(max_iter) = params.max_iter {
   111	        args.push(max_iter.to_string());
   112	    }
   113	
   114	    args
   115	}
