use std::process::{Command, Stdio};
use std::sync::Mutex;

use tauri::Emitter;

#[cfg(unix)]
use std::os::unix::process::CommandExt;

/// Global process state manager for tracking the currently running run.sh process.
static PROCESS_STATE: Mutex<Option<ProcessState>> = Mutex::new(None);

/// Stores information about a running process.
#[derive(Debug)]
struct ProcessState {
    /// Process ID (on Unix, this is the process group leader's PID).
    pid: u32,
}

/// Parameters for starting a run.sh process.
#[derive(serde::Deserialize, Debug)]
struct StartRunParams {
    issue_number: i64,
    #[serde(default)]
    max_iter: Option<u32>,
    #[serde(default)]
    agents: Option<Vec<String>>,
    #[serde(default)]
    passing_score: Option<u32>,
    #[serde(default)]
    continue_mode: Option<bool>,
}

/// Result of the start_run command.
#[derive(serde::Serialize)]
struct StartRunResult {
    pid: u32,
}

/// Configuration detection result for a project directory.
#[derive(serde::Serialize)]
struct ProjectConfig {
    has_autoresearch_dir: bool,
    has_program_md: bool,
    has_agents_dir: bool,
}

/// A label attached to a GitHub Issue.
