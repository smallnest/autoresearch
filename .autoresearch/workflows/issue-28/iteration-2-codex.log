/// # Arguments
/// * `project_path` - Path to the autoresearch project directory
/// * `params` - Parameters for the run (issue number, max iterations, etc.)
///
/// # Returns
/// The process ID of the started process.
///
/// # Errors
/// Returns an error if a process is already running or if the process fails to start.
#[tauri::command]
async fn start_run(
    app: tauri::AppHandle,
    project_path: String,
    params: StartRunParams,
) -> Result<StartRunResult, String> {
    // Check if a process is already running
    {
        let state = PROCESS_STATE
            .lock()
            .map_err(|e| format!("Failed to acquire lock: {e}"))?;
        if state.is_some() {
            return Err("A process is already running. Stop it first.".to_string());
        }
    }

    // Verify project path exists
    let base = Path::new(&project_path);
    if !base.is_dir() {
        return Err(format!("Path is not a directory: {project_path}"));
    }

    // Build the run.sh command arguments
    let run_sh = base.join("run.sh");
    if !run_sh.exists() {
        return Err(format!("run.sh not found at: {}", run_sh.display()));
    }

    let mut args: Vec<String> = Vec::new();

    // Add -c flag for continue mode
    if params.continue_mode.unwrap_or(false) {
        args.push("-c".to_string());
    }

    // Add -a flag for agents
    if let Some(agents) = &params.agents {
        if !agents.is_empty() {
            args.push("-a".to_string());
            args.push(agents.join(","));
        }
    }

    // Add issue number (required)
    args.push(params.issue_number.to_string());

    // Add max iterations (optional, must come after issue number)
    if let Some(max_iter) = params.max_iter {
        args.push(max_iter.to_string());
    }

    // Note: passing_score is passed via environment variable PASSING_SCORE
    let passing_score = params.passing_score;

    // Start the process with a new process group
    let app_handle = app.clone();

    #[cfg(unix)]
    let pid = start_run_unix(&run_sh, &args, &project_path, passing_score, app_handle)?;

    #[cfg(not(unix))]
    let pid = start_run_windows(&run_sh, &args, &project_path, passing_score, app_handle)?;

    // Store the process state
    {
        let mut state = PROCESS_STATE
            .lock()
            .map_err(|e| format!("Failed to acquire lock: {e}"))?;
        *state = Some(ProcessState { pid });
    }

    Ok(StartRunResult { pid })
}

#[cfg(unix)]
fn start_run_unix(
    run_sh: &Path,
    args: &[String],
    project_path: &str,
    passing_score: Option<u32>,
    app_handle: tauri::AppHandle,
) -> Result<u32, String> {
    use std::process::Command as StdCommand;

    let run_sh_str = run_sh.to_string_lossy().to_string();
    let args_owned: Vec<String> = args.to_vec();
    let project_path_owned = project_path.to_string();

    // Use std::process::Command for the process_group setup
    let mut cmd = StdCommand::new(&run_sh_str);
    cmd.args(&args_owned)
        .current_dir(&project_path_owned)
        .stdout(Stdio::piped())
        .stderr(Stdio::piped());

    // Set passing_score environment variable if provided
    if let Some(score) = passing_score {
        cmd.env("PASSING_SCORE", score.to_string());
    }

    // Set process group on Unix (process_group(0) makes the process its own group leader)
    cmd.process_group(0);

    // Spawn the process
    let mut child = cmd
        .spawn()
        .map_err(|e| format!("Failed to spawn process: {e}"))?;
    let pid = child.id();

    // Take stdout and stderr pipes
    let stdout = child.stdout.take().ok_or("Failed to capture stdout")?;
    let stderr = child.stderr.take().ok_or("Failed to capture stderr")?;

    // Spawn tasks to read stdout/stderr and emit events
    let app_out = app_handle.clone();
    tokio::spawn(async move {
        let reader = BufReader::new(stdout);
        for line in reader.lines().map_while(Result::ok) {
            if let Err(e) = app_out.emit("run-output", &line) {
                eprintln!("Failed to emit stdout event: {e}");
                break;
            }
        }
    });

    let app_err = app_handle.clone();
    tokio::spawn(async move {
        let reader = BufReader::new(stderr);
        for line in reader.lines().map_while(Result::ok) {
            if let Err(e) = app_err.emit("run-output", &line) {
                eprintln!("Failed to emit stderr event: {e}");
                break;
            }
        }
    });

    // Wait for process to exit and emit run-exit event
    // Use spawn_blocking since std::process::Child::wait is blocking
    let app_exit = app_handle.clone();
    tokio::task::spawn_blocking(move || {
        let status = child.wait();
        // Clear process state
        if let Ok(mut state) = PROCESS_STATE.lock() {
            *state = None;
        }
        // Emit exit event
        match status {
            Ok(exit_status) => {
                let code = exit_status.code().unwrap_or(-1);
                if let Err(e) = app_exit.emit("run-exit", code) {
                    eprintln!("Failed to emit exit event: {e}");
                }
            }
            Err(e) => {
                eprintln!("Failed to wait for process: {e}");
                if let Err(emit_err) = app_exit.emit("run-exit", -1) {
                    eprintln!("Failed to emit exit event: {emit_err}");
                }
            }
        }
    });

    Ok(pid)
}

#[cfg(not(unix))]
fn start_run_windows(
    run_sh: &Path,
    args: &[String],
    project_path: &str,
    passing_score: Option<u32>,
    app_handle: tauri::AppHandle,
) -> Result<u32, String> {
    // On Windows, we use tokio::process::Command directly
    // Process group management is more complex on Windows and would require job objects
    use tokio::process::Command as TokioCommand;

    let run_sh_str = run_sh.to_string_lossy().to_string();
    let args_owned: Vec<String> = args.to_vec();
    let project_path_owned = project_path.to_string();

    let mut cmd = TokioCommand::new(&run_sh_str);
    cmd.args(&args_owned)
        .current_dir(&project_path_owned)
        .stdout(Stdio::piped())
        .stderr(Stdio::piped())
        .kill_on_drop(true);

    // Set passing_score environment variable if provided
    if let Some(score) = passing_score {
        cmd.env("PASSING_SCORE", score.to_string());
    }

    let mut child = cmd
        .spawn()
        .map_err(|e| format!("Failed to spawn process: {e}"))?;
    let pid = child.id().ok_or("Failed to get process ID")?;

    // Take stdout and stderr pipes
    let stdout = child.stdout.take().ok_or("Failed to capture stdout")?;
    let stderr = child.stderr.take().ok_or("Failed to capture stderr")?;

    // Spawn tasks to read stdout/stderr and emit events
    let app_out = app_handle.clone();
    tokio::spawn(async move {
        let reader = BufReader::new(stdout);
        for line in reader.lines().map_while(Result::ok) {
            if let Err(e) = app_out.emit("run-output", &line) {
                eprintln!("Failed to emit stdout event: {e}");
                break;
            }
        }
    });

    let app_err = app_handle.clone();
    tokio::spawn(async move {
        let reader = BufReader::new(stderr);
        for line in reader.lines().map_while(Result::ok) {
            if let Err(e) = app_err.emit("run-output", &line) {
                eprintln!("Failed to emit stderr event: {e}");
                break;
            }
        }
    });

    // Wait for process to exit and emit run-exit event
    let app_exit = app_handle.clone();
    tokio::spawn(async move {
        let status = child.wait().await;
        // Clear process state
        if let Ok(mut state) = PROCESS_STATE.lock() {
            *state = None;
        }
        // Emit exit event
        match status {
            Ok(exit_status) => {
                let code = exit_status.code().unwrap_or(-1);
                if let Err(e) = app_exit.emit("run-exit", code) {
                    eprintln!("Failed to emit exit event: {e}");
                }
            }
            Err(e) => {
                eprintln!("Failed to wait for process: {e}");
                if let Err(emit_err) = app_exit.emit("run-exit", -1) {
                    eprintln!("Failed to emit exit event: {emit_err}");
                }
            }
        }
    });

    Ok(pid)
}

/// Stops the currently running run.sh process.
///
/// # Returns
/// `true` if a process was stopped, `false` if no process was running.
///
/// # Errors
/// Returns an error if the lock cannot be acquired or the kill operation fails.
#[tauri::command]
async fn stop_run() -> Result<bool, String> {
    let pid = {
        let state = PROCESS_STATE
            .lock()
            .map_err(|e| format!("Failed to acquire lock: {e}"))?;
        state.as_ref().map(|ps| ps.pid)
    };

    let Some(pid) = pid else {
        return Ok(false);
    };

    #[cfg(unix)]
    {
        use nix::sys::signal::{kill, Signal};
        use nix::unistd::Pid;

        // Kill the entire process group
        let pgid = Pid::from_raw(pid as i32);
        kill(pgid, Signal::SIGTERM).map_err(|e| format!("Failed to send SIGTERM: {e}"))?;

        // Clear process state
        let mut state = PROCESS_STATE
            .lock()
            .map_err(|e| format!("Failed to acquire lock: {e}"))?;
        *state = None;
    }

    #[cfg(not(unix))]
    {
        // On Windows, we would need to use job objects or taskkill
        // For now, return an error indicating this is not implemented
        return Err("Process termination is not fully implemented on Windows. Please manually terminate the process.".to_string());
    }

    Ok(true)
}

/// Checks if a run.sh process is currently running.
#[tauri::command]
fn is_run_active() -> bool {
    PROCESS_STATE.lock().map(|s| s.is_some()).unwrap_or(false)
}

#[cfg_attr(mobile, tauri::mobile_entry_point)]
pub fn run() {
    tauri::Builder::default()
        .plugin(tauri_plugin_opener::init())
        .plugin(tauri_plugin_dialog::init())
        .plugin(tauri_plugin_store::Builder::default().build())
        .invoke_handler(tauri::generate_handler![
            select_project_dir,
            detect_project_config,
            get_recent_project,
            save_recent_project,
            list_issues,
            check_processed_issues,
            get_issue_detail,
            start_run,
            stop_run,
            is_run_active,
        ])
        .run(tauri::generate_context!())
        .expect("error while running tauri application");
}

