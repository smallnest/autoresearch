   117	fn emit_run_output(
   118	    app_handle: tauri::AppHandle,
   119	    stream: impl tokio::io::AsyncRead + Unpin + Send + 'static,
   120	) {
   121	    tokio::spawn(async move {
   122	        let mut lines = BufReader::new(stream).lines();
   123	        loop {
   124	            match lines.next_line().await {
   125	                Ok(Some(line)) => {
   126	                    if let Err(e) = app_handle.emit("run-output", &line) {
   127	                        eprintln!("Failed to emit run output event: {e}");
   128	                        break;
   129	                    }
   130	                }
   131	                Ok(None) => break,
   132	                Err(e) => {
   133	                    eprintln!("Failed to read process output: {e}");
   134	                    break;
   135	                }
   136	            }
   137	        }
   138	    });
   139	}
   140	
   141	fn spawn_exit_watcher(
   142	    process_state: SharedProcessState,
   143	    handle: ChildHandle,
   144	    pid: u32,
   145	    app_handle: tauri::AppHandle,
   146	) {
   147	    tokio::spawn(async move {
   148	        let status = {
   149	            let mut child = handle.lock().await;
   150	            child.wait().await
   151	        };
   152	
   153	        clear_process_state_if_pid_matches(&process_state, pid);
   154	
   155	        match status {
   156	            Ok(exit_status) => {
   157	                let code = exit_status.code().unwrap_or(-1);
   158	                if let Err(e) = app_handle.emit("run-exit", code) {
   159	                    eprintln!("Failed to emit exit event: {e}");
   160	                }
   161	            }
   162	            Err(e) => {
   163	                eprintln!("Failed to wait for process: {e}");
   164	                if let Err(emit_err) = app_handle.emit("run-exit", -1) {
   165	                    eprintln!("Failed to emit exit event: {emit_err}");
   166	                }
   167	            }
   168	        }
   169	    });
   170	}
