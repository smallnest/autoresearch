+type ChildHandle = Arc<tokio::sync::Mutex<Child>>;
+type SharedProcessState = Arc<Mutex<Option<ProcessState>>>;
 
 /// Stores information about a running process.
-#[derive(Debug)]
 struct ProcessState {
