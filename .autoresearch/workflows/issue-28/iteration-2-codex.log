+fn new_process_state() -> SharedProcessState {
+    Arc::new(Mutex::new(None))
+}
+
+fn lock_process_state(
+    process_state: &SharedProcessState,
+) -> Result<std::sync::MutexGuard<'_, Option<ProcessState>>, String> {
+    process_state
+        .lock()
+        .map_err(|e| format!("Failed to acquire lock: {e}"))
+}
+
+fn ensure_no_running_process(process_state: &SharedProcessState) -> Result<(), String> {
+    if lock_process_state(process_state)?.is_some() {
+        return Err("A process is already running. Stop it first.".to_string());
+    }
+
+    Ok(())
+}
+
+fn set_process_state(
+    process_state: &SharedProcessState,
+    pid: u32,
+    handle: ChildHandle,
+) -> Result<(), String> {
+    *lock_process_state(process_state)? = Some(ProcessState { pid, handle });
+    Ok(())
+}
+
+fn clear_process_state_if_pid_matches(process_state: &SharedProcessState, pid: u32) {
+    if let Ok(mut state) = process_state.lock() {
+        let should_clear = state.as_ref().map(|running| running.pid) == Some(pid);
+        if should_clear {
+            *state = None;
+        }
+    }
+}
+
+fn current_process_pid(process_state: &SharedProcessState) -> Result<Option<u32>, String> {
+    Ok(lock_process_state(process_state)?
+        .as_ref()
+        .map(|state| state.pid))
+}
+
+fn current_process_handle(
+    process_state: &SharedProcessState,
+) -> Result<Option<ChildHandle>, String> {
+    Ok(lock_process_state(process_state)?
+        .as_ref()
+        .map(|state| Arc::clone(&state.handle)))
+}
+
+fn build_run_args(params: &StartRunParams) -> Vec<String> {
+    let mut args = Vec::new();
+
+    if params.continue_mode.unwrap_or(false) {
+        args.push("-c".to_string());
+    }
+
+    if let Some(agents) = &params.agents {
+        if !agents.is_empty() {
+            args.push("-a".to_string());
+            args.push(agents.join(","));
+        }
+    }
+
+    args.push(params.issue_number.to_string());
+
+    if let Some(max_iter) = params.max_iter {
+        args.push(max_iter.to_string());
+    }
+
+    args
+}
+
+fn emit_run_output(
+    app_handle: tauri::AppHandle,
+    stream: impl tokio::io::AsyncRead + Unpin + Send + 'static,
+) {
+    tokio::spawn(async move {
+        let mut lines = BufReader::new(stream).lines();
+        loop {
+            match lines.next_line().await {
+                Ok(Some(line)) => {
+                    if let Err(e) = app_handle.emit("run-output", &line) {
+                        eprintln!("Failed to emit run output event: {e}");
+                        break;
+                    }
+                }
+                Ok(None) => break,
+                Err(e) => {
+                    eprintln!("Failed to read process output: {e}");
+                    break;
+                }
+            }
+        }
+    });
+}
+
+fn spawn_exit_watcher(
+    process_state: SharedProcessState,
+    handle: ChildHandle,
+    pid: u32,
+    app_handle: tauri::AppHandle,
+) {
+    tokio::spawn(async move {
+        let status = {
+            let mut child = handle.lock().await;
+            child.wait().await
+        };
+
+        clear_process_state_if_pid_matches(&process_state, pid);
+
+        match status {
+            Ok(exit_status) => {
+                let code = exit_status.code().unwrap_or(-1);
+                if let Err(e) = app_handle.emit("run-exit", code) {
+                    eprintln!("Failed to emit exit event: {e}");
+                }
+            }
+            Err(e) => {
+                eprintln!("Failed to wait for process: {e}");
+                if let Err(emit_err) = app_handle.emit("run-exit", -1) {
+                    eprintln!("Failed to emit exit event: {emit_err}");
+                }
+            }
+        }
+    });
+}
