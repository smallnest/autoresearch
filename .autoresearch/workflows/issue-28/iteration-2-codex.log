+/// Starts a run.sh process with the given parameters.
+///
+/// # Arguments
+/// * `project_path` - Path to the autoresearch project directory
+/// * `params` - Parameters for the run (issue number, max iterations, etc.)
+///
+/// # Returns
+/// The process ID of the started process.
+///
+/// # Errors
+/// Returns an error if a process is already running or if the process fails to start.
+#[tauri::command]
+async fn start_run(
+    app: tauri::AppHandle,
+    process_state: tauri::State<'_, SharedProcessState>,
+    project_path: String,
+    params: StartRunParams,
+) -> Result<StartRunResult, String> {
+    let process_state = process_state.inner().clone();
+    ensure_no_running_process(&process_state)?;
+
+    // Verify project path exists
+    let base = Path::new(&project_path);
+    if !base.is_dir() {
+        return Err(format!("Path is not a directory: {project_path}"));
+    }
+
+    // Build the run.sh command arguments
+    let run_sh = base.join("run.sh");
+    if !run_sh.exists() {
+        return Err(format!("run.sh not found at: {}", run_sh.display()));
+    }
+
+    let args = build_run_args(&params);
+
+    // Note: passing_score is passed via environment variable PASSING_SCORE
+    let passing_score = params.passing_score;
+
+    // Start the process with a new process group
+    let app_handle = app.clone();
+
+    #[cfg(unix)]
+    let (pid, handle) = start_run_unix(
+        &run_sh,
+        &args,
+        &project_path,
+        passing_score,
+        app_handle,
+        process_state.clone(),
+    )?;
+
+    #[cfg(not(unix))]
+    let (pid, handle) = start_run_windows(
+        &run_sh,
+        &args,
+        &project_path,
+        passing_score,
+        app_handle,
+        process_state.clone(),
+    )?;
+
+    set_process_state(&process_state, pid, handle)?;
+
+    Ok(StartRunResult { pid })
+}
+
+#[cfg(unix)]
+fn start_run_unix(
+    run_sh: &Path,
+    args: &[String],
+    project_path: &str,
+    passing_score: Option<u32>,
+    app_handle: tauri::AppHandle,
+    process_state: SharedProcessState,
+) -> Result<(u32, ChildHandle), String> {
+    let mut cmd = TokioCommand::new(run_sh);
+    cmd.args(args)
+        .current_dir(project_path)
+        .stdout(Stdio::piped())
+        .stderr(Stdio::piped())
+        .kill_on_drop(false);
+
+    if let Some(score) = passing_score {
+        cmd.env("PASSING_SCORE", score.to_string());
+    }
+
+    unsafe {
+        cmd.pre_exec(|| {
+            nix::unistd::setpgid(nix::unistd::Pid::from_raw(0), nix::unistd::Pid::from_raw(0))
+                .map_err(io::Error::other)?;
+            Ok(())
+        });
+    }
+
+    let mut child = cmd
+        .spawn()
+        .map_err(|e| format!("Failed to spawn process: {e}"))?;
+    let pid = child.id().ok_or("Failed to get process ID")?;
+
+    let stdout = child.stdout.take().ok_or("Failed to capture stdout")?;
+    let stderr = child.stderr.take().ok_or("Failed to capture stderr")?;
+    let handle = Arc::new(tokio::sync::Mutex::new(child));
+
+    emit_run_output(app_handle.clone(), stdout);
+    emit_run_output(app_handle.clone(), stderr);
+    spawn_exit_watcher(process_state, Arc::clone(&handle), pid, app_handle);
+
+    Ok((pid, handle))
+}
+
+#[cfg(not(unix))]
+fn start_run_windows(
+    run_sh: &Path,
+    args: &[String],
+    project_path: &str,
+    passing_score: Option<u32>,
+    app_handle: tauri::AppHandle,
+    process_state: SharedProcessState,
+) -> Result<(u32, ChildHandle), String> {
+    let mut cmd = TokioCommand::new(run_sh);
+    cmd.args(args)
+        .current_dir(project_path)
+        .stdout(Stdio::piped())
+        .stderr(Stdio::piped())
+        .kill_on_drop(true);
+
+    if let Some(score) = passing_score {
+        cmd.env("PASSING_SCORE", score.to_string());
+    }
+
+    let mut child = cmd
+        .spawn()
+        .map_err(|e| format!("Failed to spawn process: {e}"))?;
+    let pid = child.id().ok_or("Failed to get process ID")?;
+
+    let stdout = child.stdout.take().ok_or("Failed to capture stdout")?;
+    let stderr = child.stderr.take().ok_or("Failed to capture stderr")?;
+    let handle = Arc::new(tokio::sync::Mutex::new(child));
+
+    emit_run_output(app_handle.clone(), stdout);
+    emit_run_output(app_handle.clone(), stderr);
+    spawn_exit_watcher(process_state, Arc::clone(&handle), pid, app_handle);
+
+    Ok((pid, handle))
+}
