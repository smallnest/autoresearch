    case 'stopping':
      return 'border-amber-200 bg-amber-50 text-amber-700';
    case 'finished':
      return 'border-slate-200 bg-slate-100 text-slate-700';
    case 'error':
      return 'border-red-200 bg-red-50 text-red-700';
    case 'idle':
