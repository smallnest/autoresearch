+                "comments": [
+                    {
+                        "id": "IC_kwDOA",
+                        "author": { "login": "alice" },
+                        "body": "first comment",
+                        "createdAt": "2026-04-24T10:00:00Z"
+                    }
+                ]
+            }"#,
+        )
