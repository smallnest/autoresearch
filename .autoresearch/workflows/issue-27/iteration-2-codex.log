   105	/// Scans `.autoresearch/workflows/issue-*` directories and returns Issue numbers that have been processed.
   106	fn get_processed_issue_numbers(project_path: &Path) -> Result<Vec<i64>, String> {
   107	    let workflows_dir = project_path.join(".autoresearch").join("workflows");
   108	    if !workflows_dir.is_dir() {
   109	        return Ok(Vec::new());
   110	    }
   111	    let mut numbers = Vec::new();
   112	    let entries = fs::read_dir(&workflows_dir)
   113	        .map_err(|e| format!("Failed to read workflows dir: {e}"))?;
   114	    for entry in entries.flatten() {
   115	        let name = entry.file_name();
   116	        let name_str = name.to_string_lossy();
   117	        if let Some(suffix) = name_str.strip_prefix("issue-") {
   118	            if let Ok(num) = suffix.parse::<i64>() {
   119	                numbers.push(num);
   120	            }
   121	        }
   122	    }
   123	    numbers.sort();
   124	    Ok(numbers)
   125	}
