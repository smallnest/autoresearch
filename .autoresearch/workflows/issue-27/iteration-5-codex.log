   128	    if (fenceMatch) {
   129	      index += 1;
   130	      const codeLines: string[] = [];
   131	      while (index < lines.length && !lines[index].startsWith('```')) {
   132	        codeLines.push(lines[index]);
   133	        index += 1;
   134	      }
   135	      index += 1;
   136	
   137	      const language = fenceMatch[1] || 'text';
   138	      blocks.push(
   139	        `<pre><code class="language-${escapeHtml(language)}">${highlightCode(
   140	          codeLines.join('\n'),
   141	          language
   142	        )}</code></pre>`
   143	      );
   144	      continue;
   145	    }
   146	
   147	    const headingMatch = line.match(/^(#{1,6})\s+(.+)$/);
   148	    if (headingMatch) {
   149	      const level = headingMatch[1].length;
   150	      blocks.push(`<h${level}>${parseInline(headingMatch[2])}</h${level}>`);
   151	      index += 1;
   152	      continue;
   153	    }
   154	
   155	    if (line.startsWith('> ')) {
   156	      const quoteLines: string[] = [];
   157	      while (index < lines.length && lines[index].startsWith('> ')) {
   158	        quoteLines.push(lines[index].slice(2));
   159	        index += 1;
   160	      }
   161	      blocks.push(`<blockquote>${parseParagraph(quoteLines)}</blockquote>`);
   162	      continue;
   163	    }
   164	
   165	    if (/^[-*+]\s+/.test(line)) {
   166	      const items: string[] = [];
   167	      while (index < lines.length && /^[-*+]\s+/.test(lines[index])) {
   168	        items.push(`<li>${parseInline(lines[index].replace(/^[-*+]\s+/, ''))}</li>`);
   169	        index += 1;
   170	      }
   171	      blocks.push(`<ul>${items.join('')}</ul>`);
   172	      continue;
   173	    }
   174	
   175	    if (/^\d+\.\s+/.test(line)) {
   176	      const items: string[] = [];
   177	      while (index < lines.length && /^\d+\.\s+/.test(lines[index])) {
   178	        items.push(
   179	          `<li>${parseInline(lines[index].replace(/^\d+\.\s+/, ''))}</li>`
   180	        );
   181	        index += 1;
   182	      }
   183	      blocks.push(`<ol>${items.join('')}</ol>`);
   184	      continue;
   185	    }
   186	
   187	    const paragraphLines: string[] = [];
   188	    while (
   189	      index < lines.length &&
   190	      lines[index].trim() &&
   191	      !lines[index].startsWith('```') &&
   192	      !lines[index].startsWith('> ') &&
   193	      !/^[-*+]\s+/.test(lines[index]) &&
   194	      !/^\d+\.\s+/.test(lines[index]) &&
   195	      !/^(#{1,6})\s+/.test(lines[index])
   196	    ) {
   197	      paragraphLines.push(lines[index]);
   198	      index += 1;
   199	    }
   200	
   201	    blocks.push(parseParagraph(paragraphLines));
   202	  }
   203	
   204	  return blocks.join('');
   205	}
