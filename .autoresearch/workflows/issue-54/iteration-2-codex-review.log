log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    if [ -n "$WORK_DIR" ] && [ -d "$WORK_DIR" ]; then
        echo "$msg" >> "$WORK_DIR/terminal.log"
