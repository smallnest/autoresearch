# Test 4: Threshold of 0 should always pass
test_threshold_zero() {
    echo "--- test_threshold_zero ---"
    : > "$TEST_LOG"
    DISK_MIN_MB=0 check_disk_space
    local result=$?

    assert_eq "threshold 0 returns 0 (always pass)" "0" "$result"
}

