kill() {
    if [ "$USE_MOCK_TREE" -eq 1 ]; then
        local signal=""
        local pid=""

        case "$1" in
            -0|-9)
                signal="$1"
                pid="$2"
                ;;
            *)
                pid="$1"
                ;;
        esac

        if [ -z "$pid" ]; then
            return 1
        fi

        if printf '%s\n' "$MOCK_ALIVE_PIDS" | grep -Fxq "$pid"; then
            if [ "$signal" != "-0" ]; then
                MOCK_ALIVE_PIDS=$(printf '%s\n' "$MOCK_ALIVE_PIDS" | grep -Fxv "$pid" || true)
                KILL_LOG="${KILL_LOG}${signal:-TERM}:$pid"$'\n'
            fi
            return 0
        fi

        return 1
    fi

    builtin kill "$@"
}

