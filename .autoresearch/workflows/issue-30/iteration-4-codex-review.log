   267	fn workflow_issue_dir(project_path: &str, issue_number: i64) -> Result<std::path::PathBuf, String> {
   268	    let base = Path::new(project_path);
   269	    if !base.is_dir() {
   270	        return Err(format!("Path is not a directory: {project_path}"));
   271	    }
   272	
   273	    let issue_dir = base
   274	        .join(".autoresearch")
   275	        .join("workflows")
   276	        .join(format!("issue-{issue_number}"));
   277	
   278	    if !issue_dir.is_dir() {
   279	        return Err(format!("Workflow logs for Issue #{issue_number} not found"));
   280	    }
   281	
   282	    Ok(issue_dir)
   283	}
