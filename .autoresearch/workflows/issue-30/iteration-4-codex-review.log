   285	fn classify_log_source(filename: &str) -> (&'static str, String) {
   286	    match filename {
   287	        "terminal.log" => ("terminal", "终端日志".to_string()),
   288	        "log.md" => ("summary", "工作流摘要".to_string()),
   289	        _ if filename.starts_with("iteration-") => ("iteration", filename.to_string()),
   290	        _ => ("file", filename.to_string()),
   291	    }
   292	}
   293	
   294	fn iteration_number(filename: &str) -> Option<i32> {
   295	    filename
   296	        .strip_prefix("iteration-")
   297	        .and_then(|rest| rest.split('-').next())
   298	        .and_then(|value| value.parse::<i32>().ok())
   299	}
   300	
   301	fn sort_log_sources(left: &IssueLogSource, right: &IssueLogSource) -> std::cmp::Ordering {
   302	    fn rank(kind: &str) -> i32 {
   303	        match kind {
   304	            "terminal" => 0,
   305	            "summary" => 1,
   306	            "iteration" => 2,
   307	            _ => 3,
   308	        }
   309	    }
   310	
   311	    rank(&left.kind)
   312	        .cmp(&rank(&right.kind))
   313	        .then_with(|| match (left.kind.as_str(), right.kind.as_str()) {
   314	            ("iteration", "iteration") => iteration_number(&left.id)
   315	                .cmp(&iteration_number(&right.id))
   316	                .then_with(|| left.label.cmp(&right.label)),
   317	            _ => std::cmp::Ordering::Equal,
   318	        })
   319	        .then_with(|| left.label.cmp(&right.label))
   320	}
   321	
   322	fn file_timestamp(metadata: &fs::Metadata) -> Option<String> {
   323	    metadata
   324	        .modified()
   325	        .ok()
   326	        .and_then(|time| time.duration_since(UNIX_EPOCH).ok())
   327	        .map(|duration| duration.as_secs().to_string())
   328	}
   329	
   330	fn list_issue_log_sources_sync(project_path: &str, issue_number: i64) -> Result<Vec<IssueLogSource>, String> {
   331	    let issue_dir = workflow_issue_dir(project_path, issue_number)?;
   332	    let entries = fs::read_dir(&issue_dir)
   333	        .map_err(|e| format!("Failed to read workflow dir: {e}"))?;
   334	
   335	    let mut sources = Vec::new();
   336	    for entry in entries {
   337	        let entry = entry.map_err(|e| format!("Failed to read workflow entry: {e}"))?;
   338	        let path = entry.path();
   339	        if !path.is_file() {
   340	            continue;
   341	        }
   342	
   343	        let filename = entry.file_name().to_string_lossy().to_string();
   344	        let metadata = entry
   345	            .metadata()
   346	            .map_err(|e| format!("Failed to read metadata for {filename}: {e}"))?;
   347	        let (kind, label) = classify_log_source(&filename);
   348	
   349	        sources.push(IssueLogSource {
   350	            id: filename,
   351	            label,
   352	            kind: kind.to_string(),
   353	            updated_at: file_timestamp(&metadata),
   354	            size_bytes: metadata.len(),
   355	        });
   356	    }
   357	
   358	    sources.sort_by(sort_log_sources);
   359	    Ok(sources)
   360	}
   361	
   362	fn resolve_issue_log_source_path(
   363	    project_path: &str,
   364	    issue_number: i64,
   365	    source_id: &str,
   366	) -> Result<std::path::PathBuf, String> {
   367	    if source_id.is_empty()
   368	        || source_id.contains('/')
   369	        || source_id.contains('\\')
   370	        || source_id == "."
   371	        || source_id == ".."
   372	    {
   373	        return Err(format!("Invalid log source id: {source_id}"));
   374	    }
   375	
   376	    let issue_dir = workflow_issue_dir(project_path, issue_number)?;
   377	    let path = issue_dir.join(source_id);
   378	    if !path.is_file() {
   379	        return Err(format!("Log source not found: {source_id}"));
   380	    }
   381	
   382	    Ok(path)
   383	}
   384	
   385	fn read_issue_log_content_sync(
   386	    project_path: &str,
   387	    issue_number: i64,
   388	    source_id: &str,
   389	) -> Result<IssueLogContent, String> {
   390	    let source_path = resolve_issue_log_source_path(project_path, issue_number, source_id)?;
   391	    let metadata = fs::metadata(&source_path)
   392	        .map_err(|e| format!("Failed to read metadata for {source_id}: {e}"))?;
   393	    let bytes = fs::read(&source_path)
   394	        .map_err(|e| format!("Failed to read log source {source_id}: {e}"))?;
   395	
   396	    Ok(IssueLogContent {
   397	        source_id: source_id.to_string(),
   398	        text: String::from_utf8_lossy(&bytes).into_owned(),
   399	        updated_at: file_timestamp(&metadata),
   400	    })
   401	}
