    toggleLevel: (_level: LogLevel) => {
      set((state) => {
        const nextLevelFilters = {
          ...state.levelFilters,
          [_level]: !state.levelFilters[_level],
        };
        if (Object.values(nextLevelFilters).some(Boolean)) {
          return { levelFilters: nextLevelFilters };
        }
        return state;
      });
    },

    setAutoScroll: (_enabled: boolean) => {
      set({
