   100	export function classifyLogLevel(line: string): LogLevel {
   101	  const normalized = line.toLowerCase();
   102	  if (
   103	    normalized.includes('error') ||
   104	    normalized.includes('failed') ||
   105	    normalized.includes('failure') ||
   106	    normalized.includes('fatal') ||
   107	    normalized.includes('❌') ||
   108	    normalized.includes('错误') ||
   109	    normalized.includes('失败')
   110	  ) {
   111	    return 'error';
   112	  }
   113	
   114	  if (
   115	    normalized.includes('warn') ||
   116	    normalized.includes('warning') ||
   117	    normalized.includes('⚠️') ||
   118	    normalized.includes('警告')
   119	  ) {
   120	    return 'warn';
   121	  }
   122	
   123	  return 'info';
   124	}
