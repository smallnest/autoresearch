   126	const MAX_LOG_LINES = 5000;
   127	
   128	export function buildLogEntries(text: string): LogEntry[] {
   129	  if (!text) {
   130	    return [];
   131	  }
   132	
   133	  const lines = text.split(/\r?\n/);
   134	  const start = Math.max(0, lines.length - MAX_LOG_LINES);
   135	  return lines.slice(start).map((line, index) => ({
   136	    lineNumber: start + index + 1,
   137	    text: line,
   138	    level: classifyLogLevel(line),
   139	  }));
   140	}
