  const entries = buildLogEntries('start\nWarning: retry\nbuild failed');
  const filtered = filterLogEntries(entries, 'retry', {
    info: true,
    warn: true,
    error: false,
  });

  assert.deepEqual(
    filtered.map((entry) => entry.text),
    ['Warning: retry']
  );
});

