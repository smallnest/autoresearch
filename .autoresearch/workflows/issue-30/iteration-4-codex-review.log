   142	export function filterLogEntries(
   143	  entries: LogEntry[],
   144	  searchQuery: string,
   145	  levelFilters: Record<LogLevel, boolean>
   146	): LogEntry[] {
   147	  const normalizedQuery = searchQuery.trim().toLowerCase();
   148	  return entries.filter((entry) => {
   149	    if (!levelFilters[entry.level]) {
   150	      return false;
   151	    }
   152	    if (!normalizedQuery) {
   153	      return true;
   154	    }
   155	    return entry.text.toLowerCase().includes(normalizedQuery);
   156	  });
   157	}
