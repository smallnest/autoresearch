   413	fn get_issue_detail_sync(project_path: &str, issue_number: i64) -> Result<IssueDetail, String> {
   414	    let base = Path::new(project_path);
   415	    if !base.is_dir() {
   416	        return Err(format!("Path is not a directory: {project_path}"));
   417	    }
   418	
   419	    // Execute gh issue view
   420	    let output = Command::new("gh")
   421	        .args([
   422	            "issue", "view",
   423	            &issue_number.to_string(),
   424	            "--json", "body,comments",
   425	        ])
   426	        .current_dir(base)
   427	        .output()
   428	        .map_err(|e| format!("Failed to execute gh: {e}"))?;
   429	
   430	    if !output.status.success() {
   431	        let stderr = String::from_utf8_lossy(&output.stderr);
   432	        return Err(map_issue_detail_command_error(issue_number, &stderr));
   433	    }
   434	
   435	    let stdout = String::from_utf8_lossy(&output.stdout);
   436	    parse_issue_detail(&stdout)
   437	}
   438	
   439	/// Lists available workflow log sources for a processed Issue.
   440	#[tauri::command]
   441	async fn list_issue_log_sources(
   442	    project_path: String,
   443	    issue_number: i64,
   444	) -> Result<Vec<IssueLogSource>, String> {
   445	    tokio::task::spawn_blocking(move || list_issue_log_sources_sync(&project_path, issue_number))
   446	        .await
   447	        .map_err(|e| format!("Task join error: {e}"))?
   448	}
