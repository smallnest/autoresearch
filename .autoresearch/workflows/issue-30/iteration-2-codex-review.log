   496	/// Stops the currently running run.sh process by sending SIGTERM to its process group.
   497	#[cfg(unix)]
   498	#[tauri::command]
   499	async fn stop_run(app: tauri::AppHandle) -> Result<(), String> {
   500	    let state = get_run_state();
   501	    let mut state_guard = state.lock().await;
   502	
   503	    let process = state_guard.process.take().ok_or("No run is in progress")?;
   504	    let pid = process.pid;
   505	
   506	    // Mark that we're killing via stop_run, so the wait task doesn't emit duplicate event
   507	    get_was_killed().store(true, Ordering::SeqCst);
   508	
   509	    // Send SIGTERM to the process group
   510	    // Use the PID as PGID since we set it in pre_exec
   511	    let pgid = pid as i32;
   512	
   513	    // Use nix to send signal to process group
   514	    use nix::sys::signal::{killpg, Signal};
   515	    use nix::unistd::Pid;
   516	
   517	    match killpg(Pid::from_raw(pgid), Signal::SIGTERM) {
   518	        Ok(()) => {
   519	            // Emit exit event with killed flag
   520	            let exit_event = RunExitEvent {
   521	                exit_code: None,
   522	                killed: true,
   523	            };
   524	            let _ = app.emit("run-exit", &exit_event);
   525	            Ok(())
   526	        }
   527	        Err(e) => {
   528	            // Restore process state on error
   529	            state_guard.process = Some(process);
   530	            get_was_killed().store(false, Ordering::SeqCst);
   531	            Err(format!("Failed to stop process: {e}"))
   532	        }
   533	    }
   534	}
