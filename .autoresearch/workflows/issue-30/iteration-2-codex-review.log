   378	    // run.sh is in the autoresearch project root, which is the parent of desktop_app
   379	    let autoresearch_root = project_path
   380	        .parent()
   381	        .ok_or("Cannot determine autoresearch root directory")?;
   382	    let run_sh_path = autoresearch_root.join("run.sh");
