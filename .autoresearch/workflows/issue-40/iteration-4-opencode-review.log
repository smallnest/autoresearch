function createMemoryStorage(initialState = {}) {
  const data = new Map(Object.entries(initialState));

  return {
    getItem: (name) => data.get(name) ?? null,
    setItem: (name, value) => {
      data.set(name, value);
    },
    removeItem: (name) => {
      data.delete(name);
    },
    dump: () => Object.fromEntries(data.entries()),
  };
}

